---
import BaseHead from 'src/components/BaseHead.astro';
import Header from 'src/components/Header.astro';
import Footer from 'src/components/Footer.astro';
import { SITE_TITLE } from 'src/consts';

const pageTitle = `About Us — ${SITE_TITLE}`;
const pageDescription = "HelpMini builds lightweight, instant, and 100% client-side private micro-tools for developers, marketers, and AI enthusiasts.";
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={pageTitle} description={pageDescription} />
		<style>
			:root {
				--primary: #6366f1;
				--accent: #06b6d4;
				--bg-dark: #0f172a;
				--text-main: #f8fafc;
				--text-muted: #94a3b8;
				--card-bg: rgba(30, 41, 59, 0.7);
				--card-border: rgba(255, 255, 255, 0.1);
			}
			body {
				background-color: var(--bg-dark);
				color: var(--text-main);
			}
			main {
				width: 800px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 3em 1em 5em;
			}
			.about-header {
				text-align: center;
				margin-bottom: 3em;
			}
			.about-header h1 {
				font-size: 2.5rem;
				font-weight: 800;
				margin-bottom: 0.4em;
				background: linear-gradient(135deg, #ffffff 0%, #a5b4fc 50%, #06b6d4 100%);
				-webkit-background-clip: text;
				-webkit-text-fill-color: transparent;
			}
			.about-header p {
				color: var(--text-muted);
				font-size: 1.15rem;
			}
			.content-card {
				background: var(--card-bg);
				backdrop-filter: blur(12px);
				border: 1px solid var(--card-border);
				border-radius: 16px;
				padding: 2.5em;
				line-height: 1.8;
				box-shadow: 0 4px 20px rgba(0, 0, 0, 0.2);
			}
			.content-card h2 {
				font-size: 1.4rem;
				color: #fff;
				margin: 1.8em 0 0.8em;
				display: flex;
				align-items: center;
				gap: 0.5em;
			}
			.content-card h2:first-child { margin-top: 0; }
			.content-card p {
				color: var(--text-muted);
				margin-bottom: 1.2em;
			}
			.feature-list {
				list-style: none;
				padding: 0;
				margin: 0 0 1.5em;
			}
			.feature-list li {
				margin-bottom: 1em;
				color: var(--text-main);
			}
			.feature-list strong { color: #a5b4fc; }
			.contact-box {
				background: rgba(99, 102, 241, 0.1);
				border: 1px solid rgba(99, 102, 241, 0.25);
				border-radius: 12px;
				padding: 1.5em;
				margin-top: 2em;
				text-align: center;
			}
			.contact-box a {
				color: var(--accent);
				font-weight: 600;
				text-decoration: none;
			}
			.contact-box a:hover { text-decoration: underline; }
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="about-header">
				<h1>About HelpMini</h1>
				<p>🚀 Micro Tools for Big Productivity</p>
			</div>

			<div class="content-card">
				<h2>💡 Our Mission</h2>
				<p>
					<strong>HelpMini</strong> was born out of a simple belief: <strong>in the age of AI and digital business, workflow utilities should be lightweight, instant, and unconditionally private.</strong>
				</p>
				<p>
					Whether you are a web developer, digital marketer, e-commerce entrepreneur, or AI enthusiast, daily tasks often require refining prompts, checking token limits, previewing SEO tags, or formatting JSON strings. Sadly, many traditional web tools are bloated, covered in distracting ads, or silently transmit your confidential payloads to backend servers.
				</p>
				<p>
					That's why we built <strong>HelpMini</strong> — a modern micro-tool suite designed for speed, simplicity, and total peace of mind.
				</p>

				<h2>⚡ Core Principles</h2>
				<ul class="feature-list">
					<li><strong>⚡ Lightning Fast & Instant:</strong> No mandatory sign-ups, no paywalls, and no bloat. Open the tool, get your work done in seconds, and move on with your day.</li>
					<li><strong>🔒 100% Client-Side Privacy:</strong> Your sensitive API keys, confidential configurations, and business copy never leave your browser. All processing runs 100% locally on your client device.</li>
					<li><strong>🎯 Built for Real-World Workflows:</strong> Every single utility in HelpMini is engineered to solve a specific pain point in software development, AI prompt engineering, or cross-border e-commerce operations.</li>
				</ul>

				<h2>🛠️ What We Offer</h2>
				<p>At HelpMini, you'll find micro-utilities and actionable guides tailored for:</p>
				<ul class="feature-list">
					<li><strong>AI & Prompt Optimization:</strong> CO-STAR prompt structurer, LLM token count & context window limits calculator.</li>
					<li><strong>Developer & Data Tools:</strong> Zero-server JSON formatter & validator, Base64 & URL encoder/decoder.</li>
					<li><strong>SEO & Growth Marketing:</strong> Google SERP real-time snippet previews & high-CTR meta tag generators.</li>
				</ul>

				<div class="contact-box">
					<h3 style="margin:0 0 0.5em; color:#fff; font-size:1.1rem;">📫 Get in Touch</h3>
					<p style="margin:0;">Have a suggestion for a new micro-tool, bug report, or business inquiry? Drop us an email anytime:</p>
					<p style="margin:0.5em 0 0; font-size:1.1rem;">
						📧 <a href="mailto:K162000080@gmail.com">K162000080@gmail.com</a>
					</p>
				</div>
			</div>
		</main>
		<Footer />
	</body>
</html>
