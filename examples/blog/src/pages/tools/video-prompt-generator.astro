---
import BaseHead from 'src/components/BaseHead.astro';
import Header from 'src/components/Header.astro';
import Footer from 'src/components/Footer.astro';
import { SITE_TITLE } from 'src/consts';

export const frontmatter = {
    title: "Pro AI Video Prompt Generator",
    description: "Craft cinematic prompts for Sora, Runway Gen-3, Luma Dream Machine, and Kling AI with camera movements, motion speed, and action physics.",
    icon: "🎥",
    tag: "AI Tools",
    keywords: "ai video prompt generator sora prompt helper runway gen-3 video prompt builder camera movement motion speed",
    pinned: true,
    priority: 99
};

const pageTitle = `Pro AI Video Prompt Generator — ${SITE_TITLE}`;
const pageDescription = "Craft cinematic prompts for Sora, Runway Gen-3, Luma Dream Machine, and Kling AI with camera movements, motion speed, and action physics.";
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={pageTitle} description={pageDescription} />
		<style>
			main {
				width: 1000px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 2.5em 1em 4em;
			}
			.tool-header {
				text-align: center;
				margin-bottom: 2em;
			}
			.tool-header h1 {
				font-size: 2.5rem;
				font-weight: 800;
				margin-bottom: 0.3em;
				background: var(--hero-title-gradient);
				-webkit-background-clip: text;
				-webkit-text-fill-color: transparent;
			}
			.tool-header p {
				color: var(--text-muted);
				font-size: 0.95rem;
			}

			.form-grid {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
				gap: 1.2rem;
				background: var(--bg-card);
				border: 1px solid var(--card-border);
				border-radius: 16px;
				padding: 1.8rem;
				backdrop-filter: blur(12px);
				box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
				margin-bottom: 2rem;
			}
			.form-group {
				display: flex;
				flex-direction: column;
				gap: 0.5rem;
			}
			.form-group.full-width {
				grid-column: 1 / -1;
			}
			label {
				font-size: 0.88rem;
				font-weight: 700;
				color: var(--text-main);
				display: flex;
				justify-content: space-between;
				align-items: center;
			}
			label .sub-tag {
				font-size: 0.75rem;
				color: var(--text-muted);
				font-weight: normal;
			}

			input[type="text"], select, textarea {
				width: 100%;
				padding: 0.75em 1em;
				background: var(--search-bg);
				border: 1px solid var(--card-border);
				border-radius: 8px;
				color: var(--text-main);
				font-size: 0.92rem;
				box-sizing: border-box;
				outline: none;
				transition: border-color 0.2s, box-shadow 0.2s;
			}
			input[type="text"]:focus, select:focus, textarea:focus {
				border-color: var(--accent);
				box-shadow: 0 0 10px var(--accent-glow);
			}

			.output-card {
				background: var(--bg-card);
				border: 1px solid var(--card-border);
				border-radius: 16px;
				padding: 1.5rem;
				box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
			}
			.output-header {
				display: flex;
				justify-content: space-between;
				align-items: center;
				margin-bottom: 1rem;
			}
			.output-title {
				font-size: 1.05rem;
				font-weight: 700;
				color: var(--text-main);
			}
			.btn-copy {
				background: var(--accent);
				color: #ffffff;
				border: none;
				padding: 0.6em 1.2em;
				border-radius: 8px;
				font-size: 0.88rem;
				font-weight: 700;
				cursor: pointer;
				transition: all 0.2s ease;
			}
			.btn-copy:hover {
				background: var(--accent-hover);
				transform: translateY(-1px);
			}
			.prompt-output {
				width: 100%;
				height: 140px;
				background: var(--code-bg) !important;
				border: 1px solid var(--card-border);
				border-radius: 10px;
				padding: 1rem;
				color: var(--text-main);
				font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
				font-size: 0.9rem;
				line-height: 1.6;
				resize: vertical;
				box-sizing: border-box;
				outline: none;
			}

			.toast {
				position: fixed;
				bottom: 2rem;
				right: 2rem;
				background: var(--accent);
				color: #fff;
				padding: 0.6em 1.2em;
				border-radius: 8px;
				font-size: 0.88rem;
				font-weight: 600;
				box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
				opacity: 0;
				transform: translateY(10px);
				transition: all 0.3s ease;
				pointer-events: none;
				z-index: 100;
			}
			.toast.show {
				opacity: 1;
				transform: translateY(0);
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="tool-header">
				<h1>🎥 Pro AI Video Prompt Generator</h1>
				<p>Combine cinematic camera movements, dynamic actions, and environmental physics for Sora, Runway Gen-3, Luma & Kling.</p>
			</div>

			<div class="form-grid">
				<!-- Subject & Scene -->
				<div class="form-group full-width">
					<label for="subjectInput">
						Subject & Scene Description
						<span class="sub-tag">Describe the character or environment</span>
					</label>
					<input type="text" id="subjectInput" placeholder="e.g., A raincoat-clad cyberpunk detective walking in a night neon alley..." />
				</div>

				<!-- Subject Action -->
				<div class="form-group full-width">
					<label for="actionInput">
						Subject Action & Motion Dynamics
						<span class="sub-tag">Specify motion details for video consistency</span>
					</label>
					<input type="text" id="actionInput" placeholder="e.g., turning head slowly towards camera, rain droplets running down cheeks, exhaling visible vapor..." />
				</div>

				<!-- Camera Movement -->
				<div class="form-group">
					<label for="cameraMoveSelect">Camera Movement</label>
					<select id="cameraMoveSelect">
						<option value="slow push-in shot">Slow Push-In (Dolly Zoom-In)</option>
						<option value="dolly pull-out shot">Dolly Pull-Out Shot</option>
						<option value="smooth tracking shot following the subject">Smooth Tracking Shot (Following)</option>
						<option value="360-degree orbit shot around the subject">360-Degree Orbit Shot</option>
						<option value="pan right camera movement">Horizontal Pan Movement</option>
						<option value="fpv drone fly-through shot">FPV Drone Fly-Through</option>
						<option value="cinematic handheld camera shake">Cinematic Handheld (Documentary Shake)</option>
						<option value="static camera shot">Static Locked-Off Shot</option>
					</select>
				</div>

				<!-- Focus Control -->
				<div class="form-group">
					<label for="focusSelect">Focus & Rack Movement</label>
					<select id="focusSelect">
						<option value="">Unspecified</option>
						<option value="rack focus from foreground to background">Rack Focus (Foreground to Background)</option>
						<option value="shallow depth of field with sharp focus on subject">Shallow Depth of Field (Crisp Isolation)</option>
						<option value="macro close-up focus on eyes">Macro Extreme Detail Focus</option>
					</select>
				</div>

				<!-- Speed & Motion Pace -->
				<div class="form-group">
					<label for="speedSelect">Motion Pace & Speed</label>
					<select id="speedSelect">
						<option value="real-time motion">Real-Time Natural Flow</option>
						<option value="slow-motion 60fps, smooth motion">60fps Cinematic Slow Motion</option>
						<option value="hyperlapse time-lapse style, fast moving environment">Hyperlapse / Time-Lapse (Fast Environment)</option>
					</select>
				</div>

				<!-- Environmental Physics -->
				<div class="form-group">
					<label for="envSelect">Environmental Physics & Dynamics</label>
					<select id="envSelect">
						<option value="rain splashing on ground, neon lights reflection">Rain Splashing & Glowing Reflections</option>
						<option value="wind blowing through hair and clothes">Wind Blowing Hair & Garments</option>
						<option value="floating dust particles in volumetric light rays">Floating Dust Particles & Volumetric Rays</option>
						<option value="smoke and fog drifting slowly">Drifting Smoke & Atmospheric Fog</option>
						<option value="">None</option>
					</select>
				</div>

				<!-- Lighting Style -->
				<div class="form-group">
					<label for="lightingSelect">Cinematic Lighting</label>
					<select id="lightingSelect">
						<option value="cinematic volumetric lighting">Volumetric Atmosphere Lighting</option>
						<option value="golden hour sunset lighting">Golden Hour Warm Diffuse Sunset</option>
						<option value="cyberpunk neon lighting, flickering glow">Cyberpunk Flickering Neon Glow</option>
						<option value="dramatic rim lighting">Dramatic Edge Rim Lighting</option>
					</select>
				</div>

				<!-- Video Quality & Film Grain -->
				<div class="form-group">
					<label for="qualitySelect">Video Quality & Aesthetic</label>
					<select id="qualitySelect">
						<option value="photorealistic 8k video, photorealistic details, 35mm film grain">Photorealistic 8K Video, 35mm Film Grain (Recommended)</option>
						<option value="commercial 4k video, smooth movement, clean colors">Commercial 4K, Ultra-Smooth Motion</option>
						<option value="vintage 90s camcorder vhs style">Vintage 90s VHS Camcorder Aesthetic</option>
					</select>
				</div>
			</div>

			<!-- Realtime Output -->
			<div class="output-card">
				<div class="output-header">
					<span class="output-title">✨ Generated Video Prompt (Sora / Runway / Luma / Kling)</span>
					<button class="btn-copy" id="btnCopy">📋 Copy Video Prompt</button>
				</div>
				<textarea id="promptOutput" class="prompt-output" readonly></textarea>
			</div>
		</main>

		<div id="toast" class="toast">Video prompt copied to clipboard!</div>

		<Footer />

		<script is:inline>
			const subjectInput = document.getElementById('subjectInput');
			const actionInput = document.getElementById('actionInput');
			const cameraMoveSelect = document.getElementById('cameraMoveSelect');
			const focusSelect = document.getElementById('focusSelect');
			const speedSelect = document.getElementById('speedSelect');
			const envSelect = document.getElementById('envSelect');
			const lightingSelect = document.getElementById('lightingSelect');
			const qualitySelect = document.getElementById('qualitySelect');

			const promptOutput = document.getElementById('promptOutput');
			const btnCopy = document.getElementById('btnCopy');
			const toast = document.getElementById('toast');

			function buildPrompt() {
				const subject = subjectInput.value.trim() || 'A cyberpunk detective in neon city';
				const action = actionInput.value.trim() || 'walking down the rain-soaked street, turning head slowly to look at the camera';

				const components = [
					cameraMoveSelect.value,
					`of ${subject}`,
					action,
					envSelect.value,
					focusSelect.value,
					speedSelect.value,
					lightingSelect.value,
					qualitySelect.value
				].filter(Boolean);

				promptOutput.value = components.join(', ');
			}

			[
				subjectInput, actionInput, cameraMoveSelect, focusSelect,
				speedSelect, envSelect, lightingSelect, qualitySelect
			].forEach(el => {
				el?.addEventListener('input', buildPrompt);
				el?.addEventListener('change', buildPrompt);
			});

			buildPrompt();

			btnCopy?.addEventListener('click', () => {
				if (!promptOutput.value) return;
				navigator.clipboard.writeText(promptOutput.value).then(() => {
					toast.classList.add('show');
					setTimeout(() => toast.classList.remove('show'), 2000);
				});
			});
		</script>
	</body>
</html>
