---
import BaseHead from 'src/components/BaseHead.astro';
import Header from 'src/components/Header.astro';
import Footer from 'src/components/Footer.astro';
import { SITE_TITLE } from 'src/consts';

export const frontmatter = {
    title: "Pro AI Fashion & Outfit Prompt Generator",
    description: "Craft fashion & outfit prompts for Midjourney, Flux, and SDXL with precise control over style, layers, fabrics, cuts, and accessories.",
    icon: "👗",
    tag: "AI Tools",
    keywords: "ai outfit prompt generator fashion prompt builder midjourney outfit swap flux fashion generator clothes replacement",
    pinned: true,
    priority: 97
};

const pageTitle = `Pro AI Fashion & Outfit Prompt Generator — ${SITE_TITLE}`;
const pageDescription = "Craft fashion & outfit prompts for Midjourney, Flux, and SDXL with precise control over style, layers, fabrics, cuts, and accessories.";
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={pageTitle} description={pageDescription} />
		<style>
			main {
				width: 1000px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 2.5em 1em 4em;
			}
			.tool-header {
				text-align: center;
				margin-bottom: 2em;
			}
			.tool-header h1 {
				font-size: 2.5rem;
				font-weight: 800;
				margin-bottom: 0.3em;
				background: var(--hero-title-gradient);
				-webkit-background-clip: text;
				-webkit-text-fill-color: transparent;
			}
			.tool-header p {
				color: var(--text-muted);
				font-size: 0.95rem;
			}

			.form-grid {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
				gap: 1.2rem;
				background: var(--bg-card);
				border: 1px solid var(--card-border);
				border-radius: 16px;
				padding: 1.8rem;
				backdrop-filter: blur(12px);
				box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
				margin-bottom: 2rem;
			}
			.form-group {
				display: flex;
				flex-direction: column;
				gap: 0.5rem;
			}
			.form-group.full-width {
				grid-column: 1 / -1;
			}
			label {
				font-size: 0.88rem;
				font-weight: 700;
				color: var(--text-main);
				display: flex;
				justify-content: space-between;
				align-items: center;
			}
			label .sub-tag {
				font-size: 0.75rem;
				color: var(--text-muted);
				font-weight: normal;
			}

			input[type="text"], select, textarea {
				width: 100%;
				padding: 0.75em 1em;
				background: var(--search-bg);
				border: 1px solid var(--card-border);
				border-radius: 8px;
				color: var(--text-main);
				font-size: 0.92rem;
				box-sizing: border-box;
				outline: none;
				transition: border-color 0.2s, box-shadow 0.2s;
			}
			input[type="text"]:focus, select:focus, textarea:focus {
				border-color: var(--accent);
				box-shadow: 0 0 10px var(--accent-glow);
			}

			.output-card {
				background: var(--bg-card);
				border: 1px solid var(--card-border);
				border-radius: 16px;
				padding: 1.5rem;
				box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
			}
			.output-header {
				display: flex;
				justify-content: space-between;
				align-items: center;
				margin-bottom: 1rem;
			}
			.output-title {
				font-size: 1.05rem;
				font-weight: 700;
				color: var(--text-main);
			}
			.btn-copy {
				background: var(--accent);
				color: #ffffff;
				border: none;
				padding: 0.6em 1.2em;
				border-radius: 8px;
				font-size: 0.88rem;
				font-weight: 700;
				cursor: pointer;
				transition: all 0.2s ease;
			}
			.btn-copy:hover {
				background: var(--accent-hover);
				transform: translateY(-1px);
			}
			.prompt-output {
				width: 100%;
				height: 140px;
				background: var(--code-bg) !important;
				border: 1px solid var(--card-border);
				border-radius: 10px;
				padding: 1rem;
				color: var(--text-main);
				font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
				font-size: 0.9rem;
				line-height: 1.6;
				resize: vertical;
				box-sizing: border-box;
				outline: none;
			}

			.toast {
				position: fixed;
				bottom: 2rem;
				right: 2rem;
				background: var(--accent);
				color: #fff;
				padding: 0.6em 1.2em;
				border-radius: 8px;
				font-size: 0.88rem;
				font-weight: 600;
				box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
				opacity: 0;
				transform: translateY(10px);
				transition: all 0.3s ease;
				pointer-events: none;
				z-index: 100;
			}
			.toast.show {
				opacity: 1;
				transform: translateY(0);
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="tool-header">
				<h1>👗 Pro AI Fashion & Outfit Prompt Generator</h1>
				<p>Design clothing styles, luxury fabrics, tailored cuts, and accessories for consistent character outfit swapping in Midjourney & Flux.</p>
			</div>

			<div class="form-grid">
				<!-- Model Description -->
				<div class="form-group full-width">
					<label for="modelInput">
						Model Features & Facial Consistency
						<span class="sub-tag">Describe model facial features/hair to maintain consistency</span>
					</label>
					<input type="text" id="modelInput" placeholder="e.g., A 20s East Asian female model with dark medium hair and subtle makeup..." />
				</div>

				<!-- Fashion Style Category -->
				<div class="form-group">
					<label for="styleSelect">Fashion Style Category</label>
					<select id="styleSelect">
						<option value="Quiet Luxury, minimal old money aesthetic">Quiet Luxury (Old Money Minimalist)</option>
						<option value="high fashion Vogue editorial style">High Fashion Editorial (Vogue Style)</option>
						<option value="cyberpunk techwear outfit with neon accents">Cyberpunk Techwear</option>
						<option value="Parisian chic street style, effortless elegance">Parisian Chic Street Style</option>
						<option value="Y2K streetwear style with oversized silhouette">Y2K Retro Streetwear</option>
						<option value="Bohemian minimalist resort wear">Boho Resort & Cruise Wear</option>
						<option value="formal haute couture evening gown style">Haute Couture Evening Wear</option>
					</select>
				</div>

				<!-- Top / Outerwear -->
				<div class="form-group">
					<label for="topSelect">Top / Outerwear Layer</label>
					<select id="topSelect">
						<option value="oversized double-breasted beige trench coat">Oversized Double-Breasted Beige Trench Coat</option>
						<option value="tailored black leather jacket with silver zips">Tailored Black Leather Jacket</option>
						<option value="cozy oversized chunky knit sweater">Cozy Oversized Chunky Knit Sweater</option>
						<option value="sharp structured oversized blazer">Sharp Structured Oversized Blazer</option>
						<option value="silk satin button-down shirt">100% Mulberry Silk Satin Shirt</option>
						<option value="cropped denim jacket">Cropped Denim Jacket</option>
						<option value="">None / Dress Only</option>
					</select>
				</div>

				<!-- Bottom / Dress -->
				<div class="form-group">
					<label for="bottomSelect">Bottom / Dress Layer</label>
					<select id="bottomSelect">
						<option value="paired with high-waisted wide-leg tailored trousers">High-Waisted Wide-Leg Trousers</option>
						<option value="wearing an elegant slip silk maxi dress">Elegant Silk Slip Maxi Dress</option>
						<option value="paired with vintage straight-leg washed jeans">Vintage Straight-Leg Washed Jeans</option>
						<option value="paired with pleated A-line midi skirt">Pleated A-Line Midi Skirt</option>
						<option value="paired with sleek fitted leather pants">Sleek Fitted Leather Pants</option>
					</select>
				</div>

				<!-- Fabric & Material Texture -->
				<div class="form-group">
					<label for="fabricSelect">Fabrics & Material Texture</label>
					<select id="fabricSelect">
						<option value="premium mulberry silk, ribbed cashmere, distressed leather">Mulberry Silk, Ribbed Cashmere & Leather Mix</option>
						<option value="100% heavy silk satin with soft luster">Heavy Silk Satin with Soft Luster</option>
						<option value="textured tweed fabric with golden threads">Tweed Fabric Interwoven with Gold Thread</option>
						<option value="matte soft lambskin leather">Matte Soft Lambskin Leather</option>
						<option value="sheer organza and delicate lace details">Sheer Organza & Delicate Lace Details</option>
						<option value="raw rigid cotton denim texture">Raw Rigid Cotton Denim Texture</option>
					</select>
				</div>

				<!-- Shoes & Accessories -->
				<div class="form-group">
					<label for="accessorySelect">Shoes & Fashion Accessories</label>
					<select id="accessorySelect">
						<option value="styled with chunky gold hoop earrings, a vintage leather handbag, and pointy heels">Gold Hoop Earrings, Leather Handbag & Pointy Heels</option>
						<option value="styled with leather Chelsea boots, silver chain necklace, and dark sunglasses">Chelsea Leather Boots, Silver Chain & Dark Sunglasses</option>
						<option value="accessorized with minimalist gold watch and designer leather crossbody bag">Minimalist Gold Watch & Designer Crossbody Bag</option>
						<option value="styled with retro sneakers and baseball cap">Retro Chunky Sneakers & Baseball Cap</option>
					</select>
				</div>

				<!-- Lookbook Pose -->
				<div class="form-group">
					<label for="poseSelect">Lookbook Modeling Pose</label>
					<select id="poseSelect">
						<option value="full-body lookbook fashion shot, walking on street, candid look">Full-Body Street Walking Candid Shot</option>
						<option value="three-quarter length studio portrait shot, confident stance">3/4 Studio Portrait Confident Stance</option>
						<option value="street style candid photography shot, natural lighting">Natural Light Street Style Photography</option>
						<option value="runway fashion show walk pose, dramatic lighting">Runway Catwalk Fashion Show Pose</option>
					</select>
				</div>

				<!-- Aspect Ratio (--ar) -->
				<div class="form-group">
					<label for="arSelect">Aspect Ratio (--ar)</label>
					<select id="arSelect">
						<option value="--ar 4:5">--ar 4:5 (Instagram / Lookbook Poster Vertical)</option>
						<option value="--ar 3:4">--ar 3:4 (Standard E-Commerce Outfit Shot)</option>
						<option value="--ar 9:16">--ar 9:16 (Full Screen Mobile Poster)</option>
						<option value="--ar 16:9">--ar 16:9 (Landscape Runway Banner)</option>
					</select>
				</div>
			</div>

			<!-- Realtime Output -->
			<div class="output-card">
				<div class="output-header">
					<span class="output-title">✨ Generated Outfit Prompt (Midjourney / Flux / SD)</span>
					<button class="btn-copy" id="btnCopy">📋 Copy Prompt</button>
				</div>
				<textarea id="promptOutput" class="prompt-output" readonly></textarea>
			</div>
		</main>

		<div id="toast" class="toast">Outfit prompt copied to clipboard!</div>

		<Footer />

		<script is:inline>
			const modelInput = document.getElementById('modelInput');
			const styleSelect = document.getElementById('styleSelect');
			const topSelect = document.getElementById('topSelect');
			const bottomSelect = document.getElementById('bottomSelect');
			const fabricSelect = document.getElementById('fabricSelect');
			const accessorySelect = document.getElementById('accessorySelect');
			const poseSelect = document.getElementById('poseSelect');
			const arSelect = document.getElementById('arSelect');

			const promptOutput = document.getElementById('promptOutput');
			const btnCopy = document.getElementById('btnCopy');
			const toast = document.getElementById('toast');

			function buildPrompt() {
				const modelDesc = modelInput.value.trim() || 'A beautiful East Asian female model';
				
				const components = [
					poseSelect.value,
					`featuring ${modelDesc}`,
					`wearing ${styleSelect.value}`,
					topSelect.value,
					bottomSelect.value,
					`crafted from ${fabricSelect.value}`,
					accessorySelect.value,
					'shot on Hasselblad H6D-100c, soft studio lighting, ultra-detailed fabric texture, 8k resolution, raw photo',
					arSelect.value
				].filter(Boolean);

				promptOutput.value = components.join(', ');
			}

			[
				modelInput, styleSelect, topSelect, bottomSelect,
				fabricSelect, accessorySelect, poseSelect, arSelect
			].forEach(el => {
				el?.addEventListener('input', buildPrompt);
				el?.addEventListener('change', buildPrompt);
			});

			buildPrompt();

			btnCopy?.addEventListener('click', () => {
				if (!promptOutput.value) return;
				navigator.clipboard.writeText(promptOutput.value).then(() => {
					toast.classList.add('show');
					setTimeout(() => toast.classList.remove('show'), 2000);
				});
			});
		</script>
	</body>
</html>
