---
import BaseHead from 'src/components/BaseHead.astro';
import Header from 'src/components/Header.astro';
import Footer from 'src/components/Footer.astro';
import { SITE_TITLE } from 'src/consts';

const pageTitle = `Base64 & URL Encoder/Decoder — ${SITE_TITLE}`;
const pageDescription = "Fast, 100% private online tool to encode and decode Base64 text and URL parameters.";
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={pageTitle} description={pageDescription} />
		<style>
			:root {
				--primary: #6366f1;
				--primary-hover: #4f46e5;
				--accent: #06b6d4;
				--bg-dark: #0f172a;
				--text-main: #f8fafc;
				--text-muted: #94a3b8;
				--card-bg: rgba(30, 41, 59, 0.7);
				--card-border: rgba(255, 255, 255, 0.1);
			}
			body {
				background-color: var(--bg-dark);
				color: var(--text-main);
			}
			main {
				width: 850px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 3em 1em 5em;
			}
			.tool-header {
				text-align: center;
				margin-bottom: 2em;
			}
			.tool-header h1 {
				font-size: 2.2rem;
				font-weight: 800;
				margin-bottom: 0.3em;
				background: linear-gradient(135deg, #ffffff 0%, #a5b4fc 50%, #06b6d4 100%);
				-webkit-background-clip: text;
				-webkit-text-fill-color: transparent;
			}
			.tool-header p {
				color: var(--text-muted);
				font-size: 1.05rem;
			}
			.tool-box {
				background: var(--card-bg);
				backdrop-filter: blur(12px);
				border: 1px solid var(--card-border);
				border-radius: 16px;
				padding: 2em;
				box-shadow: 0 4px 20px rgba(0, 0, 0, 0.2);
			}
			.tab-group {
				display: flex;
				gap: 0.8rem;
				margin-bottom: 1.5em;
				border-bottom: 1px solid var(--card-border);
				padding-bottom: 0.8em;
			}
			.tab-btn {
				background: none;
				border: none;
				color: var(--text-muted);
				font-size: 1rem;
				font-weight: 600;
				cursor: pointer;
				padding: 0.4em 0.8em;
				border-radius: 6px;
				transition: all 0.2s;
			}
			.tab-btn.active {
				background: rgba(99, 102, 241, 0.2);
				color: #a5b4fc;
				border: 1px solid rgba(99, 102, 241, 0.4);
			}
			.btn-group {
				display: flex;
				gap: 0.8rem;
				margin: 1rem 0;
			}
			.btn {
				background: var(--primary);
				color: #fff;
				border: none;
				padding: 0.6em 1.2em;
				border-radius: 8px;
				font-weight: 600;
				cursor: pointer;
				transition: background 0.2s;
			}
			.btn:hover { background: var(--primary-hover); }
			.btn-secondary { background: rgba(255, 255, 255, 0.1); }
			.btn-secondary:hover { background: rgba(255, 255, 255, 0.2); }
			textarea {
				width: 100%;
				height: 160px;
				padding: 1em;
				background: #0f172a;
				border: 1px solid var(--card-border);
				border-radius: 10px;
				color: #fff;
				font-size: 0.95rem;
				font-family: monospace;
				box-sizing: border-box;
				outline: none;
				resize: vertical;
			}
			textarea:focus { border-color: var(--primary); }
			label { display: block; font-weight: 600; margin-bottom: 0.5em; }
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="tool-header">
				<h1>🔤 Base64 & URL Encoder / Decoder</h1>
				<p>100% client-side text and URL parameter conversion.</p>
			</div>

			<div class="tool-box">
				<div class="tab-group">
					<button class="tab-btn active" id="modeBase64">Base64 Mode</button>
					<button class="tab-btn" id="modeURL">URL Mode</button>
				</div>

				<div>
					<label for="inputText">Input Text / Raw String:</label>
					<textarea id="inputText" placeholder="Type or paste text here..."></textarea>
				</div>

				<div class="btn-group">
					<button class="btn" id="btnEncode">Encode</button>
					<button class="btn" id="btnDecode">Decode</button>
					<button class="btn btn-secondary" id="btnClear">Clear</button>
					<button class="btn btn-secondary" id="btnCopy" style="margin-left: auto;">Copy Result</button>
				</div>

				<div>
					<label for="outputText">Output Result:</label>
					<textarea id="outputText" readonly placeholder="Output will appear here..."></textarea>
				</div>
			</div>
		</main>
		<Footer />

		<script>
			let currentMode = 'base64';
			const modeBase64 = document.getElementById('modeBase64');
			const modeURL = document.getElementById('modeURL');
			const inputText = document.getElementById('inputText') as HTMLTextAreaElement;
			const outputText = document.getElementById('outputText') as HTMLTextAreaElement;

			modeBase64?.addEventListener('click', () => {
				currentMode = 'base64';
				modeBase64.classList.add('active');
				modeURL?.classList.remove('active');
			});

			modeURL?.addEventListener('click', () => {
				currentMode = 'url';
				modeURL.classList.add('active');
				modeBase64?.classList.remove('active');
			});

			document.getElementById('btnEncode')?.addEventListener('click', () => {
				const val = inputText.value;
				try {
					if (currentMode === 'base64') {
						// 支持 UTF-8 中文 Base64 编码
						outputText.value = btoa(encodeURIComponent(val).replace(/%([0-9A-F]{2})/g, (match, p1) => String.fromCharCode(parseInt(p1, 16))));
					} else {
						outputText.value = encodeURIComponent(val);
					}
				} catch (e: any) {
					outputText.value = 'Encoding error: ' + e.message;
				}
			});

			document.getElementById('btnDecode')?.addEventListener('click', () => {
				const val = inputText.value;
				try {
					if (currentMode === 'base64') {
						outputText.value = decodeURIComponent(Array.prototype.map.call(atob(val.trim()), (c) => '%' + ('00' + c.charCodeAt(0).toString(16)).slice(-2)).join(''));
					} else {
						outputText.value = decodeURIComponent(val);
					}
				} catch (e: any) {
					outputText.value = 'Decoding error: Invalid input format.';
				}
			});

			document.getElementById('btnClear')?.addEventListener('click', () => {
				inputText.value = '';
				outputText.value = '';
			});

			document.getElementById('btnCopy')?.addEventListener('click', (e) => {
				if (!outputText.value) return;
				navigator.clipboard.writeText(outputText.value);
				const btn = e.target as HTMLButtonElement;
				btn.textContent = 'Copied!';
				setTimeout(() => { btn.textContent = 'Copy Result'; }, 2000);
			});
		</script>
	</body>
</html>
