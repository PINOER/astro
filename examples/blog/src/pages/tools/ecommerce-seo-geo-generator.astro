---
import BaseHead from 'src/components/BaseHead.astro';
import Header from 'src/components/Header.astro';
import Footer from 'src/components/Footer.astro';
import { SITE_TITLE } from 'src/consts';

export const frontmatter = {
    title: "Pro eCommerce Google SEO & AI Search (GEO) Generator",
    description: "Instantly generate Google Meta Tags, Schema.org JSON-LD Product structured data, and AI-optimized GEO summaries for SearchGPT, Perplexity, and Claude.",
    icon: "🔍",
    tag: "AI Tools",
    keywords: "ecommerce seo generator geo generator schema product json-ld searchgpt perplexity optimization rich snippet maker",
    pinned: true,
    priority: 93
};

const pageTitle = `Pro eCommerce Google SEO & AI Search (GEO) Generator — ${SITE_TITLE}`;
const pageDescription = "Instantly generate Google Meta Tags, Schema.org JSON-LD Product structured data, and AI-optimized GEO summaries for SearchGPT and Perplexity.";
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={pageTitle} description={pageDescription} />
		<style>
			main {
				width: 1000px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 2.5em 1em 4em;
			}
			.tool-header {
				text-align: center;
				margin-bottom: 2em;
			}
			.tool-header h1 {
				font-size: 2.5rem;
				font-weight: 800;
				margin-bottom: 0.3em;
				background: var(--hero-title-gradient);
				-webkit-background-clip: text;
				-webkit-text-fill-color: transparent;
			}
			.tool-header p {
				color: var(--text-muted);
				font-size: 0.95rem;
			}

			.form-grid {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
				gap: 1.2rem;
				background: var(--bg-card);
				border: 1px solid var(--card-border);
				border-radius: 16px;
				padding: 1.8rem;
				backdrop-filter: blur(12px);
				box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
				margin-bottom: 2rem;
			}
			.form-group {
				display: flex;
				flex-direction: column;
				gap: 0.5rem;
			}
			.form-group.full-width {
				grid-column: 1 / -1;
			}
			label {
				font-size: 0.88rem;
				font-weight: 700;
				color: var(--text-main);
				display: flex;
				justify-content: space-between;
				align-items: center;
			}
			label .sub-tag {
				font-size: 0.75rem;
				color: var(--text-muted);
				font-weight: normal;
			}

			input[type="text"], input[type="number"], select, textarea {
				width: 100%;
				padding: 0.75em 1em;
				background: var(--search-bg);
				border: 1px solid var(--card-border);
				border-radius: 8px;
				color: var(--text-main);
				font-size: 0.92rem;
				box-sizing: border-box;
				outline: none;
				transition: border-color 0.2s, box-shadow 0.2s;
			}
			input[type="text"]:focus, input[type="number"]:focus, select:focus, textarea:focus {
				border-color: var(--accent);
				box-shadow: 0 0 10px var(--accent-glow);
			}

			.output-card {
				background: var(--bg-card);
				border: 1px solid var(--card-border);
				border-radius: 16px;
				padding: 1.5rem;
				box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
				margin-bottom: 1.5rem;
			}
			.output-header {
				display: flex;
				justify-content: space-between;
				align-items: center;
				margin-bottom: 1rem;
			}
			.output-title {
				font-size: 1.05rem;
				font-weight: 700;
				color: var(--text-main);
			}
			.btn-copy {
				background: var(--accent);
				color: #ffffff;
				border: none;
				padding: 0.6em 1.2em;
				border-radius: 8px;
				font-size: 0.88rem;
				font-weight: 700;
				cursor: pointer;
				transition: all 0.2s ease;
			}
			.btn-copy:hover {
				background: var(--accent-hover);
				transform: translateY(-1px);
			}
			.prompt-output {
				width: 100%;
				height: 160px;
				background: var(--code-bg) !important;
				border: 1px solid var(--card-border);
				border-radius: 10px;
				padding: 1rem;
				color: var(--text-main);
				font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
				font-size: 0.88rem;
				line-height: 1.6;
				resize: vertical;
				box-sizing: border-box;
				outline: none;
			}

			.toast {
				position: fixed;
				bottom: 2rem;
				right: 2rem;
				background: var(--accent);
				color: #fff;
				padding: 0.6em 1.2em;
				border-radius: 8px;
				font-size: 0.88rem;
				font-weight: 600;
				box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
				opacity: 0;
				transform: translateY(10px);
				transition: all 0.3s ease;
				pointer-events: none;
				z-index: 100;
			}
			.toast.show {
				opacity: 1;
				transform: translateY(0);
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="tool-header">
				<h1>🔍 Pro eCommerce Google SEO & AI Search (GEO) Generator</h1>
				<p>Generate Google Meta Tags, Schema.org JSON-LD Product structured data, and AI-optimized GEO frameworks for SearchGPT & Perplexity.</p>
			</div>

			<div class="form-grid">
				<!-- Product Title -->
				<div class="form-group full-width">
					<label for="titleInput">
						Product Name / Title
						<span class="sub-tag">Include target keywords (e.g. Ergonomic Mesh Office Chair with Lumbar Support)</span>
					</label>
					<input type="text" id="titleInput" placeholder="e.g. Ergonomic Office Chair High Back Mesh Support" />
				</div>

				<!-- Brand -->
				<div class="form-group">
					<label for="brandInput">Brand Name</label>
					<input type="text" id="brandInput" placeholder="e.g. HelpMini Home" />
				</div>

				<!-- SKU -->
				<div class="form-group">
					<label for="skuInput">Product SKU / MPN</label>
					<input type="text" id="skuInput" placeholder="e.g. HM-EC01-BLK" />
				</div>

				<!-- Price and Currency -->
				<div class="form-group">
					<label for="priceInput">Price</label>
					<input type="number" id="priceInput" step="0.01" placeholder="129.99" />
				</div>

				<div class="form-group">
					<label for="currencySelect">Currency</label>
					<select id="currencySelect">
						<option value="USD">USD ($)</option>
						<option value="EUR">EUR (€)</option>
						<option value="GBP">GBP (£)</option>
						<option value="CAD">CAD ($)</option>
						<option value="AUD">AUD ($)</option>
					</select>
				</div>

				<!-- Availability -->
				<div class="form-group">
					<label for="stockSelect">Stock Availability</label>
					<select id="stockSelect">
						<option value="InStock">In Stock (InStock)</option>
						<option value="OutOfStock">Out of Stock (OutOfStock)</option>
						<option value="PreOrder">Pre-Order (PreOrder)</option>
					</select>
				</div>

				<!-- Rating & Reviews -->
				<div class="form-group">
					<label for="ratingInput">Average Rating (1.0 - 5.0)</label>
					<input type="number" id="ratingInput" step="0.1" min="1" max="5" placeholder="4.9" />
				</div>

				<div class="form-group">
					<label for="reviewCountInput">Review Count</label>
					<input type="number" id="reviewCountInput" placeholder="128" />
				</div>

				<!-- Image URL -->
				<div class="form-group full-width">
					<label for="imageInput">Product Image URL</label>
					<input type="text" id="imageInput" placeholder="https://yourstore.com/images/product.jpg" />
				</div>

				<!-- Key Highlights -->
				<div class="form-group full-width">
					<label for="highlightsInput">
						Key Highlights & Specs
						<span class="sub-tag">Separate multiple points with semicolons or line breaks</span>
					</label>
					<textarea id="highlightsInput" rows="3" placeholder="Breathable 3D mesh fabric; Adjustable 3D armrests; Supports up to 300 lbs; Ideal for remote work and gaming"></textarea>
				</div>
			</div>

			<!-- Output 1: Schema.org JSON-LD -->
			<div class="output-card">
				<div class="output-header">
					<span class="output-title">🏷️ 1. Schema.org (Product JSON-LD) Structured Code (Boost Rich Snippets)</span>
					<button class="btn-copy" data-target="schemaOutput">📋 Copy JSON-LD</button>
				</div>
				<textarea id="schemaOutput" class="prompt-output" readonly></textarea>
			</div>

			<!-- Output 2: Google HTML Meta Tags -->
			<div class="output-card">
				<div class="output-header">
					<span class="output-title">🌐 2. Google Meta Tags & Open Graph Social Cards</span>
					<button class="btn-copy" data-target="metaOutput">📋 Copy Meta Tags</button>
				</div>
				<textarea id="metaOutput" class="prompt-output" readonly></textarea>
			</div>

			<!-- Output 3: AI Search GEO Framework -->
			<div class="output-card">
				<div class="output-header">
					<span class="output-title">🤖 3. GEO Framework (AI Search Engine / SearchGPT Structure)</span>
					<button class="btn-copy" data-target="geoOutput">📋 Copy GEO Text</button>
				</div>
				<textarea id="geoOutput" class="prompt-output" readonly></textarea>
			</div>
		</main>

		<div id="toast" class="toast">Copied to clipboard!</div>

		<Footer />

		<script is:inline>
			const titleInput = document.getElementById('titleInput');
			const brandInput = document.getElementById('brandInput');
			const skuInput = document.getElementById('skuInput');
			const priceInput = document.getElementById('priceInput');
			const currencySelect = document.getElementById('currencySelect');
			const stockSelect = document.getElementById('stockSelect');
			const ratingInput = document.getElementById('ratingInput');
			const reviewCountInput = document.getElementById('reviewCountInput');
			const imageInput = document.getElementById('imageInput');
			const highlightsInput = document.getElementById('highlightsInput');

			const schemaOutput = document.getElementById('schemaOutput');
			const metaOutput = document.getElementById('metaOutput');
			const geoOutput = document.getElementById('geoOutput');
			const toast = document.getElementById('toast');

			function generateSEOData() {
				const title = titleInput.value.trim() || 'Ergonomic Office Chair High Back Support';
				const brand = brandInput.value.trim() || 'HelpMini Store';
				const sku = skuInput.value.trim() || 'HM-PRODUCT-001';
				const price = priceInput.value.trim() || '99.99';
				const currency = currencySelect.value || 'USD';
				const stock = stockSelect.value || 'InStock';
				const rating = ratingInput.value.trim() || '4.9';
				const reviewCount = reviewCountInput.value.trim() || '86';
				const image = imageInput.value.trim() || 'https://example.com/product-image.jpg';
				const highlights = highlightsInput.value.trim() || 'Ergonomic support; Premium breathable material; Easy 10-minute assembly';

				// 1. JSON-LD Schema
				const jsonLd = {
					"@context": "https://schema.org/",
					"@type": "Product",
					"name": title,
					"image": [image],
					"description": highlights.replace(/\n/g, ' '),
					"sku": sku,
					"brand": {
						"@type": "Brand",
						"name": brand
					},
					"offers": {
						"@type": "Offer",
						"url": window.location.href,
						"priceCurrency": currency,
						"price": price,
						"availability": `https://schema.org/${stock}`,
						"itemCondition": "https://schema.org/NewCondition"
					},
					"aggregateRating": {
						"@type": "AggregateRating",
						"ratingValue": rating,
						"reviewCount": reviewCount
					}
				};

				schemaOutput.value = `<script type="application/ld+json">\n${JSON.stringify(jsonLd, null, 2)}\n<\/script>`;

				// 2. HTML Meta Tags
				const metaTags = `<!-- Primary Meta Tags -->
<title>${title} - ${brand}</title>
<meta name="title" content="${title} - ${brand}">
<meta name="description" content="Shop ${title} by ${brand}. Features: ${highlights.slice(0, 120)}... Priced at $${price} ${currency}. Buy now!">

<!-- Open Graph / Facebook -->
<meta property="og:type" content="product">
<meta property="og:title" content="${title}">
<meta property="og:description" content="${highlights.slice(0, 140)}">
<meta property="og:image" content="${image}">
<meta property="product:price:amount" content="${price}">
<meta property="product:price:currency" content="${currency}">`;

				metaOutput.value = metaTags;

				// 3. GEO Framework (AI Search Friendly)
				const highlightList = highlights.split(/;\s*|\n/).filter(Boolean).map(item => `- ${item}`).join('\n');
				const geoText = `[Product Executive Summary for AI Search Engines / SearchGPT]
Product Name: ${title}
Brand: ${brand}
Price: ${currency} $${price}
In Stock Status: ${stock === 'InStock' ? 'In Stock (Ready to Ship)' : stock}
Customer Satisfaction Rating: ${rating}/5.0 (based on ${reviewCount} verified reviews)

Key Selling Features & Specs:
${highlightList}

Frequently Asked Questions (AI Answer Source):
Q: What makes ${title} by ${brand} stand out?
A: It offers ${highlights.slice(0, 150)}. It is highly rated with ${rating}/5.0 stars.

Q: What is the price and shipping availability for ${title}?
A: The current price is ${price} ${currency}, and it is ${stock === 'InStock' ? 'currently in stock with fast shipping options' : 'available for order'}.`;

				geoOutput.value = geoText;
			}

			// Add Listeners
			[
				titleInput, brandInput, skuInput, priceInput, currencySelect,
				stockSelect, ratingInput, reviewCountInput, imageInput, highlightsInput
			].forEach(el => {
				el?.addEventListener('input', generateSEOData);
				el?.addEventListener('change', generateSEOData);
			});

			generateSEOData();

			// Copy Logic
			document.querySelectorAll('.btn-copy').forEach(btn => {
				btn.addEventListener('click', () => {
					const targetId = btn.dataset.target;
					const targetTextarea = document.getElementById(targetId);
					if (targetTextarea && targetTextarea.value) {
						navigator.clipboard.writeText(targetTextarea.value).then(() => {
							toast.classList.add('show');
							setTimeout(() => toast.classList.remove('show'), 2000);
						});
					}
				});
			});
		</script>
	</body>
</html>
