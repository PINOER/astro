---
import BaseHead from 'src/components/BaseHead.astro';
import Header from 'src/components/Header.astro';
import Footer from 'src/components/Footer.astro';
import { SITE_TITLE } from 'src/consts';

const pageTitle = `JSON & YAML Formatter / Converter — ${SITE_TITLE}`;
const pageDescription = "Fast, secure, 100% client-side JSON formatter, validator, and YAML converter for developers and store owners.";
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={pageTitle} description={pageDescription} />
		<style>
			main {
				width: 900px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 3em 1em 5em;
			}
			.tool-header {
				text-align: center;
				margin-bottom: 2em;
			}
			.tool-header h1 {
				font-size: 2.2rem;
				font-weight: 800;
				margin-bottom: 0.3em;
				background: var(--hero-title-gradient);
				-webkit-background-clip: text;
				-webkit-text-fill-color: transparent;
			}
			.tool-header p {
				color: var(--text-muted);
				font-size: 1.05rem;
			}
			.tool-box {
				background: var(--bg-card);
				backdrop-filter: blur(12px);
				border: 1px solid var(--card-border);
				border-radius: 16px;
				padding: 2em;
				box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
			}
			.btn-group {
				display: flex;
				gap: 0.8rem;
				margin-bottom: 1rem;
				flex-wrap: wrap;
			}
			.btn {
				background: var(--gray-light);
				border: 1px solid var(--card-border);
				color: var(--text-main);
				padding: 0.5em 1em;
				border-radius: 8px;
				font-size: 0.88rem;
				font-weight: 600;
				cursor: pointer;
				transition: all 0.2s;
			}
			.btn:hover {
				border-color: var(--accent);
				color: var(--accent);
			}
			.btn-primary {
				background: var(--accent);
				border-color: var(--accent);
				color: #ffffff !important;
			}
			.btn-primary:hover {
				background: var(--accent-hover);
				border-color: var(--accent-hover);
				color: #ffffff !important;
			}
			.editor-grid {
				display: grid;
				grid-template-columns: 1fr 1fr;
				gap: 1rem;
			}
			textarea {
				width: 100%;
				height: 380px;
				padding: 1em;
				background: var(--code-bg) !important;
				border: 1px solid var(--card-border);
				border-radius: 10px;
				color: var(--text-main);
				font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
				font-size: 0.88rem;
				box-sizing: border-box;
				outline: none;
				resize: vertical;
				line-height: 1.5;
				transition: border-color 0.2s, box-shadow 0.2s;
			}
			textarea:focus {
				border-color: var(--accent);
				box-shadow: 0 0 10px var(--accent-glow);
			}
			.status-bar {
				margin-top: 1rem;
				font-size: 0.85rem;
				font-weight: 600;
				padding: 0.6em 1em;
				border-radius: 6px;
				display: none;
			}
			.status-success { 
				background: rgba(34, 197, 94, 0.12); 
				color: #16a34a; 
				border: 1px solid rgba(34, 197, 94, 0.3); 
			}
			.status-error { 
				background: rgba(239, 68, 68, 0.12); 
				color: #dc2626; 
				border: 1px solid rgba(239, 68, 68, 0.3); 
			}
			
			:global([data-theme="dark"]) .status-success { color: #4ade80; }
			:global([data-theme="dark"]) .status-error { color: #f87171; }

			@media (max-width: 720px) {
				.editor-grid { grid-template-columns: 1fr; }
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="tool-header">
				<h1>⚙️ JSON Formatter & Validator</h1>
				<p>100% private, client-side JSON formatting, validation, and minification.</p>
			</div>

			<div class="tool-box">
				<div class="btn-group">
					<button class="btn btn-primary" id="btnFormat">Prettify (2 Spaces)</button>
					<button class="btn" id="btnMinify">Minify JSON</button>
					<button class="btn" id="btnClear">Clear</button>
					<button class="btn" id="btnCopy" style="margin-left: auto;">Copy Output</button>
				</div>

				<div class="editor-grid">
					<div>
						<label style="display: block; margin-bottom: 0.4rem; font-size: 0.85rem; font-weight: 600; color: var(--text-muted);">Input JSON:</label>
						<textarea id="jsonInput" placeholder='Paste your raw JSON here... e.g. {"name": "HelpMini", "status": "active"}'></textarea>
					</div>
					<div>
						<label style="display: block; margin-bottom: 0.4rem; font-size: 0.85rem; font-weight: 600; color: var(--text-muted);">Formatted / Validated Output:</label>
						<textarea id="jsonOutput" readonly placeholder="Output will appear here..."></textarea>
					</div>
				</div>

				<div id="statusBar" class="status-bar"></div>
			</div>
		</main>
		<Footer />

		<script>
			const jsonInput = document.getElementById('jsonInput') as HTMLTextAreaElement;
			const jsonOutput = document.getElementById('jsonOutput') as HTMLTextAreaElement;
			const statusBar = document.getElementById('statusBar') as HTMLDivElement;

			const btnFormat = document.getElementById('btnFormat');
			const btnMinify = document.getElementById('btnMinify');
			const btnClear = document.getElementById('btnClear');
			const btnCopy = document.getElementById('btnCopy');

			function showStatus(msg: string, isError = false) {
				statusBar.style.display = 'block';
				statusBar.className = `status-bar ${isError ? 'status-error' : 'status-success'}`;
				statusBar.textContent = msg;
			}

			btnFormat?.addEventListener('click', () => {
				try {
					const raw = jsonInput.value.trim();
					if (!raw) return;
					const parsed = JSON.parse(raw);
					jsonOutput.value = JSON.stringify(parsed, null, 2);
					showStatus('Valid JSON! Successfully formatted.');
				} catch (err: any) {
					jsonOutput.value = '';
					showStatus(`Invalid JSON Syntax: ${err.message}`, true);
				}
			});

			btnMinify?.addEventListener('click', () => {
				try {
					const raw = jsonInput.value.trim();
					if (!raw) return;
					const parsed = JSON.parse(raw);
					jsonOutput.value = JSON.stringify(parsed);
					showStatus('Valid JSON! Successfully minified.');
				} catch (err: any) {
					jsonOutput.value = '';
					showStatus(`Invalid JSON Syntax: ${err.message}`, true);
				}
			});

			btnClear?.addEventListener('click', () => {
				jsonInput.value = '';
				jsonOutput.value = '';
				statusBar.style.display = 'none';
			});

			btnCopy?.addEventListener('click', () => {
				if (!jsonOutput.value) return;
				navigator.clipboard.writeText(jsonOutput.value);
				btnCopy.textContent = 'Copied!';
				setTimeout(() => { btnCopy.textContent = 'Copy Output'; }, 2000);
			});
		</script>
	</body>
</html>
