---
import BaseHead from 'src/components/BaseHead.astro';
import Header from 'src/components/Header.astro';
import Footer from 'src/components/Footer.astro';
import { SITE_TITLE } from 'src/consts';

export const frontmatter = {
    title: "Pro Social Media Copywriting AI Prompt Generator",
    description: "Designed for DTC brands and digital creators! Generate high-converting AI prompts for TikTok, Instagram, Facebook, and Email marketing with hooks, emojis, and hashtags.",
    icon: "📱",
    tag: "AI Tools",
    keywords: "social media copywriting generator tiktok copy prompt instagram caption maker facebook ad copywriter email subject line prompt ChatGPT copy prompt",
    pinned: true,
    priority: 91
};

const pageTitle = `Pro Social Media Copywriting AI Prompt Generator — ${SITE_TITLE}`;
const pageDescription = "Designed for DTC brands and creators! Generate high-converting AI prompts for TikTok, Instagram, Facebook, and Email marketing.";
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={pageTitle} description={pageDescription} />
		<style>
			main {
				width: 1000px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 2.5em 1em 4em;
			}
			.tool-header {
				text-align: center;
				margin-bottom: 2em;
			}
			.tool-header h1 {
				font-size: 2.5rem;
				font-weight: 800;
				margin-bottom: 0.3em;
				background: var(--hero-title-gradient);
				-webkit-background-clip: text;
				-webkit-text-fill-color: transparent;
			}
			.tool-header p {
				color: var(--text-muted);
				font-size: 0.95rem;
			}

			.form-grid {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
				gap: 1.2rem;
				background: var(--bg-card);
				border: 1px solid var(--card-border);
				border-radius: 16px;
				padding: 1.8rem;
				backdrop-filter: blur(12px);
				box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
				margin-bottom: 2rem;
			}
			.form-group {
				display: flex;
				flex-direction: column;
				gap: 0.5rem;
			}
			.form-group.full-width {
				grid-column: 1 / -1;
			}
			label {
				font-size: 0.88rem;
				font-weight: 700;
				color: var(--text-main);
				display: flex;
				justify-content: space-between;
				align-items: center;
			}
			label .sub-tag {
				font-size: 0.75rem;
				color: var(--text-muted);
				font-weight: normal;
			}

			input[type="text"], select, textarea {
				width: 100%;
				padding: 0.75em 1em;
				background: var(--search-bg);
				border: 1px solid var(--card-border);
				border-radius: 8px;
				color: var(--text-main);
				font-size: 0.92rem;
				box-sizing: border-box;
				outline: none;
				transition: border-color 0.2s, box-shadow 0.2s;
			}
			input[type="text"]:focus, select:focus, textarea:focus {
				border-color: var(--accent);
				box-shadow: 0 0 10px var(--accent-glow);
			}

			.output-card {
				background: var(--bg-card);
				border: 1px solid var(--card-border);
				border-radius: 16px;
				padding: 1.5rem;
				box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
			}
			.output-header {
				display: flex;
				justify-content: space-between;
				align-items: center;
				margin-bottom: 1rem;
			}
			.output-title {
				font-size: 1.05rem;
				font-weight: 700;
				color: var(--text-main);
			}
			.btn-copy {
				background: var(--accent);
				color: #ffffff;
				border: none;
				padding: 0.6em 1.2em;
				border-radius: 8px;
				font-size: 0.88rem;
				font-weight: 700;
				cursor: pointer;
				transition: all 0.2s ease;
			}
			.btn-copy:hover {
				background: var(--accent-hover);
				transform: translateY(-1px);
			}
			.prompt-output {
				width: 100%;
				height: 160px;
				background: var(--code-bg) !important;
				border: 1px solid var(--card-border);
				border-radius: 10px;
				padding: 1rem;
				color: var(--text-main);
				font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
				font-size: 0.9rem;
				line-height: 1.6;
				resize: vertical;
				box-sizing: border-box;
				outline: none;
			}

			.toast {
				position: fixed;
				bottom: 2rem;
				right: 2rem;
				background: var(--accent);
				color: #fff;
				padding: 0.6em 1.2em;
				border-radius: 8px;
				font-size: 0.88rem;
				font-weight: 600;
				box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
				opacity: 0;
				transform: translateY(10px);
				transition: all 0.3s ease;
				pointer-events: none;
				z-index: 100;
			}
			.toast.show {
				opacity: 1;
				transform: translateY(0);
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="tool-header">
				<h1>📱 Pro Social Media Copywriting AI Prompt Generator</h1>
				<p>Select target platform and brand voice to instantly generate engineered copywriting prompts for ChatGPT, Claude, and Gemini.</p>
			</div>

			<div class="form-grid">
				<!-- Target Platform -->
				<div class="form-group">
					<label for="platformSelect">Target Platform</label>
					<select id="platformSelect">
						<option value="TikTok">TikTok (Viral Script / 3-Sec Hook / Gen-Z Lingo)</option>
						<option value="Instagram">Instagram (Aesthetic Lifestyle / Engaging Caption / Bio CTA)</option>
						<option value="Facebook">Facebook (Long-Form Storytelling / Pain Points / Conversion)</option>
						<option value="Xiaohongshu">Xiaohongshu RED (Personal Recommendation / High Emoji Density)</option>
						<option value="EDM_Email">EDM Email Marketing (High-CTR Subject Lines & Body)</option>
					</select>
				</div>

				<!-- Tone & Voice -->
				<div class="form-group">
					<label for="toneSelect">Tone & Brand Voice</label>
					<select id="toneSelect">
						<option value="Enthusiastic & Viral">Enthusiastic & Viral (High-Energy Recommendation)</option>
						<option value="Aesthetic & Minimalist">Quiet Luxury & Minimalist (Sophisticated / Premium)</option>
						<option value="Problem-Solving & Educational">Problem-Solving & Educational (Functional Specs)</option>
						<option value="Urgent & FOMO">Urgent & FOMO (Limited Time / Scarcity Discount)</option>
						<option value="Humorous & Relatable">Humorous & Relatable (Conversational / Comment Magnet)</option>
					</select>
				</div>

				<!-- Product & Key Highlights -->
				<div class="form-group full-width">
					<label for="productInput">
						Product Name & Key Features
						<span class="sub-tag">Specify main selling points (e.g., Waterproof outdoor shell jacket, 40-hour battery wireless earbuds)</span>
					</label>
					<input type="text" id="productInput" placeholder="e.g. Waterproof outdoor shell jacket, ultra-light breathable fabric, hidden storm-proof pockets..." />
				</div>

				<!-- Target Audience -->
				<div class="form-group">
					<label for="audienceInput">Target Audience & Use Case</label>
					<input type="text" id="audienceInput" placeholder="e.g. Outdoor enthusiasts, daily commuters, campers, urban hikers" />
				</div>

				<!-- Call to Action -->
				<div class="form-group">
					<label for="ctaSelect">Call to Action (CTA)</label>
					<select id="ctaSelect">
						<option value="Click the link in Bio to shop now">Link in Bio Checkout (Click Link in Bio)</option>
						<option value="Comment 'WANT' below to get the exclusive discount code">Comment Keyword for Discount (Engagement Prompt)</option>
						<option value="Save and share this with someone who needs it">Save & Share with Friends (Organic Reach)</option>
						<option value="Limited time offer! Grab yours before it sells out">Limited Stock Urgency (Grab Yours Now)</option>
					</select>
				</div>
			</div>

			<!-- Output Prompt Card -->
			<div class="output-card">
				<div class="output-header">
					<span class="output-title">✨ Generated AI Copywriting Prompt (Paste to ChatGPT / Claude / Gemini)</span>
					<button class="btn-copy" id="btnCopy">📋 Copy Prompt</button>
				</div>
				<textarea id="promptOutput" class="prompt-output" readonly></textarea>
			</div>
		</main>

		<div id="toast" class="toast">Prompt copied to clipboard!</div>

		<Footer />

		<script is:inline>
			const platformSelect = document.getElementById('platformSelect');
			const toneSelect = document.getElementById('toneSelect');
			const productInput = document.getElementById('productInput');
			const audienceInput = document.getElementById('audienceInput');
			const ctaSelect = document.getElementById('ctaSelect');

			const promptOutput = document.getElementById('promptOutput');
			const btnCopy = document.getElementById('btnCopy');
			const toast = document.getElementById('toast');

			function buildPrompt() {
				const platform = platformSelect.value;
				const tone = toneSelect.value;
				const product = productInput.value.trim() || 'Wireless Noise-Canceling Headphones with 40-hour battery life';
				const audience = audienceInput.value.trim() || 'Tech enthusiasts and daily commuters';
				const cta = ctaSelect.value;

				let platformSpec = '';
				if (platform === 'TikTok') {
					platformSpec = 'Format for TikTok. Must start with a 3-second scroll-stopping HOOK. Use trendy Gen-Z/viral social language, well-placed Emojis, line breaks for fast reading, and include 3-5 trending relevant hashtags.';
				} else if (platform === 'Instagram') {
					platformSpec = 'Format for Instagram Caption. Focus on aesthetic storytelling, line breaks for clean structure, engaging Emojis, a clear Call-to-Action to check link in bio, and a block of 8-10 targeted hashtags at the end.';
				} else if (platform === 'Facebook') {
					platformSpec = 'Format for Facebook Ad / Post. Focus on story-driven copywriting addressing customer pain points, building social proof, clear feature bullets, and a strong CTA link prompt.';
				} else if (platform === 'Xiaohongshu') {
					platformSpec = 'Format for Xiaohongshu (RED / 小红书). High emoji density, highly engaging personal experience tone, eye-catching Title with brackets [ ], pain-point analysis, and natural lifestyle recommendations.';
				} else {
					platformSpec = 'Format for Email Marketing. Provide 3 catchy, high-CTR Subject Line options, followed by a punchy email body with a clear CTA button callout.';
				}

				const prompt = `Act as an expert senior eCommerce Copywriter and Social Media Specialist.

Write a high-converting copy for ${platform}.

[Product Details & Key Highlights]: ${product}
[Target Audience & Scenario]: ${audience}
[Tone & Style]: ${tone}
[Call-to-Action (CTA)]: ${cta}

[Platform Formatting Rules]:
${platformSpec}

Please output 2 distinct creative variations so I can A/B test them. Keep the language natural, engaging, and persuasive!`;

				promptOutput.value = prompt;
			}

			// Add Input Listeners
			[platformSelect, toneSelect, productInput, audienceInput, ctaSelect].forEach(el => {
				el?.addEventListener('input', buildPrompt);
				el?.addEventListener('change', buildPrompt);
			});

			buildPrompt();

			// Copy Function
			btnCopy?.addEventListener('click', () => {
				if (!promptOutput.value) return;
				navigator.clipboard.writeText(promptOutput.value).then(() => {
					toast.classList.add('show');
					setTimeout(() => toast.classList.remove('show'), 2000);
				});
			});
		</script>
	</body>
</html>
