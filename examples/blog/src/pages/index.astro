---
import BaseHead from 'src/components/BaseHead.astro';
import Header from 'src/components/Header.astro';
import Footer from 'src/components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from 'src/consts';
import { getCollection } from 'astro:content';
import { toolsData } from 'src/data/tools';

// 1. 获取英文博客
const allPosts = await getCollection('blog');
const enPosts = allPosts.filter((post) => post.data?.lang === 'en' || post.id.startsWith('en/'));

// 2. 赞助商/广告卡片配置（可随时增减或从配置文件读取）
const sponsorItems = [
	// 示例赞助商卡片（取消注释即可开启）
	/*
	{
		title: 'Vercel Pro Cloud',
		desc: 'Deploy your frontend applications with instant global CDN and zero configuration.',
		url: 'https://vercel.com',
		type: 'sponsor',
		icon: '⚡',
		tag: 'Sponsor',
		keywords: 'cloud hosting deployment vercel CDN',
		pinned: true,      // 是否置顶
		priority: 100      // 排序优先级 (越高越靠前)
	}
	*/
];

// 3. 组装统一的数据集 (Tools + Blogs + Sponsors)
const allSearchableItems = [
	...toolsData.map((tool) => ({
		title: tool.title.en,
		desc: tool.desc.en,
		url: tool.url.en,
		type: 'tool',
		icon: tool.icon,
		tag: tool.tag.en,
		keywords: `${tool.title.en} ${tool.keywords.en}`,
		pinned: (tool as any).pinned || false,
		priority: (tool as any).priority || 0
	})),
	...enPosts.map((post) => ({
		title: post.data.title,
		desc: post.data.description,
		url: `/blog/${post.id.replace(/\.(md|mdx)$/, '').replace(/\/index$/, '')}/`,
		type: 'blog',
		icon: '📚',
		tag: 'Guide',
		keywords: `${post.data.title} ${post.data.description}`,
		pinned: false,
		priority: 0
	})),
	...sponsorItems
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 1000px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 3em 1em 5em;
			}
			.hero {
				text-align: center;
				padding: 2em 0 3em;
				position: relative;
			}
			.badge {
				display: inline-block;
				background: var(--badge-bg);
				color: var(--badge-color);
				border: 1px solid var(--badge-border);
				padding: 0.4em 1.2em;
				border-radius: 20px;
				font-size: 0.85rem;
				font-weight: 600;
				margin-bottom: 1.5em;
				box-shadow: 0 0 15px rgba(99, 102, 241, 0.15);
				transition: all 0.3s ease;
			}
			.hero h1 {
				font-size: 3.5rem;
				font-weight: 800;
				margin-bottom: 0.4em;
				line-height: 1.2;
				letter-spacing: -1px;
				background: var(--hero-title-gradient);
				-webkit-background-clip: text;
				-webkit-text-fill-color: transparent;
			}
			.hero p {
				font-size: 0.95rem;
				color: var(--text-muted);
				max-width: 600px;
				margin: 0 auto 2em;
				line-height: 1.6;
			}

			/* 🔍 中央搜索框设计 */
			.search-wrapper {
				max-width: 640px;
				margin: 0 auto 3em;
				position: relative;
			}
			.search-input-box {
				width: 100%;
				padding: 1.1em 1.5em 1.1em 3.2em;
				background: var(--search-bg);
				backdrop-filter: blur(16px);
				border: 1px solid var(--card-border);
				border-radius: 16px;
				color: var(--text-main);
				font-size: 1.05rem;
				outline: none;
				box-sizing: border-box;
				box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
				transition: all 0.3s ease;
			}
			.search-input-box:focus {
				border-color: var(--accent);
				box-shadow: 0 0 25px var(--accent-glow);
			}
			.search-icon {
				position: absolute;
				left: 1.2em;
				top: 50%;
				transform: translateY(-50%);
				font-size: 1.2rem;
				opacity: 0.6;
				pointer-events: none;
			}

			/* 动态网格区域 */
			.section-title-wrapper {
				display: flex;
				align-items: center;
				justify-content: space-between;
				margin-bottom: 1.5rem;
			}
			.section-title {
				font-size: 1.5rem;
				font-weight: 700;
				letter-spacing: -0.5px;
				color: var(--text-main);
				margin: 0;
			}
			.result-count-badge {
				font-size: 0.85rem;
				color: var(--text-muted);
				font-weight: 600;
			}

			.tool-grid {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
				gap: 1.5rem;
			}

			/* 卡片基本通用样式 */
			.item-card {
				background: var(--bg-card);
				backdrop-filter: blur(12px);
				border: 1px solid var(--card-border);
				border-radius: 16px;
				padding: 1.8rem;
				text-decoration: none;
				color: var(--text-main);
				display: flex;
				flex-direction: column;
				position: relative;
				transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
				box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
			}
			.item-card:hover {
				transform: translateY(-6px);
				border-color: var(--accent);
				box-shadow: 0 12px 30px -5px var(--accent-glow);
			}
			.item-card-header {
				display: flex;
				justify-content: space-between;
				align-items: flex-start;
				margin-bottom: 1rem;
			}
			.item-icon { font-size: 2.2rem; }
			.item-card h3 { font-size: 1.25rem; font-weight: 700; margin-bottom: 0.6rem; color: var(--text-main); }
			.item-card p { font-size: 0.92rem; color: var(--text-muted); flex: 1; margin-bottom: 1.2rem; line-height: 1.6; }
			
			/* 标签与 Badge 样式适配 */
			.item-footer {
				display: flex;
				justify-content: space-between;
				align-items: center;
			}
			.item-tag { font-size: 0.75rem; font-weight: 700; text-transform: uppercase; }
			
			/* 不同类型卡片的专属风格 */
			.tag-tool { color: var(--cyan); }
			.tag-blog { color: var(--accent); }
			.tag-sponsor { color: #f59e0b; } /* 赞助商琥珀金 */

			.type-badge {
				font-size: 0.7rem;
				padding: 0.2em 0.6em;
				border-radius: 6px;
				font-weight: 700;
				text-transform: uppercase;
			}
			.badge-tool { background: rgba(6, 182, 212, 0.15); color: var(--cyan); }
			.badge-blog { background: rgba(99, 102, 241, 0.15); color: var(--accent); }
			.badge-sponsor { background: rgba(245, 158, 11, 0.15); color: #f59e0b; border: 1px solid rgba(245, 158, 11, 0.3); }

			/* 置顶标志 (Pinned) */
			.pinned-icon {
				position: absolute;
				top: 1rem;
				right: 1rem;
				font-size: 0.9rem;
				opacity: 0.8;
			}

			.no-results {
				text-align: center;
				padding: 4em 1em;
				color: var(--text-muted);
				grid-column: 1 / -1;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<div class="badge">🚀 Micro AI Tools for Big Help</div>
				<h1>HelpMini</h1>
				
				<!-- 🔍 中央搜索框 -->
				<div class="search-wrapper">
					<span class="search-icon">🔍</span>
					<input
						type="text"
						id="searchInput"
						class="search-input-box"
						placeholder="Search tools, guides, or keywords... (e.g., SEO, Token, Prompt)"
						autocomplete="off"
					/>
				</div>
			</section>

			<!-- 📦 统一内容与搜索结果展示区 -->
			<section>
				<div class="section-title-wrapper">
					<h2 id="sectionTitle" class="section-title">Featured Micro Tools</h2>
					<span id="resultCount" class="result-count-badge"></span>
				</div>
				
				<!-- 动态网格展示容器 -->
				<div id="contentGrid" class="tool-grid"></div>
			</section>

			<section class="hero" style="padding-top: 4em;">
				<p>Lightweight, instant productivity tools that save you hours.</p>
			</section>
		</main>
		<Footer />

		<!-- 客户端实时驱动脚本 -->
		<script is:inline define:vars={{ allSearchableItems }}>
			const searchInput = document.getElementById('searchInput');
			const sectionTitle = document.getElementById('sectionTitle');
			const resultCount = document.getElementById('resultCount');
			const contentGrid = document.getElementById('contentGrid');

			// 1. 核心排序函数（置顶优先 -> 优先级最高 -> 默认顺序）
			function sortItems(items) {
				return [...items].sort((a, b) => {
					if (a.pinned && !b.pinned) return -1;
					if (!a.pinned && b.pinned) return 1;
					return (b.priority || 0) - (a.priority || 0);
				});
			}

			// 2. 渲染卡片 HTML
			function renderItems(items) {
				if (!contentGrid) return;

				if (items.length === 0) {
					contentGrid.innerHTML = `
						<div class="no-results">
							<div style="font-size: 2.5rem; margin-bottom: 0.5rem;">🔍</div>
							<p style="font-size: 1.1rem; font-weight: 600;">No matching tools or guides found</p>
							<p style="font-size: 0.88rem; opacity: 0.8;">Try searching for other keywords like "SEO", "JSON", or "Token"</p>
						</div>
					`;
					return;
				}

				contentGrid.innerHTML = items.map(item => {
					const isExternal = item.url.startsWith('http');
					const typeBadgeClass = item.type === 'sponsor' ? 'badge-sponsor' : (item.type === 'blog' ? 'badge-blog' : 'badge-tool');
					const tagClass = item.type === 'sponsor' ? 'tag-sponsor' : (item.type === 'blog' ? 'tag-blog' : 'tag-tool');
					const typeLabel = item.type === 'sponsor' ? 'Ad / Sponsor' : (item.type === 'blog' ? 'Blog' : 'Tool');

					return `
						<a href="${item.url}" class="item-card" ${isExternal ? 'target="_blank" rel="noopener"' : ''}>
							${item.pinned ? '<span class="pinned-icon" title="Pinned">📌</span>' : ''}
							<div class="item-card-header">
								<div class="item-icon">${item.icon}</div>
								<span class="type-badge ${typeBadgeClass}">${typeLabel}</span>
							</div>
							<h3>${item.title}</h3>
							<p>${item.desc}</p>
							<div class="item-footer">
								<span class="item-tag ${tagClass}">${item.tag || 'Tool'}</span>
							</div>
						</a>
					`;
				}).join('');
			}

			// 3. 初始渲染逻辑 (未搜索时，最多前 20 项)
			function initDefaultView() {
				const sorted = sortItems(allSearchableItems);
				const default20 = sorted.slice(0, 20); // 最多显示前 20 项
				
				if (sectionTitle) sectionTitle.textContent = 'Featured Micro Tools';
				if (resultCount) resultCount.textContent = `${default20.length} items`;
				
				renderItems(default20);
			}

			// 4. 监听搜索事件
			searchInput?.addEventListener('input', (e) => {
				const query = e.target.value.toLowerCase().trim();

				if (!query) {
					initDefaultView();
					return;
				}

				// 搜寻匹配
				const filtered = allSearchableItems.filter(item =>
					item.title.toLowerCase().includes(query) ||
					item.desc.toLowerCase().includes(query) ||
					item.keywords.toLowerCase().includes(query)
				);

				const sortedResults = sortItems(filtered);

				if (sectionTitle) sectionTitle.textContent = 'Search Results';
				if (resultCount) resultCount.textContent = `${sortedResults.length} found`;

				renderItems(sortedResults);
			});

			// 初始化执行
			initDefaultView();
		</script>
	</body>
</html>
