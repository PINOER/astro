---
import BaseHead from 'src/components/BaseHead.astro';
import Header from 'src/components/Header.astro';
import Footer from 'src/components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from 'src/consts';
import { getCollection } from 'astro:content';
import { toolsData } from 'src/data/tools';

// 1. 获取英文博客
const allPosts = await getCollection('blog');
const enPosts = allPosts.filter((post) => post.data?.lang === 'en' || post.id.startsWith('en/'));

// 2. 赞助商/广告卡片配置（可选）
const sponsorItems = [];

// 3. 组装统一数据集 (Tools + Blogs + Sponsors) 并排序 (置顶优先 -> 权重优先)
const rawItems = [
	...toolsData.map((tool) => ({
		title: tool.title.en,
		desc: tool.desc.en,
		url: tool.url.en,
		type: 'tool',
		icon: tool.icon,
		tag: tool.tag.en,
		keywords: `${tool.title.en} ${tool.keywords.en}`,
		pinned: (tool as any).pinned || false,
		priority: (tool as any).priority || 0
	})),
	...enPosts.map((post) => ({
		title: post.data.title,
		desc: post.data.description,
		url: `/blog/${post.id.replace(/\.(md|mdx)$/, '').replace(/\/index$/, '')}/`,
		type: 'blog',
		icon: '📚',
		tag: 'Guide',
		keywords: `${post.data.title} ${post.data.description}`,
		pinned: (post.data as any).pinned || false,       // 👈 继承文章 Head Matter 中的 pinned
		priority: (post.data as any).priority || 0         // 👈 继承文章 Head Matter 中的 priority
	})),
	...sponsorItems
];

// 统一排序：置顶优先 -> 权重高的靠前
const allSearchableItems = rawItems.sort((a, b) => {
	if (a.pinned && !b.pinned) return -1;
	if (!a.pinned && b.pinned) return 1;
	return (b.priority || 0) - (a.priority || 0);
});
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 1000px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 3em 1em 5em;
			}
			.hero {
				text-align: center;
				padding: 2em 0 2.5em;
				position: relative;
			}
			.badge {
				display: inline-block;
				background: var(--badge-bg);
				color: var(--badge-color);
				border: 1px solid var(--badge-border);
				padding: 0.4em 1.2em;
				border-radius: 20px;
				font-size: 0.85rem;
				font-weight: 600;
				margin-bottom: 1.5em;
				box-shadow: 0 0 15px rgba(99, 102, 241, 0.15);
				transition: all 0.3s ease;
			}
			.hero h1 {
				font-size: 3.5rem;
				font-weight: 800;
				margin-bottom: 0.4em;
				line-height: 1.2;
				letter-spacing: -1px;
				background: var(--hero-title-gradient);
				-webkit-background-clip: text;
				-webkit-text-fill-color: transparent;
			}
			.hero p {
				font-size: 0.95rem;
				color: var(--text-muted);
				max-width: 600px;
				margin: 0 auto 2em;
				line-height: 1.6;
			}

			/* 🔍 中央搜索框 */
			.search-wrapper {
				max-width: 640px;
				margin: 0 auto 2.5em;
				position: relative;
			}
			.search-input-box {
				width: 100%;
				padding: 1.1em 1.5em 1.1em 3.2em;
				background: var(--search-bg);
				backdrop-filter: blur(16px);
				border: 1px solid var(--card-border);
				border-radius: 16px;
				color: var(--text-main);
				font-size: 1.05rem;
				outline: none;
				box-sizing: border-box;
				box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
				transition: all 0.3s ease;
			}
			.search-input-box:focus {
				border-color: var(--accent);
				box-shadow: 0 0 25px var(--accent-glow);
			}
			.search-icon {
				position: absolute;
				left: 1.2em;
				top: 50%;
				transform: translateY(-50%);
				font-size: 1.2rem;
				opacity: 0.6;
				pointer-events: none;
			}

			/* 📦 标头区 */
			.section-title-wrapper {
				display: flex;
				align-items: center;
				justify-content: space-between;
				margin-bottom: 1.2rem;
			}
			.section-title {
				font-size: 1.35rem;
				font-weight: 700;
				letter-spacing: -0.5px;
				color: var(--text-main);
				margin: 0;
			}
			.result-count-badge {
				font-size: 0.82rem;
				color: var(--text-muted);
				font-weight: 600;
				background: var(--gray-light);
				padding: 0.25em 0.7em;
				border-radius: 12px;
				border: 1px solid var(--card-border);
			}

			/* ⚡ 还原原生 3 列极客标准网格 */
			.tool-grid {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
				gap: 1.5rem;
			}

			/* 💎 Astro 原生渲染的纯正卡片 (.tool-card) */
			.tool-card {
				background: var(--bg-card);
				backdrop-filter: blur(12px);
				-webkit-backdrop-filter: blur(12px);
				border: 1px solid var(--card-border);
				border-radius: 16px;
				padding: 1.8rem;
				text-decoration: none !important;
				color: var(--text-main);
				display: flex;
				flex-direction: column;
				position: relative;
				box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
				transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
				box-sizing: border-box;
			}

			.tool-card:hover {
				transform: translateY(-6px);
				border-color: var(--accent);
				box-shadow: 0 12px 30px -5px var(--accent-glow);
			}

			.tool-icon {
				font-size: 2.2rem;
				margin-bottom: 1rem;
				line-height: 1;
			}

			.tool-card h3 {
				font-size: 1.25rem;
				font-weight: 700;
				margin-bottom: 0.6rem;
				color: var(--text-main);
				line-height: 1.3;
			}

			.tool-card p {
				font-size: 0.92rem;
				color: var(--text-muted);
				flex: 1;
				margin-bottom: 1.2rem;
				line-height: 1.6;
			}

			/* Footer 布局与标签 */
			.tool-card-footer {
				display: flex;
				justify-content: space-between;
				align-items: center;
				margin-top: auto;
			}

			.tool-tag {
				font-size: 0.75rem;
				font-weight: 700;
				text-transform: uppercase;
				letter-spacing: 0.5px;
			}

			.tag-tool { color: var(--cyan); }
			.tag-blog { color: var(--accent); }
			.tag-sponsor { color: #f59e0b; }

			.type-badge {
				font-size: 0.7rem;
				padding: 0.2em 0.6em;
				border-radius: 6px;
				font-weight: 700;
				text-transform: uppercase;
			}
			.badge-tool { background: rgba(6, 182, 212, 0.15); color: var(--cyan); border: 1px solid rgba(6, 182, 212, 0.25); }
			.badge-blog { background: rgba(99, 102, 241, 0.15); color: var(--accent); border: 1px solid rgba(99, 102, 241, 0.25); }
			.badge-sponsor { background: rgba(245, 158, 11, 0.15); color: #f59e0b; border: 1px solid rgba(245, 158, 11, 0.3); }

			.pinned-icon {
				position: absolute;
				top: 1rem;
				right: 1rem;
				font-size: 0.9rem;
				opacity: 0.8;
			}

			/* 搜索无匹配提示 */
			.no-results {
				text-align: center;
				padding: 4em 1em;
				color: var(--text-muted);
				grid-column: 1 / -1;
				display: none;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<div class="badge">🚀 Micro AI Tools for Big Help</div>
				<h1>HelpMini</h1>
				
				<!-- 🔍 中央搜索框 -->
				<div class="search-wrapper">
					<span class="search-icon">🔍</span>
					<input
						type="text"
						id="searchInput"
						class="search-input-box"
						placeholder="Search tools, guides, or keywords... (e.g., SEO, Token, Prompt)"
						autocomplete="off"
					/>
				</div>
			</section>

			<!-- 📦 统一内容与搜索结果展示区 -->
			<section>
				<div class="section-title-wrapper">
					<h2 id="sectionTitle" class="section-title">Featured Micro Tools</h2>
					<span id="resultCount" class="result-count-badge"></span>
				</div>
				
				<div id="contentGrid" class="tool-grid">
					{allSearchableItems.map((item, index) => (
						<a 
							href={item.url} 
							class="tool-card searchable-item"
							data-title={item.title.toLowerCase()}
							data-desc={item.desc.toLowerCase()}
							data-keywords={item.keywords.toLowerCase()}
							data-default-show={index < 20 ? "true" : "false"}
							style={index >= 20 ? "display: none;" : "display: flex;"}
							target={item.url.startsWith('http') ? '_blank' : '_self'}
							rel={item.url.startsWith('http') ? 'noopener' : ''}
						>
							{item.pinned && <span class="pinned-icon" title="Pinned">📌</span>}
							<div class="tool-icon">{item.icon}</div>
							<h3>{item.title}</h3>
							<p>{item.desc}</p>
							<div class="tool-card-footer">
								<span class={`tool-tag tag-${item.type}`}>{item.tag || 'Tool'}</span>
								<span class={`type-badge badge-${item.type}`}>{item.type === 'sponsor' ? 'Ad' : (item.type === 'blog' ? 'Blog' : 'Tool')}</span>
							</div>
						</a>
					))}

					<div id="noResults" class="no-results">
						<div style="font-size: 2.5rem; margin-bottom: 0.5rem;">🔍</div>
						<p style="font-size: 1.1rem; font-weight: 600;">No matching tools or guides found</p>
						<p style="font-size: 0.88rem; opacity: 0.8;">Try searching for other keywords like "SEO", "JSON", or "Token"</p>
					</div>
				</div>
			</section>

			<section class="hero" style="padding-top: 4em;">
				<p>Lightweight, instant productivity tools that save you hours.</p>
			</section>
		</main>
		<Footer />

		<!-- 极简客户端 JS：仅负责控制原生 DOM 的显隐 (Display) -->
		<script is:inline>
			const searchInput = document.getElementById('searchInput');
			const sectionTitle = document.getElementById('sectionTitle');
			const resultCount = document.getElementById('resultCount');
			const items = document.querySelectorAll('.searchable-item');
			const noResults = document.getElementById('noResults');

			// 初始化状态 (未输入搜索词时，仅显示前 20 项)
			function initDefaultView() {
				let shownCount = 0;
				items.forEach(item => {
					if (item.getAttribute('data-default-show') === 'true') {
						item.style.display = 'flex';
						shownCount++;
					} else {
						item.style.display = 'none';
					}
				});

				if (sectionTitle) sectionTitle.textContent = 'Featured Micro Tools';
				if (resultCount) resultCount.textContent = `${shownCount} items`;
				if (noResults) noResults.style.display = 'none';
			}

			// 搜索实时过滤逻辑
			searchInput?.addEventListener('input', (e) => {
				const query = e.target.value.toLowerCase().trim();

				if (!query) {
					initDefaultView();
					return;
				}

				let matchCount = 0;
				items.forEach(item => {
					const title = item.getAttribute('data-title') || '';
					const desc = item.getAttribute('data-desc') || '';
					const keywords = item.getAttribute('data-keywords') || '';

					if (title.includes(query) || desc.includes(query) || keywords.includes(query)) {
						item.style.display = 'flex';
						matchCount++;
					} else {
						item.style.display = 'none';
					}
				});

				if (sectionTitle) sectionTitle.textContent = 'Search Results';
				if (resultCount) resultCount.textContent = `${matchCount} found`;

				if (noResults) {
					noResults.style.display = matchCount === 0 ? 'block' : 'none';
				}
			});

			// 页面加载即刻初始化
			initDefaultView();
		</script>
	</body>
</html>
