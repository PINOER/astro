---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			:root {
				--primary: #6366f1;
				--primary-hover: #4f46e5;
				--accent: #06b6d4;
				--bg-dark: #0f172a;
				--text-main: #f8fafc;
				--text-muted: #94a3b8;
				--card-bg: rgba(30, 41, 59, 0.7);
				--card-border: rgba(255, 255, 255, 0.1);
			}
			body {
				background-color: var(--bg-dark);
				color: var(--text-main);
			}
			main {
				width: 1000px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 3em 1em 5em;
			}
			.hero {
				text-align: center;
				padding: 3em 0 4em;
			}
			.badge {
				display: inline-block;
				background: rgba(99, 102, 241, 0.15);
				color: #a5b4fc;
				border: 1px solid rgba(99, 102, 241, 0.3);
				padding: 0.4em 1.2em;
				border-radius: 20px;
				font-size: 0.85rem;
				font-weight: 600;
				margin-bottom: 1.5em;
				box-shadow: 0 0 15px rgba(99, 102, 241, 0.2);
			}
			/* 科技渐变大标题 */
			.hero h1 {
				font-size: 3.5rem;
				font-weight: 800;
				margin-bottom: 0.4em;
				line-height: 1.2;
				letter-spacing: -1px;
				background: linear-gradient(135deg, #ffffff 0%, #a5b4fc 50%, #06b6d4 100%);
				-webkit-background-clip: text;
				-webkit-text-fill-color: transparent;
			}
			.hero p {
				font-size: 1.2rem;
				color: var(--text-muted);
				max-width: 600px;
				margin: 0 auto 2em;
				line-height: 1.6;
			}
			.tool-grid {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
				gap: 1.5rem;
				margin-top: 2rem;
			}
			/* 毛玻璃卡片风格 */
			.tool-card {
				background: var(--card-bg);
				backdrop-filter: blur(12px);
				border: 1px solid var(--card-border);
				border-radius: 16px;
				padding: 1.8rem;
				text-decoration: none;
				color: var(--text-main);
				display: flex;
				flex-direction: column;
				transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
				box-shadow: 0 4px 20px rgba(0, 0, 0, 0.2);
			}
			.tool-card:hover {
				transform: translateY(-6px);
				border-color: rgba(99, 102, 241, 0.6);
				box-shadow: 0 12px 30px -5px rgba(99, 102, 241, 0.3);
			}
			.tool-icon {
				font-size: 2.2rem;
				margin-bottom: 1rem;
			}
			.tool-card h3 {
				font-size: 1.25rem;
				font-weight: 700;
				margin-bottom: 0.6rem;
			}
			.tool-card p {
				font-size: 0.92rem;
				color: var(--text-muted);
				flex: 1;
				margin-bottom: 1.2rem;
				line-height: 1.6;
			}
			.tool-tag {
				font-size: 0.75rem;
				color: var(--accent);
				font-weight: 600;
				text-transform: uppercase;
				letter-spacing: 0.5px;
			}
			@media (max-width: 720px) {
				.hero h1 { font-size: 2.4rem; }
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<div class="badge">🚀 Micro AI Tools for Big Help</div>
				<h1>HelpMini</h1>
				<p>Lightweight, instant, and supercharged AI tools designed to save you hours every week.</p>
			</section>

			<section>
				<h2 style="font-size: 1.5rem; font-weight: 700; letter-spacing: -0.5px;">Featured Micro Tools</h2>
				<div class="tool-grid">
					
					<!-- 第一个微工具卡片 -->
					<a href="/tools/prompt-refiner" class="tool-card">
						<div class="tool-icon">📝</div>
						<h3>Prompt Structurer & Refiner</h3>
						<p>Transform rough ideas into structured, high-performing prompts for ChatGPT & Claude.</p>
						<span class="tool-tag">Free Tool • Instant</span>
					</a>

					<!-- 占位卡片 2 -->
					<a href="/tools/token-calculator" class="tool-card">
						<div class="tool-icon">📊</div>
						<h3>Token & Context Limit Checker</h3>
						<p>Calculate precise token counts for LLMs and avoid context cutoff issues.</p>
						<span class="tool-tag">Free Tool • Instant</span>
					</a>

					<!-- 占位卡片 3 -->
					<a href="/tools/seo-meta-generator" class="tool-card">
						<div class="tool-icon">🔍</div>
						<h3>SEO Meta Title & Desc Generator</h3>
						<p>Generate Google-friendly meta titles and descriptions optimized for higher CTR.</p>
						<span class="tool-tag">Free Tool • Instant</span>
					</a>

				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>
