---
import BaseHead from 'src/components/BaseHead.astro';
import Header from 'src/components/Header.astro';
import Footer from 'src/components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from 'src/consts';
import { getCollection } from 'astro:content';
import { sponsorItems } from 'src/data/tools'; // 专用于广告赞助卡片

// 1. ⚡ 自动化魔法：批量自动扫描 src/pages/tools/ 下的所有英文 .astro 工具页面
const toolFiles = import.meta.glob('/src/pages/tools/*.astro', { eager: true });

const enTools = Object.entries(toolFiles).map(([path, file]: [string, any]) => {
	const slug = path.split('/').pop().replace('.astro', '');
	const fm = file.frontmatter || {};
	
	return {
		title: fm.title || slug,
		desc: fm.description || '',
		url: `/tools/${slug}/`,
		type: 'tool',
		icon: fm.icon || '⚡',
		tag: fm.tag || 'Tool',
		keywords: `${fm.title || ''} ${fm.keywords || ''}`,
		pinned: fm.pinned || false,
		priority: fm.priority || 0
	};
});

// 2. 自动从 Content Collection 获取所有英文博客
const allPosts = await getCollection('blog');
const enPosts = allPosts.filter((post) => post.data?.lang === 'en' || post.id.startsWith('en/'));

// 3. 组装统一数据集 (Tools + Blogs + Sponsors) 并排序
const rawItems = [
	...enTools,
	...enPosts.map((post) => ({
		title: post.data.title,
		desc: post.data.description,
		url: `/blog/${post.id.replace(/\.(md|mdx)$/, '').replace(/\/index$/, '')}/`,
		type: 'blog',
		icon: '📚',
		tag: 'Guide',
		keywords: `${post.data.title} ${post.data.description}`,
		pinned: (post.data as any).pinned || false,
		priority: (post.data as any).priority || 0
	})),
	...(sponsorItems.en || []).map((sponsor) => ({
		title: sponsor.title,
		desc: sponsor.desc,
		url: sponsor.url,
		type: 'sponsor',
		icon: sponsor.icon,
		tag: sponsor.tag,
		keywords: sponsor.keywords,
		pinned: sponsor.pinned,
		priority: sponsor.priority
	}))
];

// 统一排序：置顶优先 -> 权重高的靠前
const allSearchableItems = rawItems.sort((a, b) => {
	if (a.pinned && !b.pinned) return -1;
	if (!a.pinned && b.pinned) return 1;
	return (b.priority || 0) - (a.priority || 0);
});
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 1000px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 3em 1em 5em;
			}
			.hero {
				text-align: center;
				padding: 2em 0 2.5em;
				position: relative;
			}
			.badge {
				display: inline-block;
				background: var(--badge-bg);
				color: var(--badge-color);
				border: 1px solid var(--badge-border);
				padding: 0.4em 1.2em;
				border-radius: 20px;
				font-size: 0.85rem;
				font-weight: 600;
				margin-bottom: 1.5em;
				box-shadow: 0 0 15px rgba(99, 102, 241, 0.15);
				transition: all 0.3s ease;
			}
			.hero h1 {
				font-size: 3.5rem;
				font-weight: 800;
				margin-bottom: 0.4em;
				line-height: 1.2;
				letter-spacing: -1px;
				background: var(--hero-title-gradient);
				-webkit-background-clip: text;
				-webkit-text-fill-color: transparent;
			}
			.hero p {
				font-size: 0.95rem;
				color: var(--text-muted);
				max-width: 600px;
				margin: 0 auto 2em;
				line-height: 1.6;
			}

			/* 🔍 Central Search Input */
			.search-wrapper {
				max-width: 640px;
				margin: 0 auto 2.5em;
				position: relative;
			}
			.search-input-box {
				width: 100%;
				padding: 1.1em 1.5em 1.1em 3.2em;
				background: var(--search-bg);
				backdrop-filter: blur(16px);
				border: 1px solid var(--card-border);
				border-radius: 16px;
				color: var(--text-main);
				font-size: 1.05rem;
				outline: none;
				box-sizing: border-box;
				box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
				transition: all 0.3s ease;
			}
			.search-input-box:focus {
				border-color: var(--accent);
				box-shadow: 0 0 25px var(--accent-glow);
			}
			.search-icon {
				position: absolute;
				left: 1.2em;
				top: 50%;
				transform: translateY(-50%);
				font-size: 1.2rem;
				opacity: 0.6;
				pointer-events: none;
			}

			/* 📦 Section Header */
			.section-title-wrapper {
				display: flex;
				align-items: center;
				justify-content: space-between;
				margin-bottom: 1.2rem;
			}
			.section-title {
				font-size: 1.35rem;
				font-weight: 700;
				letter-spacing: -0.5px;
				color: var(--text-main);
				margin: 0;
			}
			.result-count-badge {
				font-size: 0.82rem;
				color: var(--text-muted);
				font-weight: 600;
				background: var(--gray-light);
				padding: 0.25em 0.7em;
				border-radius: 12px;
				border: 1px solid var(--card-border);
			}

			/* ⚡ 3-Column Standard Grid */
			.tool-grid {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
				gap: 1.5rem;
			}

			/* 💎 Tool Card (.tool-card) */
			.tool-card {
				background: var(--bg-card);
				backdrop-filter: blur(12px);
				-webkit-backdrop-filter: blur(12px);
				border: 1px solid var(--card-border);
				border-radius: 16px;
				padding: 1.8rem;
				text-decoration: none !important;
				color: var(--text-main);
				display: flex;
				flex-direction: column;
				position: relative;
				box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
				transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
				box-sizing: border-box;
			}

			.tool-card:hover {
				transform: translateY(-6px);
				border-color: var(--accent);
				box-shadow: 0 12px 30px -5px var(--accent-glow);
			}

			.tool-icon {
				font-size: 2.2rem;
				margin-bottom: 1rem;
				line-height: 1;
			}

			.tool-card h3 {
				font-size: 1.25rem;
				font-weight: 700;
				margin-bottom: 0.6rem;
				color: var(--text-main);
				line-height: 1.3;
			}

			.tool-card p {
				font-size: 0.92rem;
				color: var(--text-muted);
				flex: 1;
				margin-bottom: 1.2rem;
				line-height: 1.6;
			}

			/* Footer Layout & Badges */
			.tool-card-footer {
				display: flex;
				justify-content: space-between;
				align-items: center;
				margin-top: auto;
			}

			.tool-tag {
				font-size: 0.75rem;
				font-weight: 700;
				text-transform: uppercase;
				letter-spacing: 0.5px;
			}

			.tag-tool { color: var(--cyan); }
			.tag-blog { color: var(--accent); }
			.tag-sponsor { color: #f59e0b; }

			.type-badge {
				font-size: 0.7rem;
				padding: 0.2em 0.6em;
				border-radius: 6px;
				font-weight: 700;
				text-transform: uppercase;
			}
			.badge-tool { background: rgba(6, 182, 212, 0.15); color: var(--cyan); border: 1px solid rgba(6, 182, 212, 0.25); }
			.badge-blog { background: rgba(99, 102, 241, 0.15); color: var(--accent); border: 1px solid rgba(99, 102, 241, 0.25); }
			.badge-sponsor { background: rgba(245, 158, 11, 0.15); color: #f59e0b; border: 1px solid rgba(245, 158, 11, 0.3); }

			.pinned-icon {
				position: absolute;
				top: 1rem;
				right: 1rem;
				font-size: 0.9rem;
				opacity: 0.8;
			}

			/* 📄 Client-side Pagination Styles */
			.pagination-wrapper {
				display: flex;
				justify-content: center;
				align-items: center;
				gap: 1rem;
				margin-top: 3em;
			}
			.page-btn {
				background: var(--bg-card);
				border: 1px solid var(--card-border);
				color: var(--text-main);
				padding: 0.6em 1.2em;
				border-radius: 10px;
				font-weight: 600;
				font-size: 0.9rem;
				cursor: pointer;
				transition: all 0.2s ease;
			}
			.page-btn:hover:not(:disabled) {
				border-color: var(--accent);
				color: var(--accent);
				transform: translateY(-2px);
			}
			.page-btn:disabled {
				opacity: 0.4;
				cursor: not-allowed;
			}
			.page-info {
				font-size: 0.9rem;
				font-weight: 600;
				color: var(--text-muted);
			}

			/* No Results Alert */
			.no-results {
				text-align: center;
				padding: 4em 1em;
				color: var(--text-muted);
				grid-column: 1 / -1;
				display: none;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<div class="badge">🚀 Micro AI Tools for Big Help</div>
				<h1>HelpMini</h1>
				
				<!-- 🔍 Central Search Input -->
				<div class="search-wrapper">
					<span class="search-icon">🔍</span>
					<input
						type="text"
						id="searchInput"
						class="search-input-box"
						placeholder="Search tools, guides, or keywords... (e.g., SEO, Token, Prompt)"
						autocomplete="off"
					/>
				</div>
			</section>

			<!-- 📦 Main Content & Search Display Area -->
			<section>
				<div class="section-title-wrapper">
					<h2 id="sectionTitle" class="section-title">Featured Micro Tools</h2>
					<span id="resultCount" class="result-count-badge"></span>
				</div>
				
				<div id="contentGrid" class="tool-grid">
					{allSearchableItems.map((item) => (
						<a 
							href={item.url} 
							class="tool-card searchable-item"
							data-title={item.title.toLowerCase()}
							data-desc={item.desc.toLowerCase()}
							data-keywords={item.keywords.toLowerCase()}
							target={item.url.startsWith('http') ? '_blank' : '_self'}
							rel={item.url.startsWith('http') ? 'noopener' : ''}
						>
							{item.pinned && <span class="pinned-icon" title="Pinned">📌</span>}
							<div class="tool-icon">{item.icon}</div>
							<h3>{item.title}</h3>
							<p>{item.desc}</p>
							<div class="tool-card-footer">
								<span class={`tool-tag tag-${item.type}`}>{item.tag || 'Tool'}</span>
								<span class={`type-badge badge-${item.type}`}>{item.type === 'sponsor' ? 'Ad' : (item.type === 'blog' ? 'Blog' : 'Tool')}</span>
							</div>
						</a>
					))}

					<div id="noResults" class="no-results">
						<div style="font-size: 2.5rem; margin-bottom: 0.5rem;">🔍</div>
						<p style="font-size: 1.1rem; font-weight: 600;">No matching tools or guides found</p>
						<p style="font-size: 0.88rem; opacity: 0.8;">Try searching for other keywords like "SEO", "JSON", or "Token"</p>
					</div>
				</div>

				<!-- 📄 Dynamic Client-Side Pagination Controls -->
				<div id="pagination" class="pagination-wrapper">
					<button id="prevBtn" class="page-btn">← Previous</button>
					<span id="pageInfo" class="page-info">Page 1</span>
					<button id="nextBtn" class="page-btn">Next →</button>
				</div>
			</section>

			<section class="hero" style="padding-top: 4em;">
				<p>Lightweight, instant productivity tools that save you hours.</p>
			</section>
		</main>
		<Footer />

		<!-- Lightweight Client JS: Handles 21-item pagination & search filtering -->
		<script is:inline>
			const ITEMS_PER_PAGE = 21; // Max 21 items per page
			let currentPage = 1;
			let filteredItems = [];

			const searchInput = document.getElementById('searchInput');
			const sectionTitle = document.getElementById('sectionTitle');
			const resultCount = document.getElementById('resultCount');
			const items = Array.from(document.querySelectorAll('.searchable-item'));
			const noResults = document.getElementById('noResults');

			const pagination = document.getElementById('pagination');
			const prevBtn = document.getElementById('prevBtn');
			const nextBtn = document.getElementById('nextBtn');
			const pageInfo = document.getElementById('pageInfo');

			// Render cards for the current page
			function renderPage() {
				const query = searchInput?.value.toLowerCase().trim() || '';
				const totalItems = filteredItems.length;
				const totalPages = Math.ceil(totalItems / ITEMS_PER_PAGE) || 1;

				if (currentPage > totalPages) currentPage = totalPages;
				if (currentPage < 1) currentPage = 1;

				const startIndex = (currentPage - 1) * ITEMS_PER_PAGE;
				const endIndex = startIndex + ITEMS_PER_PAGE;

				// Hide all cards first, then show current page items
				items.forEach(item => item.style.display = 'none');
				
				const visibleItems = filteredItems.slice(startIndex, endIndex);
				visibleItems.forEach(item => item.style.display = 'flex');

				// Update title and count badge
				if (sectionTitle) sectionTitle.textContent = query ? 'Search Results' : 'Featured Micro Tools';
				if (resultCount) resultCount.textContent = `${totalItems} items`;

				// Toggle No Results UI
				if (noResults) {
					noResults.style.display = totalItems === 0 ? 'block' : 'none';
				}

				// Handle pagination controls display
				if (pagination) {
					if (totalItems <= ITEMS_PER_PAGE) {
						pagination.style.display = 'none'; // Hide pagination if <= 21 items
					} else {
						pagination.style.display = 'flex';
						if (pageInfo) pageInfo.textContent = `Page ${currentPage} of ${totalPages}`;
						if (prevBtn) prevBtn.disabled = currentPage === 1;
						if (nextBtn) nextBtn.disabled = currentPage === totalPages;
					}
				}
			}

			// Search Filter Handler
			function handleSearch() {
				const query = searchInput?.value.toLowerCase().trim() || '';

				filteredItems = items.filter(item => {
					const title = item.getAttribute('data-title') || '';
					const desc = item.getAttribute('data-desc') || '';
					const keywords = item.getAttribute('data-keywords') || '';
					return title.includes(query) || desc.includes(query) || keywords.includes(query);
				});

				currentPage = 1; // Reset to page 1 on search
				renderPage();
			}

			// Pagination Event Listeners
			prevBtn?.addEventListener('click', () => {
				if (currentPage > 1) {
					currentPage--;
					renderPage();
					window.scrollTo({ top: 300, behavior: 'smooth' });
				}
			});

			nextBtn?.addEventListener('click', () => {
				const totalPages = Math.ceil(filteredItems.length / ITEMS_PER_PAGE);
				if (currentPage < totalPages) {
					currentPage++;
					renderPage();
					window.scrollTo({ top: 300, behavior: 'smooth' });
				}
			});

			// Search Input Event Listener
			searchInput?.addEventListener('input', handleSearch);

			// Initial page load setup
			filteredItems = [...items];
			renderPage();
		</script>
	</body>
</html>
