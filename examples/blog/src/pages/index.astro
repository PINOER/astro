---
import BaseHead from 'src/components/BaseHead.astro';
import Header from 'src/components/Header.astro';
import Footer from 'src/components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from 'src/consts';
import { getCollection } from 'astro:content';
import { toolsData } from 'src/data/tools';

// 1. 获取英文博客
const allPosts = await getCollection('blog');
const enPosts = allPosts.filter((post) => post.data?.lang === 'en' || post.id.startsWith('en/'));

// 2. 赞助商/广告卡片配置（可随时增减或从配置文件读取）
const sponsorItems = [
	// 示例赞助商卡片（取消注释即可开启）
	/*
	{
		title: 'Vercel Pro Cloud',
		desc: 'Deploy your frontend applications with instant global CDN and zero configuration.',
		url: 'https://vercel.com',
		type: 'sponsor',
		icon: '⚡',
		tag: 'Sponsor',
		keywords: 'cloud hosting deployment vercel CDN',
		pinned: true,      // 是否置顶
		priority: 100      // 排序优先级 (越高越靠前)
	}
	*/
];

// 3. 组装统一的数据集 (Tools + Blogs + Sponsors)
const allSearchableItems = [
	...toolsData.map((tool) => ({
		title: tool.title.en,
		desc: tool.desc.en,
		url: tool.url.en,
		type: 'tool',
		icon: tool.icon,
		tag: tool.tag.en,
		keywords: `${tool.title.en} ${tool.keywords.en}`,
		pinned: (tool as any).pinned || false,
		priority: (tool as any).priority || 0
	})),
	...enPosts.map((post) => ({
		title: post.data.title,
		desc: post.data.description,
		url: `/blog/${post.id.replace(/\.(md|mdx)$/, '').replace(/\/index$/, '')}/`,
		type: 'blog',
		icon: '📚',
		tag: 'Guide',
		keywords: `${post.data.title} ${post.data.description}`,
		pinned: false,
		priority: 0
	})),
	...sponsorItems
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 1000px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 3em 1em 5em;
			}
			.hero {
				text-align: center;
				padding: 2em 0 3em;
				position: relative;
			}
			.badge {
				display: inline-block;
				background: var(--badge-bg);
				color: var(--badge-color);
				border: 1px solid var(--badge-border);
				padding: 0.4em 1.2em;
				border-radius: 20px;
				font-size: 0.85rem;
				font-weight: 600;
				margin-bottom: 1.5em;
				box-shadow: 0 0 15px rgba(99, 102, 241, 0.15);
				transition: all 0.3s ease;
			}
			.hero h1 {
				font-size: 3.5rem;
				font-weight: 800;
				margin-bottom: 0.4em;
				line-height: 1.2;
				letter-spacing: -1px;
				background: var(--hero-title-gradient);
				-webkit-background-clip: text;
				-webkit-text-fill-color: transparent;
			}
			.hero p {
				font-size: 0.95rem;
				color: var(--text-muted);
				max-width: 600px;
				margin: 0 auto 2em;
				line-height: 1.6;
			}

			/* 🔍 中央搜索框设计 */
			.search-wrapper {
				max-width: 640px;
				margin: 0 auto 3em;
				position: relative;
			}
			.search-input-box {
				width: 100%;
				padding: 1.1em 1.5em 1.1em 3.2em;
				background: var(--search-bg);
				backdrop-filter: blur(16px);
				border: 1px solid var(--card-border);
				border-radius: 16px;
				color: var(--text-main);
				font-size: 1.05rem;
				outline: none;
				box-sizing: border-box;
				box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
				transition: all 0.3s ease;
			}
			.search-input-box:focus {
				border-color: var(--accent);
				box-shadow: 0 0 25px var(--accent-glow);
			}
			.search-icon {
				position: absolute;
				left: 1.2em;
				top: 50%;
				transform: translateY(-50%);
				font-size: 1.2rem;
				opacity: 0.6;
				pointer-events: none;
			}

			/* 📦 统一内容与搜索结果展示区 */
			.section-title-wrapper {
				display: flex;
				align-items: center;
				justify-content: space-between;
				margin-bottom: 1.5rem;
			}
			.section-title {
				font-size: 1.35rem;
				font-weight: 700;
				letter-spacing: -0.5px;
				color: var(--text-main);
				margin: 0;
			}
			.result-count-badge {
				font-size: 0.82rem;
				color: var(--text-muted);
				font-weight: 600;
				background: var(--gray-light);
				padding: 0.25em 0.7em;
				border-radius: 12px;
				border: 1px solid var(--card-border);
			}

			/* ⚡ 响应式极客网格：长方形布局 */
			.tool-grid {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
				gap: 1.2rem;
			}

			/* 💎 扁平长方形科技感卡片 */
			.item-card {
				background: var(--bg-card);
				backdrop-filter: blur(16px);
				-webkit-backdrop-filter: blur(16px);
				border: 1px solid var(--card-border);
				border-radius: 14px;
				padding: 1.1rem 1.3rem;
				text-decoration: none;
				color: var(--text-main);
				display: flex;
				align-items: center;
				gap: 1.1rem;
				position: relative;
				overflow: hidden;
				transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
				box-shadow: 0 4px 20px rgba(0, 0, 0, 0.04);
			}

			/* 顶部高光微边框与极光悬浮 Glow 效果 */
			.item-card::before {
				content: '';
				position: absolute;
				top: 0;
				left: 0;
				right: 0;
				height: 1px;
				background: linear-gradient(90deg, transparent, var(--accent), transparent);
				opacity: 0;
				transition: opacity 0.3s ease;
			}

			.item-card:hover {
				transform: translateY(-3px) scale(1.01);
				border-color: var(--accent);
				box-shadow: 0 8px 25px -5px var(--accent-glow);
			}

			.item-card:hover::before {
				opacity: 1;
			}

			/* 左侧 Icon 科技晶体微框 */
			.item-icon-box {
				width: 48px;
				height: 48px;
				min-width: 48px;
				border-radius: 12px;
				background: var(--gray-light);
				border: 1px solid var(--card-border);
				display: flex;
				align-items: center;
				justify-content: center;
				font-size: 1.6rem;
				transition: transform 0.3s ease, border-color 0.3s ease;
			}

			.item-card:hover .item-icon-box {
				transform: scale(1.08) rotate(-3deg);
				border-color: var(--accent);
			}

			/* 右侧长方形主体布局 */
			.item-body {
				flex: 1;
				min-width: 0; /* 防止文本溢出破框 */
				display: flex;
				flex-direction: column;
				justify-content: center;
			}

			.item-header-row {
				display: flex;
				align-items: center;
				justify-content: space-between;
				gap: 0.5rem;
				margin-bottom: 0.3rem;
			}

			.item-card h3 {
				font-size: 1.05rem;
				font-weight: 700;
				margin: 0;
				color: var(--text-main);
				white-space: nowrap;
				overflow: hidden;
				text-overflow: ellipsis;
			}

			.item-card p {
				font-size: 0.83rem;
				color: var(--text-muted);
				margin: 0;
				line-height: 1.45;
				display: -webkit-box;
				-webkit-line-clamp: 2; /* 限制最多2行 */
				-webkit-box-orient: vertical;
				overflow: hidden;
			}

			/* 科技微型 Badge 标签 */
			.type-badge {
				font-size: 0.68rem;
				padding: 0.15em 0.5em;
				border-radius: 6px;
				font-weight: 700;
				text-transform: uppercase;
				letter-spacing: 0.3px;
				white-space: nowrap;
				flex-shrink: 0;
			}
			.badge-tool { background: rgba(6, 182, 212, 0.12); color: var(--cyan); border: 1px solid rgba(6, 182, 212, 0.25); }
			.badge-blog { background: rgba(99, 102, 241, 0.12); color: var(--accent); border: 1px solid rgba(99, 102, 241, 0.25); }
			.badge-sponsor { background: rgba(245, 158, 11, 0.12); color: #f59e0b; border: 1px solid rgba(245, 158, 11, 0.3); }

			/* 置顶 Pin 标志 */
			.pinned-tag {
				font-size: 0.7rem;
				margin-right: 0.3rem;
			}

			.no-results {
				text-align: center;
				padding: 3em 1em;
				color: var(--text-muted);
				grid-column: 1 / -1;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<div class="badge">🚀 Micro AI Tools for Big Help</div>
				<h1>HelpMini</h1>
				
				<!-- 🔍 中央搜索框 -->
				<div class="search-wrapper">
					<span class="search-icon">🔍</span>
					<input
						type="text"
						id="searchInput"
						class="search-input-box"
						placeholder="Search tools, guides, or keywords... (e.g., SEO, Token, Prompt)"
						autocomplete="off"
					/>
				</div>
			</section>

			<!-- 📦 统一内容与搜索结果展示区 -->
			<section>
				<div class="section-title-wrapper">
					<h2 id="sectionTitle" class="section-title">Featured Micro Tools</h2>
					<span id="resultCount" class="result-count-badge"></span>
				</div>
				
				<!-- 动态网格展示容器 -->
				<div id="contentGrid" class="tool-grid"></div>
			</section>

			<section class="hero" style="padding-top: 4em;">
				<p>Lightweight, instant productivity tools that save you hours.</p>
			</section>
		</main>
		<Footer />

		<!-- 客户端实时驱动脚本 -->
		<script is:inline define:vars={{ allSearchableItems }}>
			const searchInput = document.getElementById('searchInput');
			const sectionTitle = document.getElementById('sectionTitle');
			const resultCount = document.getElementById('resultCount');
			const contentGrid = document.getElementById('contentGrid');

			// 1. 核心排序函数（置顶优先 -> 优先级最高 -> 默认顺序）
			function sortItems(items) {
				return [...items].sort((a, b) => {
					if (a.pinned && !b.pinned) return -1;
					if (!a.pinned && b.pinned) return 1;
					return (b.priority || 0) - (a.priority || 0);
				});
			}

			// 2. 渲染长方形科技卡片
			function renderItems(items) {
				if (!contentGrid) return;

				if (items.length === 0) {
					contentGrid.innerHTML = `
						<div class="no-results">
							<div style="font-size: 2.2rem; margin-bottom: 0.5rem;">🔍</div>
							<p style="font-size: 1rem; font-weight: 600;">No matching tools or guides found</p>
							<p style="font-size: 0.85rem; opacity: 0.8;">Try searching for other keywords like "SEO", "JSON", or "Token"</p>
						</div>
					`;
					return;
				}

				contentGrid.innerHTML = items.map(item => {
					const isExternal = item.url.startsWith('http');
					const typeBadgeClass = item.type === 'sponsor' ? 'badge-sponsor' : (item.type === 'blog' ? 'badge-blog' : 'badge-tool');
					const typeLabel = item.type === 'sponsor' ? 'Ad' : (item.type === 'blog' ? 'Blog' : 'Tool');

					return `
						<a href="${item.url}" class="item-card" ${isExternal ? 'target="_blank" rel="noopener"' : ''}>
							<div class="item-icon-box">${item.icon}</div>
							<div class="item-body">
								<div class="item-header-row">
									<h3>${item.pinned ? '<span class="pinned-tag">📌</span>' : ''}${item.title}</h3>
									<span class="type-badge ${typeBadgeClass}">${typeLabel}</span>
								</div>
								<p>${item.desc}</p>
							</div>
						</a>
					`;
				}).join('');
			}

			// 3. 初始渲染逻辑 (未搜索时，最多前 20 项)
			function initDefaultView() {
				const sorted = sortItems(allSearchableItems);
				const default20 = sorted.slice(0, 20); // 最多显示前 20 项
				
				if (sectionTitle) sectionTitle.textContent = 'Featured Micro Tools';
				if (resultCount) resultCount.textContent = `${default20.length} items`;
				
				renderItems(default20);
			}

			// 4. 监听搜索事件
			searchInput?.addEventListener('input', (e) => {
				const query = e.target.value.toLowerCase().trim();

				if (!query) {
					initDefaultView();
					return;
				}

				// 搜寻匹配
				const filtered = allSearchableItems.filter(item =>
					item.title.toLowerCase().includes(query) ||
					item.desc.toLowerCase().includes(query) ||
					item.keywords.toLowerCase().includes(query)
				);

				const sortedResults = sortItems(filtered);

				if (sectionTitle) sectionTitle.textContent = 'Search Results';
				if (resultCount) resultCount.textContent = `${sortedResults.length} found`;

				renderItems(sortedResults);
			});

			// 初始化执行
			initDefaultView();
		</script>
	</body>
</html>
