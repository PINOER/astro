---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';

// 自动读取 src/content/blog/ 目录下的所有文章并按时间倒序排列
const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			:root {
				--accent: #6366f1;
				--accent-dark: #4f46e5;
			}
			main {
				width: 960px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 3em 1em;
			}
			.hero {
				text-align: center;
				padding: 3em 0 2em;
			}
			.hero h1 {
				font-size: 3rem;
				font-weight: 800;
				margin-bottom: 0.5em;
				line-height: 1.2;
			}
			.hero p {
				font-size: 1.25rem;
				color: #64748b;
				max-width: 600px;
				margin: 0 auto 2em;
			}
			.badge {
				display: inline-block;
				background: rgba(99, 102, 241, 0.1);
				color: var(--accent);
				border: 1px solid rgba(99, 102, 241, 0.2);
				padding: 0.3em 0.8em;
				border-radius: 20px;
				font-size: 0.85rem;
				font-weight: 600;
				margin-bottom: 1em;
			}
			.section-title {
				font-size: 1.5rem;
				font-weight: 700;
				margin: 2em 0 1em;
				border-bottom: 2px solid #f1f5f9;
				padding-bottom: 0.5em;
			}
			ul {
				display: flex;
				flex-wrap: wrap;
				gap: 2rem;
				list-style-type: none;
				margin: 0;
				padding: 0;
			}
			ul li {
				width: calc(50% - 1rem);
			}
			ul li * {
				text-decoration: none;
				transition: 0.2s ease;
			}
			ul li img {
				margin-bottom: 0.5rem;
				border-radius: 12px;
			}
			ul li a {
				display: block;
			}
			.title {
				margin: 0;
				color: rgb(var(--black));
				line-height: 1.2;
				font-size: 1.25rem;
			}
			.date {
				margin: 0;
				color: rgb(var(--gray));
				font-size: 0.9rem;
			}
			ul li a:hover .title {
				color: var(--accent);
			}
			@media (max-width: 720px) {
				ul li {
					width: 100%;
				}
				.hero h1 {
					font-size: 2.2rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<!-- Hero 介绍区 -->
			<section class="hero">
				<div class="badge">🚀 Mini-tools for Big Help</div>
				<h1>HelpMini</h1>
				<p>Lightweight AI tools, prompts, and actionable guides to boost your everyday productivity 10x.</p>
			</section>

			<!-- 博客内容区 -->
			<h2 class="section-title">Latest Articles & Guides</h2>
			<section>
				<ul>
					{
						posts.map((post) => (
							<li>
								<a href={`/blog/${post.slug}/`}>
									{post.data.heroImage && (
										<img width={720} height={360} src={post.data.heroImage} alt="" />
									)}
									<h4 class="title">{post.data.title}</h4>
									<p class="date">
										<FormattedDate date={post.data.pubDate} />
									</p>
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>
