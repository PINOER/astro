---
import BaseHead from 'src/components/BaseHead.astro';
import Header from 'src/components/Header.astro';
import Footer from 'src/components/Footer.astro';
import { SITE_TITLE } from 'src/consts';

const pageTitle = `SEO Meta 标题与描述生成器 — ${SITE_TITLE}`;
const pageDescription = "一键生成高点击率 (CTR) 的 Google Meta 标题与描述，实时预览谷歌搜索结果卡片并检查字数限制。";
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={pageTitle} description={pageDescription} />
		<style>
			main {
				width: 850px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 3em 1em 5em;
			}
			.tool-header {
				text-align: center;
				margin-bottom: 2em;
			}
			.tool-header h1 {
				font-size: 2.2rem;
				font-weight: 800;
				margin-bottom: 0.3em;
				background: var(--hero-title-gradient);
				-webkit-background-clip: text;
				-webkit-text-fill-color: transparent;
			}
			.tool-header p {
				color: var(--text-muted);
				font-size: 1.05rem;
			}
			.tool-box {
				background: var(--bg-card);
				backdrop-filter: blur(12px);
				border: 1px solid var(--card-border);
				border-radius: 16px;
				padding: 2em;
				box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
			}
			.form-group {
				margin-bottom: 1.2em;
			}
			label {
				display: block;
				font-weight: 600;
				margin-bottom: 0.5em;
				color: var(--text-main);
			}
			input[type="text"], textarea, select {
				width: 100%;
				padding: 0.8em 1em;
				background: var(--search-bg);
				border: 1px solid var(--card-border);
				border-radius: 8px;
				color: var(--text-main);
				font-size: 0.95rem;
				box-sizing: border-box;
				outline: none;
				transition: border-color 0.2s, box-shadow 0.2s;
			}
			input[type="text"]:focus, textarea:focus, select:focus {
				border-color: var(--accent);
				box-shadow: 0 0 10px var(--accent-glow);
			}
			.btn-generate {
				width: 100%;
				background: var(--accent);
				color: #ffffff;
				border: none;
				padding: 0.9em;
				font-size: 1rem;
				font-weight: 700;
				border-radius: 8px;
				cursor: pointer;
				transition: background 0.2s;
				margin-top: 1em;
			}
			.btn-generate:hover {
				background: var(--accent-hover);
			}
			.results-wrapper {
				margin-top: 2em;
				display: none;
			}
			.results-wrapper h3 {
				font-size: 1.1rem;
				font-weight: 700;
				margin-bottom: 1em;
				color: var(--text-main);
			}
			.result-card {
				background: var(--gray-light);
				border: 1px solid var(--card-border);
				border-radius: 12px;
				padding: 1.2rem;
				margin-bottom: 1.2rem;
			}
			.result-header {
				display: flex;
				justify-content: space-between;
				align-items: center;
				margin-bottom: 0.5rem;
			}
			.result-tag {
				font-size: 0.75rem;
				color: var(--cyan);
				font-weight: 700;
				text-transform: uppercase;
				letter-spacing: 0.5px;
			}
			.btn-copy-sm {
				background: var(--bg-card);
				border: 1px solid var(--card-border);
				color: var(--text-main);
				padding: 0.35em 0.7em;
				border-radius: 6px;
				cursor: pointer;
				font-size: 0.8rem;
				font-weight: 600;
				transition: all 0.2s ease;
			}
			.btn-copy-sm:hover {
				border-color: var(--accent);
				color: var(--accent);
			}
			/* 🎯 Google SERP 真实模拟预览区（保持真实 Google 白底样式） */
			.serp-preview {
				background: #ffffff !important;
				padding: 1.2rem;
				border-radius: 8px;
				border: 1px solid #dadce0;
				margin-top: 0.8rem;
				font-family: arial, sans-serif;
				box-shadow: 0 1px 6px rgba(32, 33, 36, 0.1);
			}
			.serp-title {
				color: #1a0dab !important;
				font-size: 18px;
				line-height: 1.3;
				cursor: pointer;
				text-decoration: none;
				display: block;
				margin-bottom: 2px;
				font-weight: 400;
			}
			.serp-title:hover {
				text-decoration: underline;
			}
			.serp-url {
				color: #202124 !important;
				font-size: 12px;
				line-height: 1.3;
				margin-bottom: 4px;
			}
			.serp-desc {
				color: #4d5156 !important;
				font-size: 14px;
				line-height: 1.58;
			}
			.char-counter {
				font-size: 0.8rem;
				color: var(--text-muted);
				margin-top: 0.6rem;
				display: flex;
				justify-content: space-between;
			}
		</style>
	</head>
	<body>
		<Header lang="zh" />
		<main>
			<div class="tool-header">
				<h1>🔍 SEO Meta 标题与描述生成器</h1>
				<p>生成符合 Google 规范的高点击率 (CTR) 元标签，自带实时 Google 搜索卡片预览。</p>
			</div>

			<div class="tool-box">
				<div class="form-group">
					<label for="topicInput">页面主题 / 核心关键词：</label>
					<input type="text" id="topicInput" placeholder="例如：2026年提升 Shopify 独立站销量的必装 App 推荐" />
				</div>

				<div class="form-group">
					<label for="brandInput">品牌名称 / 网站名称（选填）：</label>
					<input type="text" id="brandInput" placeholder="例如：HelpMini" />
				</div>

				<button class="btn-generate" id="generateBtn">生成高点击率 Meta 标签 ✨</button>

				<div class="results-wrapper" id="resultsWrapper">
					<h3>生成的 Meta 标签预案</h3>

					<!-- 方案 1: 高点击率互动导向 -->
					<div class="result-card">
						<div class="result-header">
							<div class="result-tag">🔥 高点击率 (CTR) / 实操指南导向</div>
							<button class="btn-copy-sm" data-target="opt1">复制标签</button>
						</div>
						<div class="serp-preview">
							<a class="serp-title" id="title1">标题输出中...</a>
							<div class="serp-url">https://example.com/page</div>
							<div class="serp-desc" id="desc1">描述输出中...</div>
						</div>
						<div class="char-counter">
							<span id="lenTitle1">标题: 0 / 60 字符</span>
							<span id="lenDesc1">描述: 0 / 155 字符</span>
						</div>
					</div>

					<!-- 方案 2: 专业权威权威导向 -->
					<div class="result-card">
						<div class="result-header">
							<div class="result-tag">🎓 权威专业 / 终极指南导向</div>
							<button class="btn-copy-sm" data-target="opt2">复制标签</button>
						</div>
						<div class="serp-preview">
							<a class="serp-title" id="title2">标题输出中...</a>
							<div class="serp-url">https://example.com/page</div>
							<div class="serp-desc" id="desc2">描述输出中...</div>
						</div>
						<div class="char-counter">
							<span id="lenTitle2">标题: 0 / 60 字符</span>
							<span id="lenDesc2">描述: 0 / 155 字符</span>
						</div>
					</div>
				</div>
			</div>
		</main>
		<Footer lang="zh" />

		<script>
			const generateBtn = document.getElementById('generateBtn');
			const topicInput = document.getElementById('topicInput') as HTMLInputElement;
			const brandInput = document.getElementById('brandInput') as HTMLInputElement;
			const resultsWrapper = document.getElementById('resultsWrapper') as HTMLDivElement;

			generateBtn?.addEventListener('click', () => {
				const topic = topicInput.value.trim();
				const brand = brandInput.value.trim();

				if (!topic) {
					alert('请输入页面主题或核心关键词！');
					return;
				}

				const brandSuffix = brand ? ` | ${brand}` : '';

				// 方案 1: 高 CTR / 实操指南
				const t1 = `10+ 实操干货：${topic} (新手避坑指南)${brandSuffix}`;
				const d1 = `还在寻找优秀的 ${topic} 解决方案？立即探索专家实操建议与高转化策略，快速提升你的业务成果！`;

				// 方案 2: 专业权威 / 终极框架
				const t2 = `${topic} 终极完全指南 [2026 最新版]${brandSuffix}`;
				const d2 = `基于 2026 最新策略深度解析 ${topic}。掌握行业核心技巧，助你避开常见误区，轻松获取更高权重。`;

				// 更新 UI
				updateOption('1', t1, d1);
				updateOption('2', t2, d2);

				resultsWrapper.style.display = 'block';
			});

			function updateOption(id: string, title: string, desc: string) {
				const titleEl = document.getElementById(`title${id}`);
				const descEl = document.getElementById(`desc${id}`);
				const lenTitleEl = document.getElementById(`lenTitle${id}`);
				const lenDescEl = document.getElementById(`lenDesc${id}`);

				if (titleEl) titleEl.textContent = title;
				if (descEl) descEl.textContent = desc;

				if (lenTitleEl) lenTitleEl.textContent = `标题: ${title.length} / 60 字符 ${title.length > 60 ? '⚠️ 建议精简' : '✅ 长度合适'}`;
				if (lenDescEl) lenDescEl.textContent = `描述: ${desc.length} / 155 字符 ${desc.length > 155 ? '⚠️ 建议精简' : '✅ 长度合适'}`;
			}

			// 复制按钮逻辑
			document.querySelectorAll('.btn-copy-sm').forEach(btn => {
				btn.addEventListener('click', (e) => {
					const target = (e.target as HTMLElement).getAttribute('data-target');
					const id = target === 'opt1' ? '1' : '2';
					const titleText = document.getElementById(`title${id}`)?.textContent || '';
					const descText = document.getElementById(`desc${id}`)?.textContent || '';

					const textToCopy = `Meta 标题: ${titleText}\nMeta 描述: ${descText}`;
					navigator.clipboard.writeText(textToCopy);

					btn.textContent = '已复制！';
					setTimeout(() => { btn.textContent = '复制标签'; }, 2000);
				});
			});
		</script>
	</body>
</html>
