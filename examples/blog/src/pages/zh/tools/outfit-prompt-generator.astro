---
import BaseHead from 'src/components/BaseHead.astro';
import Header from 'src/components/Header.astro';
import Footer from 'src/components/Footer.astro';
import { SITE_TITLE } from 'src/consts';

export const frontmatter = {
    title: "AI 人物换装与时尚穿搭提示词生成器",
    description: "精准替换服装材质、版型、穿搭风格与配饰，保持人物脸部一致，生成适用于 Midjourney、Flux 与 SDXL 的时尚换装 Prompt。",
    icon: "👗",
    tag: "AI 时尚",
    keywords: "AI 换装提示词 时尚穿搭 提示词生成器 midjourney flux 服装设计 服饰替换",
    pinned: true,
    priority: 97
};

const pageTitle = `AI 人物换装与时尚穿搭提示词生成器 — ${SITE_TITLE}`;
const pageDescription = "精准替换服装材质、版型、穿搭风格与配饰，保持人物脸部一致，生成适用于 Midjourney、Flux 与 SDXL 的时尚换装 Prompt。";
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={pageTitle} description={pageDescription} />
		<style>
			main {
				width: 1000px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 2.5em 1em 4em;
			}
			.tool-header {
				text-align: center;
				margin-bottom: 2em;
			}
			.tool-header h1 {
				font-size: 2.5rem;
				font-weight: 800;
				margin-bottom: 0.3em;
				background: var(--hero-title-gradient);
				-webkit-background-clip: text;
				-webkit-text-fill-color: transparent;
			}
			.tool-header p {
				color: var(--text-muted);
				font-size: 0.95rem;
			}

			.form-grid {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
				gap: 1.2rem;
				background: var(--bg-card);
				border: 1px solid var(--card-border);
				border-radius: 16px;
				padding: 1.8rem;
				backdrop-filter: blur(12px);
				box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
				margin-bottom: 2rem;
			}
			.form-group {
				display: flex;
				flex-direction: column;
				gap: 0.5rem;
			}
			.form-group.full-width {
				grid-column: 1 / -1;
			}
			label {
				font-size: 0.88rem;
				font-weight: 700;
				color: var(--text-main);
				display: flex;
				justify-content: space-between;
				align-items: center;
			}
			label .sub-tag {
				font-size: 0.75rem;
				color: var(--text-muted);
				font-weight: normal;
			}

			input[type="text"], select, textarea {
				width: 100%;
				padding: 0.75em 1em;
				background: var(--search-bg);
				border: 1px solid var(--card-border);
				border-radius: 8px;
				color: var(--text-main);
				font-size: 0.92rem;
				box-sizing: border-box;
				outline: none;
				transition: border-color 0.2s, box-shadow 0.2s;
			}
			input[type="text"]:focus, select:focus, textarea:focus {
				border-color: var(--accent);
				box-shadow: 0 0 10px var(--accent-glow);
			}

			.output-card {
				background: var(--bg-card);
				border: 1px solid var(--card-border);
				border-radius: 16px;
				padding: 1.5rem;
				box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
			}
			.output-header {
				display: flex;
				justify-content: space-between;
				align-items: center;
				margin-bottom: 1rem;
			}
			.output-title {
				font-size: 1.05rem;
				font-weight: 700;
				color: var(--text-main);
			}
			.btn-copy {
				background: var(--accent);
				color: #ffffff;
				border: none;
				padding: 0.6em 1.2em;
				border-radius: 8px;
				font-size: 0.88rem;
				font-weight: 700;
				cursor: pointer;
				transition: all 0.2s ease;
			}
			.btn-copy:hover {
				background: var(--accent-hover);
				transform: translateY(-1px);
			}
			.prompt-output {
				width: 100%;
				height: 140px;
				background: var(--code-bg) !important;
				border: 1px solid var(--card-border);
				border-radius: 10px;
				padding: 1rem;
				color: var(--text-main);
				font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
				font-size: 0.9rem;
				line-height: 1.6;
				resize: vertical;
				box-sizing: border-box;
				outline: none;
			}

			.toast {
				position: fixed;
				bottom: 2rem;
				right: 2rem;
				background: var(--accent);
				color: #fff;
				padding: 0.6em 1.2em;
				border-radius: 8px;
				font-size: 0.88rem;
				font-weight: 600;
				box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
				opacity: 0;
				transform: translateY(10px);
				transition: all 0.3s ease;
				pointer-events: none;
				z-index: 100;
			}
			.toast.show {
				opacity: 1;
				transform: translateY(0);
			}
		</style>
	</head>
	<body>
		<Header lang="zh" />
		<main>
			<div class="tool-header">
				<h1>👗 AI 人物换装与时尚穿搭提示词生成器</h1>
				<p>精准设计服装风格、面料材质、版型剪裁与配饰，一键生成用于 Midjourney、Flux 与 SDXL 换装的高质感 Prompt。</p>
			</div>

			<div class="form-grid">
				<!-- 人物主体与特征 -->
				<div class="form-group full-width">
					<label for="modelInput">
						模特人物特征 (Model Features)
						<span class="sub-tag">描述人物身份与脸部/发型特征，用于保持人物一致性</span>
					</label>
					<input type="text" id="modelInput" placeholder="例如：20代东亚女性模特，黑色中长发，精致淡妆..." />
				</div>

				<!-- 整体穿搭风格 -->
				<div class="form-group">
					<label for="styleSelect">整体穿搭风格 (Fashion Style)</label>
					<select id="styleSelect">
						<option value="Quiet Luxury, minimal old money aesthetic">静奢老钱风 (Quiet Luxury / Old Money)</option>
						<option value="high fashion Vogue editorial style">Vogue 顶级时尚杂志大片风 (High Fashion Editorial)</option>
						<option value="cyberpunk techwear outfit with neon accents">赛博朋克机能风 (Cyberpunk Techwear)</option>
						<option value="Parisian chic street style, effortless elegance">法式复古优雅街拍风 (Parisian Chic)</option>
						<option value="Y2K streetwear style with oversized silhouette">Y2K 美式复古街头风</option>
						<option value="Bohemian minimalist resort wear">波西米亚度假风 (Boho Resort)</option>
						<option value="formal haute couture evening gown style">高级定制晚礼服 (Haute Couture)</option>
					</select>
				</div>

				<!-- 外套/主要上装 -->
				<div class="form-group">
					<label for="topSelect">外套/主要上装 (Top / Outerwear)</label>
					<select id="topSelect">
						<option value="oversized double-breasted beige trench coat">廓形双排扣米色风衣</option>
						<option value="tailored black leather jacket with silver zips">修身黑皮衣外套</option>
						<option value="cozy oversized chunky knit sweater">宽松粗针织毛衣</option>
						<option value="sharp structured oversized blazer">干练垫肩廓形西装外套</option>
						<option value="silk satin button-down shirt">100% 桑蚕丝真丝衬衫</option>
						<option value="cropped denim jacket">短款牛仔外套</option>
						<option value="">无外套 / 连衣裙方案</option>
					</select>
				</div>

				<!-- 内搭/下装/连衣裙 -->
				<div class="form-group">
					<label for="bottomSelect">下装/连衣裙 (Bottom / Dress)</label>
					<select id="bottomSelect">
						<option value="paired with high-waisted wide-leg tailored trousers">高腰垂坠感阔腿西装裤</option>
						<option value="wearing an elegant slip silk maxi dress">优雅吊带真丝长裙</option>
						<option value="paired with vintage straight-leg washed jeans">复古直筒水洗牛仔裤</option>
						<option value="paired with pleated A-line midi skirt">百褶 A 字中长裙</option>
						<option value="paired with sleek fitted leather pants">紧身皮革长裤</option>
					</select>
				</div>

				<!-- 面料与材质 -->
				<div class="form-group">
					<label for="fabricSelect">服装面料与材质 (Fabrics & Texture)</label>
					<select id="fabricSelect">
						<option value="premium mulberry silk, ribbed cashmere, distressed leather">真丝、羊绒与复古皮革混合质感</option>
						<option value="100% heavy silk satin with soft luster">高重磅真丝光泽</option>
						<option value="textured tweed fabric with golden threads">小香风粗花呢与金丝交织</option>
						<option value="matte soft lambskin leather">哑光软羊皮材质</option>
						<option value="sheer organza and delicate lace details">薄纱欧根纱与精致蕾丝</option>
						<option value="raw rigid cotton denim texture">硬挺纯棉牛仔质感</option>
					</select>
				</div>

				<!-- 鞋靴与配饰 -->
				<div class="form-group">
					<label for="accessorySelect">鞋靴与时尚配饰 (Shoes & Accessories)</label>
					<select id="accessorySelect">
						<option value="styled with chunky gold hoop earrings, a vintage leather handbag, and pointy heels">金色耳环、复古皮质手袋与尖头高跟鞋</option>
						<option value="styled with leather Chelsea boots, silver chain necklace, and dark sunglasses">切尔西皮靴、银色项链与黑色墨镜</option>
						<option value="accessorized with minimalist gold watch and designer leather crossbody bag">简约金表与大牌皮革斜挎包</option>
						<option value="styled with retro sneakers and baseball cap">复古运动鞋与棒球帽</option>
					</select>
				</div>

				<!-- 模特摄影姿态 -->
				<div class="form-group">
					<label for="poseSelect">拍摄展示姿态 (Lookbook Pose)</label>
					<select id="poseSelect">
						<option value="full-body lookbook fashion shot, walking on street, candid look">全身时尚 Lookbook 姿态，街头行走抓拍</option>
						<option value="three-quarter length studio portrait shot, confident stance">3/4 摄影棚全身模特姿态，自信挺拔</option>
						<option value="street style candid photography shot, natural lighting">自然光下街头时尚时尚拍</option>
						<option value="runway fashion show walk pose, dramatic lighting">T台走秀模型动态姿态</option>
					</select>
				</div>

				<!-- 画幅比例 -->
				<div class="form-group">
					<label for="arSelect">画面宽高比 (Aspect Ratio --ar)</label>
					<select id="arSelect">
						<option value="--ar 4:5">--ar 4:5 (时尚杂志/Instagram 纵向海报)</option>
						<option value="--ar 3:4">--ar 3:4 (电商 Lookbook 服装展示)</option>
						<option value="--ar 9:16">--ar 9:16 (手机全屏竖屏海报)</option>
						<option value="--ar 16:9">--ar 16:9 (横屏大片)</option>
					</select>
				</div>
			</div>

			<!-- 实时生成预览 -->
			<div class="output-card">
				<div class="output-header">
					<span class="output-title">✨ 生成的英文换装 Prompt (适用于 Midjourney / Flux / SD)</span>
					<button class="btn-copy" id="btnCopy">📋 一键复制换装 Prompt</button>
				</div>
				<textarea id="promptOutput" class="prompt-output" readonly></textarea>
			</div>
		</main>

		<div id="toast" class="toast">换装提示词已成功复制到剪贴板！</div>

		<Footer lang="zh" />

		<script is:inline>
			const modelInput = document.getElementById('modelInput');
			const styleSelect = document.getElementById('styleSelect');
			const topSelect = document.getElementById('topSelect');
			const bottomSelect = document.getElementById('bottomSelect');
			const fabricSelect = document.getElementById('fabricSelect');
			const accessorySelect = document.getElementById('accessorySelect');
			const poseSelect = document.getElementById('poseSelect');
			const arSelect = document.getElementById('arSelect');

			const promptOutput = document.getElementById('promptOutput');
			const btnCopy = document.getElementById('btnCopy');
			const toast = document.getElementById('toast');

			function buildPrompt() {
				const modelDesc = modelInput.value.trim() || 'A beautiful East Asian female model';
				
				const components = [
					poseSelect.value,
					`featuring ${modelDesc}`,
					`wearing ${styleSelect.value}`,
					topSelect.value,
					bottomSelect.value,
					`crafted from ${fabricSelect.value}`,
					accessorySelect.value,
					'shot on Hasselblad H6D-100c, soft studio lighting, ultra-detailed fabric texture, 8k resolution, raw photo',
					arSelect.value
				].filter(Boolean);

				promptOutput.value = components.join(', ');
			}

			[
				modelInput, styleSelect, topSelect, bottomSelect,
				fabricSelect, accessorySelect, poseSelect, arSelect
			].forEach(el => {
				el?.addEventListener('input', buildPrompt);
				el?.addEventListener('change', buildPrompt);
			});

			buildPrompt();

			btnCopy?.addEventListener('click', () => {
				if (!promptOutput.value) return;
				navigator.clipboard.writeText(promptOutput.value).then(() => {
					toast.classList.add('show');
					setTimeout(() => toast.classList.remove('show'), 2000);
				});
			});
		</script>
	</body>
</html>
