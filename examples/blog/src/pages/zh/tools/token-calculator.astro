---
import BaseHead from 'src/components/BaseHead.astro';
import Header from 'src/components/Header.astro';
import Footer from 'src/components/Footer.astro';
import { SITE_TITLE } from 'src/consts';

const pageTitle = `Token 与上下文限制计算器 — ${SITE_TITLE}`;
const pageDescription = "精准估算中英文 Token 消耗，实时对比 ChatGPT、Claude 3.5、DeepSeek 与 Gemini 1.5 的上下文窗口比例。";
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={pageTitle} description={pageDescription} />
		<style>
			main {
				width: 850px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 3em 1em 5em;
			}
			.tool-header {
				text-align: center;
				margin-bottom: 2em;
			}
			.tool-header h1 {
				font-size: 2.2rem;
				font-weight: 800;
				margin-bottom: 0.3em;
				background: var(--hero-title-gradient);
				-webkit-background-clip: text;
				-webkit-text-fill-color: transparent;
			}
			.tool-header p {
				color: var(--text-muted);
				font-size: 1.05rem;
			}
			.tool-box {
				background: var(--bg-card);
				backdrop-filter: blur(12px);
				border: 1px solid var(--card-border);
				border-radius: 16px;
				padding: 2em;
				box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
			}
			.form-group {
				margin-bottom: 1.5em;
			}
			label {
				display: block;
				font-weight: 600;
				margin-bottom: 0.5em;
				color: var(--text-main);
			}
			textarea {
				width: 100%;
				padding: 1em;
				background: var(--search-bg);
				border: 1px solid var(--card-border);
				border-radius: 10px;
				color: var(--text-main);
				font-size: 0.95rem;
				box-sizing: border-box;
				outline: none;
				resize: vertical;
				line-height: 1.5;
				transition: border-color 0.2s, box-shadow 0.2s;
			}
			textarea:focus {
				border-color: var(--accent);
				box-shadow: 0 0 10px var(--accent-glow);
			}
			.stats-grid {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
				gap: 1rem;
				margin-top: 1.5em;
				margin-bottom: 2em;
			}
			.stat-card {
				background: var(--gray-light);
				border: 1px solid var(--card-border);
				border-radius: 12px;
				padding: 1.2rem;
				text-align: center;
			}
			.stat-value {
				font-size: 1.8rem;
				font-weight: 800;
				color: var(--cyan);
				margin-bottom: 0.2rem;
			}
			.stat-label {
				font-size: 0.82rem;
				color: var(--text-muted);
				text-transform: uppercase;
				letter-spacing: 0.5px;
				font-weight: 600;
			}
			.model-comparison {
				margin-top: 2em;
				border-top: 1px solid var(--card-border);
				padding-top: 1.5em;
			}
			.model-comparison h3 {
				font-size: 1.1rem;
				font-weight: 700;
				margin-bottom: 1em;
				color: var(--text-main);
			}
			.model-row {
				display: flex;
				justify-content: space-between;
				align-items: center;
				padding: 0.8em 0;
				border-bottom: 1px solid var(--card-border);
			}
			.model-name {
				font-weight: 600;
				font-size: 0.95rem;
				color: var(--text-main);
			}
			.progress-bar-bg {
				flex: 1;
				height: 8px;
				background: var(--gray-light);
				border: 1px solid var(--card-border);
				border-radius: 4px;
				margin: 0 1.5rem;
				overflow: hidden;
			}
			.progress-bar-fill {
				height: 100%;
				background: var(--accent);
				border-radius: 4px;
				width: 0%;
				transition: width 0.3s ease;
			}
			.model-limit {
				font-size: 0.85rem;
				color: var(--text-muted);
				min-width: 80px;
				text-align: right;
				font-weight: 600;
			}
		</style>
	</head>
	<body>
		<Header lang="zh" />
		<main>
			<div class="tool-header">
				<h1>📊 Token 与上下文限制计算器</h1>
				<p>实时估算提示词 Token 数量、字符数，并预判各大语言模型的上下文容量占用比例。</p>
			</div>

			<div class="tool-box">
				<div class="form-group">
					<label for="inputText">在下方粘贴或输入文本 / 提示词：</label>
					<textarea id="inputText" rows="8" placeholder="在此粘贴你的文章、代码或 Prompt，系统将即时计算 Token 消耗..."></textarea>
				</div>

				<div class="stats-grid">
					<div class="stat-card">
						<div class="stat-value" id="tokenCount">0</div>
						<div class="stat-label">预估 Token 数量</div>
					</div>
					<div class="stat-card">
						<div class="stat-value" id="charCount">0</div>
						<div class="stat-label">总字符数</div>
					</div>
					<div class="stat-card">
						<div class="stat-value" id="wordCount">0</div>
						<div class="stat-label">总词数</div>
					</div>
				</div>

				<div class="model-comparison">
					<h3>主流大模型上下文窗口（Context Window）占用率</h3>
					
					<div class="model-row">
						<span class="model-name">GPT-4o (128k)</span>
						<div class="progress-bar-bg"><div class="progress-bar-fill" id="bar-gpt4o"></div></div>
						<span class="model-limit" id="text-gpt4o">0%</span>
					</div>

					<div class="model-row">
						<span class="model-name">Claude 3.5 Sonnet (200k)</span>
						<div class="progress-bar-bg"><div class="progress-bar-fill" id="bar-claude"></div></div>
						<span class="model-limit" id="text-claude">0%</span>
					</div>

					<div class="model-row">
						<span class="model-name">DeepSeek V3 / R1 (64k)</span>
						<div class="progress-bar-bg"><div class="progress-bar-fill" id="bar-deepseek"></div></div>
						<span class="model-limit" id="text-deepseek">0%</span>
					</div>

					<div class="model-row">
						<span class="model-name">Gemini 1.5 Pro (200万)</span>
						<div class="progress-bar-bg"><div class="progress-bar-fill" id="bar-gemini"></div></div>
						<span class="model-limit" id="text-gemini">0%</span>
					</div>
				</div>
			</div>
		</main>
		<Footer lang="zh" />

		<script>
			const inputText = document.getElementById('inputText') as HTMLTextAreaElement;
			const tokenCountEl = document.getElementById('tokenCount') as HTMLDivElement;
			const charCountEl = document.getElementById('charCount') as HTMLDivElement;
			const wordCountEl = document.getElementById('wordCount') as HTMLDivElement;

			const models = {
				gpt4o: { limit: 128000, bar: document.getElementById('bar-gpt4o'), text: document.getElementById('text-gpt4o') },
				claude: { limit: 200000, bar: document.getElementById('bar-claude'), text: document.getElementById('text-claude') },
				deepseek: { limit: 64000, bar: document.getElementById('bar-deepseek'), text: document.getElementById('text-deepseek') },
				gemini: { limit: 2000000, bar: document.getElementById('bar-gemini'), text: document.getElementById('text-gemini') }
			};

			inputText?.addEventListener('input', () => {
				const text = inputText.value;
				const charCount = text.length;
				
				// 计算单词数
				const words = text.trim() ? text.trim().split(/\s+/).length : 0;
				
				// 启发式混合 Token 估计（英文 1 token ≈ 4 字符，中文 1 token ≈ 1.5 字符）
				let tokens = 0;
				for (let i = 0; i < text.length; i++) {
					const code = text.charCodeAt(i);
					if (code > 255) {
						tokens += 0.65; // CJK 中日韩字符
					} else {
						tokens += 0.25; // 英文字符/数字/标点
					}
				}
				const finalTokens = Math.ceil(tokens);

				tokenCountEl.textContent = finalTokens.toLocaleString();
				charCountEl.textContent = charCount.toLocaleString();
				wordCountEl.textContent = words.toLocaleString();

				// 更新大模型上下文占比进度条
				Object.values(models).forEach(m => {
					if (m.bar && m.text) {
						const percentage = Math.min(((finalTokens / m.limit) * 100), 100);
						m.bar.style.width = `${percentage}%`;
						m.text.textContent = percentage < 0.01 && finalTokens > 0 ? '<0.01%' : `${percentage.toFixed(2)}%`;
					}
				});
			});
		</script>
	</body>
</html>
