---
import BaseHead from 'src/components/BaseHead.astro';
import Header from 'src/components/Header.astro';
import Footer from 'src/components/Footer.astro';
import { SITE_TITLE } from 'src/consts';

export const frontmatter = {
    title: "JSON 转 TypeScript 类型定义工具",
    description: "100% 本地浏览器运行，一键将复杂的 JSON 数据自动解析并递归转换为 TypeScript interface 或 type 定义。",
    icon: "💻",
    tag: "效率工具",
    keywords: "json typescript interface 类型定义 转换器 开发者工具",
    pinned: false,
    priority: 93
};

const pageTitle = `JSON 转 TypeScript 类型定义工具 — ${SITE_TITLE}`;
const pageDescription = "100% 本地浏览器运行，一键将复杂的 JSON 数据自动解析并递归转换为 TypeScript interface 或 type 定义。";
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={pageTitle} description={pageDescription} />
		<style>
			main {
				width: 1000px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 2.5em 1em 4em;
			}
			.tool-header {
				text-align: center;
				margin-bottom: 2em;
			}
			.tool-header h1 {
				font-size: 2.5rem;
				font-weight: 800;
				margin-bottom: 0.3em;
				background: var(--hero-title-gradient);
				-webkit-background-clip: text;
				-webkit-text-fill-color: transparent;
			}
			.tool-header p {
				color: var(--text-muted);
				font-size: 0.95rem;
			}

			.status-bar {
				background: var(--bg-card);
				border: 1px solid var(--card-border);
				border-radius: 12px;
				padding: 0.8rem 1.2rem;
				margin-bottom: 1.2rem;
				display: flex;
				justify-content: space-between;
				align-items: center;
				font-size: 0.88rem;
			}
			.status-success { color: #10b981; font-weight: 600; }
			.status-error { color: #ef4444; font-weight: 600; }

			.editor-grid {
				display: grid;
				grid-template-columns: 1fr 1fr;
				gap: 1.2rem;
				margin-bottom: 1.5rem;
			}
			@media (max-width: 768px) {
				.editor-grid {
					grid-template-columns: 1fr;
				}
			}

			.editor-box {
				display: flex;
				flex-direction: column;
				gap: 0.6rem;
			}
			.editor-top {
				display: flex;
				justify-content: space-between;
				align-items: center;
			}
			.editor-title {
				font-size: 0.9rem;
				font-weight: 700;
				color: var(--text-main);
			}
			.btn-text {
				background: none;
				border: none;
				color: var(--accent);
				font-size: 0.82rem;
				cursor: pointer;
				font-weight: 600;
			}
			.btn-text:hover {
				text-decoration: underline;
			}

			textarea {
				width: 100%;
				height: 400px;
				padding: 1rem;
				background: var(--bg-card);
				border: 1px solid var(--card-border);
				border-radius: 12px;
				color: var(--text-main);
				font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
				font-size: 0.88rem;
				line-height: 1.6;
				resize: vertical;
				outline: none;
				box-sizing: border-box;
				transition: border-color 0.2s ease;
			}
			textarea:focus {
				border-color: var(--accent);
			}

			.action-bar {
				display: flex;
				justify-content: space-between;
				align-items: center;
				gap: 1rem;
				flex-wrap: wrap;
			}
			.btn-group {
				display: flex;
				gap: 0.8rem;
			}
			.btn {
				padding: 0.6em 1.2em;
				border-radius: 8px;
				font-size: 0.88rem;
				font-weight: 600;
				cursor: pointer;
				border: 1px solid var(--card-border);
				transition: all 0.2s ease;
			}
			.btn-primary {
				background: var(--accent);
				color: #ffffff;
				border-color: var(--accent);
			}
			.btn-primary:hover {
				opacity: 0.9;
				transform: translateY(-1px);
			}
			.btn-secondary {
				background: var(--gray-light);
				color: var(--text-main);
			}
			.btn-secondary:hover {
				border-color: var(--accent);
			}

			.toast {
				position: fixed;
				bottom: 2rem;
				right: 2rem;
				background: var(--accent);
				color: #fff;
				padding: 0.6em 1.2em;
				border-radius: 8px;
				font-size: 0.88rem;
				font-weight: 600;
				box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
				opacity: 0;
				transform: translateY(10px);
				transition: all 0.3s ease;
				pointer-events: none;
				z-index: 100;
			}
			.toast.show {
				opacity: 1;
				transform: translateY(0);
			}
		</style>
	</head>
	<body>
		<Header lang="zh" />
		<main>
			<div class="tool-header">
				<h1>💻 JSON 转 TypeScript 接口定义工具</h1>
				<p>100% 本地浏览器运行，一键将任意 JSON 数据递归转换为结构化的 TypeScript interface。</p>
			</div>

			<div class="status-bar">
				<span id="statusText" class="status-success">✓ 准备就绪 (输入或粘贴 JSON 自动生成)</span>
				<span style="color: var(--text-muted); font-size: 0.82rem;">Mode: JSON ➔ TypeScript Interface</span>
			</div>

			<div class="editor-grid">
				<div class="editor-box">
					<div class="editor-top">
						<span class="editor-title">JSON 输入</span>
						<button id="btnClear" class="btn-text">清空</button>
					</div>
					<textarea id="jsonInput" placeholder='在此粘贴你的 JSON 数据... e.g. {"id": 1, "name": "HelpMini", "active": true}'></textarea>
				</div>

				<div class="editor-box">
					<div class="editor-top">
						<span class="editor-title">TypeScript 接口输出</span>
						<button id="btnCopy" class="btn-text">📋 复制结果</button>
					</div>
					<textarea id="tsOutput" placeholder="转换后的 TypeScript 接口将在此处实时显示..." readonly></textarea>
				</div>
			</div>

			<div class="action-bar">
				<div class="btn-group">
					<button id="btnSample" class="btn btn-secondary">加载测试示例</button>
				</div>
			</div>
		</main>

		<div id="toast" class="toast">代码已复制到剪贴板！</div>

		<Footer lang="zh" />

		<script is:inline>
			const jsonInput = document.getElementById('jsonInput');
			const tsOutput = document.getElementById('tsOutput');
			const statusText = document.getElementById('statusText');
			const btnClear = document.getElementById('btnClear');
			const btnCopy = document.getElementById('btnCopy');
			const btnSample = document.getElementById('btnSample');
			const toast = document.getElementById('toast');

			function capitalize(str) {
				return str.charAt(0).toUpperCase() + str.slice(1);
			}

			function inferType(val, keyName = 'Item', interfaces = []) {
				if (val === null) return 'null';
				const type = typeof val;

				if (type === 'string') return 'string';
				if (type === 'number') return 'number';
				if (type === 'boolean') return 'boolean';

				if (Array.isArray(val)) {
					if (val.length === 0) return 'any[]';
					const subType = inferType(val[0], keyName, interfaces);
					return `${subType}[]`;
				}

				if (type === 'object') {
					const interfaceName = capitalize(keyName) + 'Interface';
					const fields = [];
					for (const k of Object.keys(val)) {
						const subTypeName = inferType(val[k], k, interfaces);
						fields.push(`  ${k}: ${subTypeName};`);
					}
					interfaces.push(`interface ${interfaceName} {\n${fields.join('\n')}\n}`);
					return interfaceName;
				}

				return 'any';
			}

			function convertJSONToTS() {
				const val = jsonInput.value.trim();
				if (!val) {
					tsOutput.value = '';
					statusText.className = 'status-success';
					statusText.textContent = '✓ 准备就绪';
					return;
				}

				try {
					const jsonObj = JSON.parse(val);
					const interfaces = [];
					const rootType = inferType(jsonObj, 'RootObject', interfaces);

					// 去重并反转顺序以符合从属关系
					const uniqueInterfaces = [...new Set(interfaces)].reverse();
					
					let finalResult = uniqueInterfaces.join('\n\n');
					if (finalResult) {
						finalResult += '\n\n';
					}
					finalResult += `type RootObject = ${rootType};`;

					tsOutput.value = finalResult;
					statusText.className = 'status-success';
					statusText.textContent = '✓ JSON 解析与 TypeScript 接口生成成功';
				} catch (err) {
					tsOutput.value = '';
					statusText.className = 'status-error';
					statusText.textContent = `❌ JSON 语法错误: ${err.message}`;
				}
			}

			jsonInput?.addEventListener('input', convertJSONToTS);

			btnClear?.addEventListener('click', () => {
				jsonInput.value = '';
				convertJSONToTS();
			});

			btnCopy?.addEventListener('click', () => {
				if (!tsOutput.value) return;
				navigator.clipboard.writeText(tsOutput.value).then(() => {
					toast.classList.add('show');
					setTimeout(() => toast.classList.remove('show'), 2000);
				});
			});

			btnSample?.addEventListener('click', () => {
				jsonInput.value = JSON.stringify({
					id: 101,
					title: "HelpMini Developer Hub",
					published: true,
					tags: ["AI", "Astro", "TypeScript"],
					author: {
						name: "Alex",
						role: "Founder"
					},
					metrics: [
						{ views: 1200, clicks: 350 }
					]
				}, null, 2);
				convertJSONToTS();
			});
		</script>
	</body>
</html>
