---
import BaseHead from 'src/components/BaseHead.astro';
import Header from 'src/components/Header.astro';
import Footer from 'src/components/Footer.astro';
import { SITE_TITLE } from 'src/consts';

const pageTitle = `Base64 & URL 编码解码工具 — ${SITE_TITLE}`;
const pageDescription = "100% 本地计算、安全不上传。支持 UTF-8 中文 Base64 编解码与 URL 网址参数转义。";

title: "Base64 & URL 编码解码工具"
description: "100% 本地计算、安全不上传。支持 UTF-8 中文 Base64 编解码与 URL 网址参数转义。"
icon: "🔤"
tag: "效率工具"
keywords: "base64 url 编码 解码 编解码 utf-8 中文"
lang: "zh"
pinned: false
priority: 85
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={pageTitle} description={pageDescription} />
		<style>
			main {
				width: 850px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 3em 1em 5em;
			}
			.tool-header {
				text-align: center;
				margin-bottom: 2em;
			}
			.tool-header h1 {
				font-size: 2.2rem;
				font-weight: 800;
				margin-bottom: 0.3em;
				background: var(--hero-title-gradient);
				-webkit-background-clip: text;
				-webkit-text-fill-color: transparent;
			}
			.tool-header p {
				color: var(--text-muted);
				font-size: 1.05rem;
			}
			.tool-box {
				background: var(--bg-card);
				backdrop-filter: blur(12px);
				border: 1px solid var(--card-border);
				border-radius: 16px;
				padding: 2em;
				box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
			}
			.tab-group {
				display: flex;
				gap: 0.8rem;
				margin-bottom: 1.5em;
				border-bottom: 1px solid var(--card-border);
				padding-bottom: 0.8em;
			}
			.tab-btn {
				background: none;
				border: 1px solid transparent;
				color: var(--text-muted);
				font-size: 1rem;
				font-weight: 600;
				cursor: pointer;
				padding: 0.4em 0.9em;
				border-radius: 8px;
				transition: all 0.2s ease;
			}
			.tab-btn:hover {
				color: var(--text-main);
			}
			.tab-btn.active {
				background: var(--badge-bg);
				color: var(--accent);
				border-color: var(--badge-border);
			}
			.btn-group {
				display: flex;
				gap: 0.8rem;
				margin: 1.2rem 0;
				flex-wrap: wrap;
			}
			.btn {
				background: var(--accent);
				color: #ffffff !important;
				border: none;
				padding: 0.6em 1.2em;
				border-radius: 8px;
				font-weight: 600;
				cursor: pointer;
				transition: background 0.2s;
			}
			.btn:hover { background: var(--accent-hover); }
			.btn-secondary { 
				background: var(--gray-light); 
				border: 1px solid var(--card-border);
				color: var(--text-main);
			}
			.btn-secondary:hover { 
				border-color: var(--accent);
				color: var(--accent);
			}
			textarea {
				width: 100%;
				height: 160px;
				padding: 1em;
				background: var(--code-bg) !important;
				border: 1px solid var(--card-border);
				border-radius: 10px;
				color: var(--text-main);
				font-size: 0.95rem;
				font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
				box-sizing: border-box;
				outline: none;
				resize: vertical;
				line-height: 1.5;
				transition: border-color 0.2s, box-shadow 0.2s;
			}
			textarea:focus { 
				border-color: var(--accent); 
				box-shadow: 0 0 10px var(--accent-glow);
			}
			label { 
				display: block; 
				font-weight: 600; 
				margin-bottom: 0.5em; 
				color: var(--text-main);
			}
		</style>
	</head>
	<body>
		<Header lang="zh" />
		<main>
			<div class="tool-header">
				<h1>🔤 Base64 & URL 编码解码工具</h1>
				<p>100% 浏览器本地处理，安全不上传。支持 UTF-8 中文完美兼容。</p>
			</div>

			<div class="tool-box">
				<div class="tab-group">
					<button class="tab-btn active" id="modeBase64">Base64 模式</button>
					<button class="tab-btn" id="modeURL">URL 网址模式</button>
				</div>

				<div>
					<label for="inputText">输入需要转换的文本 / 字符串：</label>
					<textarea id="inputText" placeholder="在此粘贴或输入需要处理的内容..."></textarea>
				</div>

				<div class="btn-group">
					<button class="btn" id="btnEncode">编码 (Encode)</button>
					<button class="btn" id="btnDecode">解码 (Decode)</button>
					<button class="btn btn-secondary" id="btnClear">清空</button>
					<button class="btn btn-secondary" id="btnCopy" style="margin-left: auto;">复制结果</button>
				</div>

				<div>
					<label for="outputText">转换结果：</label>
					<textarea id="outputText" readonly placeholder="转换后的结果将在此显示..."></textarea>
				</div>
			</div>
		</main>
		<Footer lang="zh" />

		<script>
			let currentMode = 'base64';
			const modeBase64 = document.getElementById('modeBase64');
			const modeURL = document.getElementById('modeURL');
			const inputText = document.getElementById('inputText') as HTMLTextAreaElement;
			const outputText = document.getElementById('outputText') as HTMLTextAreaElement;

			modeBase64?.addEventListener('click', () => {
				currentMode = 'base64';
				modeBase64.classList.add('active');
				modeURL?.classList.remove('active');
			});

			modeURL?.addEventListener('click', () => {
				currentMode = 'url';
				modeURL.classList.add('active');
				modeBase64?.classList.remove('active');
			});

			document.getElementById('btnEncode')?.addEventListener('click', () => {
				const val = inputText.value;
				try {
					if (currentMode === 'base64') {
						// 支持 UTF-8 中文编码
						outputText.value = btoa(encodeURIComponent(val).replace(/%([0-9A-F]{2})/g, (match, p1) => String.fromCharCode(parseInt(p1, 16))));
					} else {
						outputText.value = encodeURIComponent(val);
					}
				} catch (e: any) {
					outputText.value = '编码失败: ' + e.message;
				}
			});

			document.getElementById('btnDecode')?.addEventListener('click', () => {
				const val = inputText.value;
				try {
					if (currentMode === 'base64') {
						outputText.value = decodeURIComponent(Array.prototype.map.call(atob(val.trim()), (c) => '%' + ('00' + c.charCodeAt(0).toString(16)).slice(-2)).join(''));
					} else {
						outputText.value = decodeURIComponent(val);
					}
				} catch (e: any) {
					outputText.value = '解码失败: 请检查输入内容格式是否正确。';
				}
			});

			document.getElementById('btnClear')?.addEventListener('click', () => {
				inputText.value = '';
				outputText.value = '';
			});

			document.getElementById('btnCopy')?.addEventListener('click', (e) => {
				if (!outputText.value) return;
				navigator.clipboard.writeText(outputText.value);
				const btn = e.target as HTMLButtonElement;
				btn.textContent = '已复制！';
				setTimeout(() => { btn.textContent = '复制结果'; }, 2000);
			});
		</script>
	</body>
</html>
