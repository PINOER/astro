---
import BaseHead from 'src/components/BaseHead.astro';
import Header from 'src/components/Header.astro';
import Footer from 'src/components/Footer.astro';
import { SITE_TITLE } from 'src/consts';

export const frontmatter = {
    title: "AI 电商产品多场景渲染提示词生成器",
    description: "随手拍产品图一键融入高质感商业场景！组合台面材质、环境氛围、光影阴影与衬托道具，生成适用于 Midjourney、Flux 与 ControlNet 的电商产品大片 Prompt。",
    icon: "🛍️",
    tag: "电商 AI",
    keywords: "电商产品图提示词 产品场景渲染 midjourney flux 图生图 商拍提示词 controlnet",
    pinned: true,
    priority: 96
};

const pageTitle = `AI 电商产品多场景渲染提示词生成器 — ${SITE_TITLE}`;
const pageDescription = "随手拍产品图一键融入高质感商业场景！组合台面材质、环境氛围、光影阴影与衬托道具，生成适用于 Midjourney、Flux 与 ControlNet 的电商产品大片 Prompt。";
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={pageTitle} description={pageDescription} />
		<style>
			main {
				width: 1000px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 2.5em 1em 4em;
			}
			.tool-header {
				text-align: center;
				margin-bottom: 2em;
			}
			.tool-header h1 {
				font-size: 2.5rem;
				font-weight: 800;
				margin-bottom: 0.3em;
				background: var(--hero-title-gradient);
				-webkit-background-clip: text;
				-webkit-text-fill-color: transparent;
			}
			.tool-header p {
				color: var(--text-muted);
				font-size: 0.95rem;
			}

			.form-grid {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
				gap: 1.2rem;
				background: var(--bg-card);
				border: 1px solid var(--card-border);
				border-radius: 16px;
				padding: 1.8rem;
				backdrop-filter: blur(12px);
				box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
				margin-bottom: 2rem;
			}
			.form-group {
				display: flex;
				flex-direction: column;
				gap: 0.5rem;
			}
			.form-group.full-width {
				grid-column: 1 / -1;
			}
			label {
				font-size: 0.88rem;
				font-weight: 700;
				color: var(--text-main);
				display: flex;
				justify-content: space-between;
				align-items: center;
			}
			label .sub-tag {
				font-size: 0.75rem;
				color: var(--text-muted);
				font-weight: normal;
			}

			input[type="text"], select, textarea {
				width: 100%;
				padding: 0.75em 1em;
				background: var(--search-bg);
				border: 1px solid var(--card-border);
				border-radius: 8px;
				color: var(--text-main);
				font-size: 0.92rem;
				box-sizing: border-box;
				outline: none;
				transition: border-color 0.2s, box-shadow 0.2s;
			}
			input[type="text"]:focus, select:focus, textarea:focus {
				border-color: var(--accent);
				box-shadow: 0 0 10px var(--accent-glow);
			}

			.output-card {
				background: var(--bg-card);
				border: 1px solid var(--card-border);
				border-radius: 16px;
				padding: 1.5rem;
				box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
			}
			.output-header {
				display: flex;
				justify-content: space-between;
				align-items: center;
				margin-bottom: 1rem;
			}
			.output-title {
				font-size: 1.05rem;
				font-weight: 700;
				color: var(--text-main);
			}
			.btn-copy {
				background: var(--accent);
				color: #ffffff;
				border: none;
				padding: 0.6em 1.2em;
				border-radius: 8px;
				font-size: 0.88rem;
				font-weight: 700;
				cursor: pointer;
				transition: all 0.2s ease;
			}
			.btn-copy:hover {
				background: var(--accent-hover);
				transform: translateY(-1px);
			}
			.prompt-output {
				width: 100%;
				height: 140px;
				background: var(--code-bg) !important;
				border: 1px solid var(--card-border);
				border-radius: 10px;
				padding: 1rem;
				color: var(--text-main);
				font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
				font-size: 0.9rem;
				line-height: 1.6;
				resize: vertical;
				box-sizing: border-box;
				outline: none;
			}

			.toast {
				position: fixed;
				bottom: 2rem;
				right: 2rem;
				background: var(--accent);
				color: #fff;
				padding: 0.6em 1.2em;
				border-radius: 8px;
				font-size: 0.88rem;
				font-weight: 600;
				box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
				opacity: 0;
				transform: translateY(10px);
				transition: all 0.3s ease;
				pointer-events: none;
				z-index: 100;
			}
			.toast.show {
				opacity: 1;
				transform: translateY(0);
			}
		</style>
	</head>
	<body>
		<Header lang="zh" />
		<main>
			<div class="tool-header">
				<h1>🛍️ AI 电商产品多场景渲染提示词生成器</h1>
				<p>组合台面材质、光影氛围与衬托道具，将随手拍的产品原图瞬间生成为符合 Midjourney / Flux / ControlNet 规范的商业级场景大片。</p>
			</div>

			<div class="form-grid">
				<!-- 产品主体描述 -->
				<div class="form-group full-width">
					<label for="productInput">
						产品主体描述 (Product Subject)
						<span class="sub-tag">简述你的产品类型与特征（例如：白色极简保温杯、金色玻璃瓶香水）</span>
					</label>
					<input type="text" id="productInput" placeholder="例如：A sleek minimalist white thermos bottle (一款极简白色保温杯)" />
				</div>

				<!-- 放置台面材质 -->
				<div class="form-group">
					<label for="surfaceSelect">放置台面/基底 (Surface / Podium)</label>
					<select id="surfaceSelect">
						<option value="placed on a luxury white marble countertop">奢华白色大理石台面 (White Marble)</option>
						<option value="placed on a sunlit rustic wooden tabletop">阳光照射下的复古原木桌面 (Rustic Wood)</option>
						<option value="placed on a smooth wet stone surface with subtle reflections">微湿浅水石块台面 (Wet Stone Surface)</option>
						<option value="placed on a minimalist pastel-colored cylindrical podium">极简莫兰迪色圆柱展示台 (Podium)</option>
						<option value="placed on a textured beige linen fabric table">温暖米色亚麻布面 (Linen Fabric)</option>
						<option value="placed on a clean reflective mirror glass surface">高透反光镜面台面 (Mirror Glass)</option>
					</select>
				</div>

				<!-- 使用场景氛围 -->
				<div class="form-group">
					<label for="sceneSelect">使用场景与背景氛围 (Environment)</label>
					<select id="sceneSelect">
						<option value="in a cozy Scandinavian minimalist living room background">北欧极简温馨客厅背景 (Scandinavian Living Room)</option>
						<option value="in a sunlit modern kitchen counter environment">阳光充沛的现代厨房背景 (Modern Kitchen)</option>
						<option value="in a luxury spa bathroom vanity setting">高档 Spa 浴室洗手台背景 (Luxury Bathroom)</option>
						<option value="in a lush green tropical forest with soft morning mist">晨雾缭绕的热带绿植森林背景 (Tropical Nature)</option>
						<option value="in a professional clean commercial photo studio background">干净无瑕的商业摄影棚纯色背景 (Studio Setup)</option>
						<option value="in a vibrant outdoor camping scene under golden sunlight">户外露营与自然光背景 (Outdoor Camping)</option>
					</select>
				</div>

				<!-- 衬托道具与细节 -->
				<div class="form-group">
					<label for="propSelect">衬托道具与环境元素 (Props & Elements)</label>
					<select id="propSelect">
						<option value="surrounded by fresh monstera leaves and subtle water splashes">绿植龟背竹叶与清爽飞溅水花</option>
						<option value="surrounded by scattered coffee beans and cinnamon sticks">散落的咖啡豆与香草干花道具</option>
						<option value="with fresh lemon slices and mint leaves in blurry background">鲜切柠檬片与薄荷叶衬托 (清新饮品感)</option>
						<option value="accented with soft natural cotton flowers and dried wheat">柔和棉花与干小麦道具 (自然温润感)</option>
						<option value="with elegant cosmetics brushes and silk ribbons nearby">精致化妆刷与丝带衬托 (护肤美妆感)</option>
						<option value="">无额外道具 (保持极简洁净)</option>
					</select>
				</div>

				<!-- 光影与物理阴影 -->
				<div class="form-group">
					<label for="lightingSelect">光影打光与阴影融合 (Lighting & Shadow)</label>
					<select id="lightingSelect">
						<option value="morning sunlight filtering through window blinds creating dynamic dappled shadow cast">百叶窗过滤的早晨阳光与斑驳阴影 (最具生活真实感)</option>
						<option value="soft diffuse studio softbox light with realistic contact shadow">柔光箱摄影棚均匀光线 + 真实接触阴影</option>
						<option value="golden hour warm sunset backlighting with subtle lens flare">逆光暖阳夕阳余晖 + 柔和眩光</option>
						<option value="dramatic side lighting with strong contrast shadow">戏剧性侧向高对比度硬光阴影</option>
					</select>
				</div>

				<!-- 构图与画幅 -->
				<div class="form-group">
					<label for="arSelect">画幅比例 (--ar)</label>
					<select id="arSelect">
						<option value="--ar 4:5">--ar 4:5 (电商主图/Instagram 纵向海报)</option>
						<option value="--ar 1:1">--ar 1:1 (正方形商品卡片)</option>
						<option value="--ar 3:4">--ar 3:4 (独立站商品详情页比例)</option>
						<option value="--ar 16:9">--ar 16:9 (横屏 Banner 广告海报)</option>
					</select>
				</div>
			</div>

			<!-- 实时生成预览 -->
			<div class="output-card">
				<div class="output-header">
					<span class="output-title">✨ 生成的英文商拍 Prompt (可直接粘贴至 Midjourney / Flux / SD)</span>
					<button class="btn-copy" id="btnCopy">📋 一键复制提示词</button>
				</div>
				<textarea id="promptOutput" class="prompt-output" readonly></textarea>
			</div>
		</main>

		<div id="toast" class="toast">商拍提示词已成功复制到剪贴板！</div>

		<Footer lang="zh" />

		<script is:inline>
			const productInput = document.getElementById('productInput');
			const surfaceSelect = document.getElementById('surfaceSelect');
			const sceneSelect = document.getElementById('sceneSelect');
			const propSelect = document.getElementById('propSelect');
			const lightingSelect = document.getElementById('lightingSelect');
			const arSelect = document.getElementById('arSelect');

			const promptOutput = document.getElementById('promptOutput');
			const btnCopy = document.getElementById('btnCopy');
			const toast = document.getElementById('toast');

			function buildPrompt() {
				const product = productInput.value.trim() || 'A sleek minimalist product';

				const components = [
					`Commercial product photography shot of ${product}`,
					surfaceSelect.value,
					sceneSelect.value,
					propSelect.value,
					lightingSelect.value,
					'realistic ground shadow, shallow depth of field, sharp focus on product, ultra-detailed, 8k resolution, raw photo',
					arSelect.value
				].filter(Boolean);

				promptOutput.value = components.join(', ');
			}

			[
				productInput, surfaceSelect, sceneSelect, propSelect,
				lightingSelect, arSelect
			].forEach(el => {
				el?.addEventListener('input', buildPrompt);
				el?.addEventListener('change', buildPrompt);
			});

			buildPrompt();

			btnCopy?.addEventListener('click', () => {
				if (!promptOutput.value) return;
				navigator.clipboard.writeText(promptOutput.value).then(() => {
					toast.classList.add('show');
					setTimeout(() => toast.classList.remove('show'), 2000);
				});
			});
		</script>
	</body>
</html>
