---
import BaseHead from 'src/components/BaseHead.astro';
import Header from 'src/components/Header.astro';
import Footer from 'src/components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from 'src/consts';
import { getCollection } from 'astro:content';
import { toolsData } from 'src/data/tools';

// 1. Fetch English blogs
const allPosts = await getCollection('blog');
const enPosts = allPosts.filter((post) => post.data?.lang === 'en' || post.id.startsWith('en/'));

// 2. Sponsor / Ad Items Configuration
const sponsorItems = [];

// 3. Searchable Dataset (Tools + Blogs + Sponsors)
const allSearchableItems = [
	...toolsData.map((tool) => ({
		title: tool.title.en,
		desc: tool.desc.en,
		url: tool.url.en,
		type: 'tool',
		icon: tool.icon,
		tag: tool.tag.en,
		keywords: `${tool.title.en} ${tool.keywords.en}`,
		pinned: (tool as any).pinned || false,
		priority: (tool as any).priority || 0
	})),
	...enPosts.map((post) => ({
		title: post.data.title,
		desc: post.data.description,
		url: `/blog/${post.id.replace(/\.(md|mdx)$/, '').replace(/\/index$/, '')}/`,
		type: 'blog',
		icon: '📚',
		tag: 'Guide',
		keywords: `${post.data.title} ${post.data.description}`,
		pinned: false,
		priority: 0
	})),
	...sponsorItems
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 1000px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 3em 1em 5em;
			}
			.hero {
				text-align: center;
				padding: 2em 0 2.5em;
				position: relative;
			}
			.badge {
				display: inline-block;
				background: var(--badge-bg);
				color: var(--badge-color);
				border: 1px solid var(--badge-border);
				padding: 0.4em 1.2em;
				border-radius: 20px;
				font-size: 0.85rem;
				font-weight: 600;
				margin-bottom: 1.5em;
				box-shadow: 0 0 15px rgba(99, 102, 241, 0.15);
				transition: all 0.3s ease;
			}
			.hero h1 {
				font-size: 3.5rem;
				font-weight: 800;
				margin-bottom: 0.4em;
				line-height: 1.2;
				letter-spacing: -1px;
				background: var(--hero-title-gradient);
				-webkit-background-clip: text;
				-webkit-text-fill-color: transparent;
			}
			.hero p {
				font-size: 0.95rem;
				color: var(--text-muted);
				max-width: 600px;
				margin: 0 auto 2em;
				line-height: 1.6;
			}

			/* 🔍 Central Search Engine Bar */
			.search-wrapper {
				max-width: 640px;
				margin: 0 auto 2.5em;
				position: relative;
			}
			.search-input-box {
				width: 100%;
				padding: 1.1em 1.5em 1.1em 3.2em;
				background: var(--search-bg);
				backdrop-filter: blur(16px);
				border: 1px solid var(--card-border);
				border-radius: 16px;
				color: var(--text-main);
				font-size: 1.05rem;
				outline: none;
				box-sizing: border-box;
				box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
				transition: all 0.3s ease;
			}
			.search-input-box:focus {
				border-color: var(--accent);
				box-shadow: 0 0 25px var(--accent-glow);
			}
			.search-icon {
				position: absolute;
				left: 1.2em;
				top: 50%;
				transform: translateY(-50%);
				font-size: 1.2rem;
				opacity: 0.6;
				pointer-events: none;
			}

			/* 📦 Header Row */
			.section-title-wrapper {
				display: flex;
				align-items: center;
				justify-content: space-between;
				margin-bottom: 1.2rem;
			}
			.section-title {
				font-size: 1.35rem;
				font-weight: 700;
				letter-spacing: -0.5px;
				color: var(--text-main);
				margin: 0;
			}
			.result-count-badge {
				font-size: 0.82rem;
				color: var(--text-muted);
				font-weight: 600;
				background: var(--gray-light);
				padding: 0.25em 0.7em;
				border-radius: 12px;
				border: 1px solid var(--card-border);
			}

			/* ⚡ Dual-Column Streamlined Grid */
			.tool-grid {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(420px, 1fr));
				gap: 0.9rem;
			}

			/* 🎯 Perfect Item Card Style based on search-result-item */
			.item-card {
				display: flex;
				align-items: center;
				gap: 1.1em;
				padding: 0.9em 1.2em;
				text-decoration: none;
				color: var(--text-main);
				background: var(--bg-card);
				backdrop-filter: blur(16px);
				-webkit-backdrop-filter: blur(16px);
				border: 1px solid var(--card-border);
				border-radius: 14px;
				transition: all 0.25s ease;
				position: relative;
				overflow: hidden;
				box-shadow: 0 2px 8px rgba(0, 0, 0, 0.03);
			}

			.item-card:hover {
				background: var(--dropdown-hover);
				border-color: var(--accent);
				transform: translateY(-2px);
				box-shadow: 0 8px 25px -5px var(--accent-glow);
			}

			.item-icon {
				font-size: 1.5rem;
				display: flex;
				align-items: center;
				justify-content: center;
				width: 38px;
				height: 38px;
				min-width: 38px;
				border-radius: 10px;
				background: var(--gray-light);
				border: 1px solid var(--card-border);
			}

			.item-info {
				flex: 1;
				overflow: hidden;
				display: flex;
				flex-direction: column;
				justify-content: center;
			}

			.item-title {
				font-weight: 700;
				font-size: 0.98rem;
				color: var(--text-main);
				margin-bottom: 0.2em;
				white-space: nowrap;
				overflow: hidden;
				text-overflow: ellipsis;
			}

			.item-desc {
				font-size: 0.82rem;
				color: var(--text-muted);
				white-space: nowrap;
				overflow: hidden;
				text-overflow: ellipsis;
				line-height: 1.4;
			}

			.item-badge {
				margin-left: auto;
				font-size: 0.7rem;
				padding: 0.2em 0.6em;
				border-radius: 6px;
				font-weight: 700;
				white-space: nowrap;
				flex-shrink: 0;
				text-transform: uppercase;
			}

			.type-tool { background: rgba(6, 182, 212, 0.15); color: var(--cyan); border: 1px solid rgba(6, 182, 212, 0.25); }
			.type-blog { background: rgba(99, 102, 241, 0.15); color: var(--accent); border: 1px solid rgba(99, 102, 241, 0.25); }
			.type-sponsor { background: rgba(245, 158, 11, 0.15); color: #f59e0b; border: 1px solid rgba(245, 158, 11, 0.3); }

			.pinned-tag {
				font-size: 0.75rem;
				margin-right: 0.2rem;
			}

			.no-results {
				text-align: center;
				padding: 3em 1em;
				color: var(--text-muted);
				grid-column: 1 / -1;
			}

			@media (max-width: 640px) {
				.tool-grid {
					grid-template-columns: 1fr;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<div class="badge">🚀 Micro AI Tools for Big Help</div>
				<h1>HelpMini</h1>

				<!-- 🔍 Search Bar -->
				<div class="search-wrapper">
					<span class="search-icon">🔍</span>
					<input
						type="text"
						id="searchInput"
						class="search-input-box"
						placeholder="Search micro-tools, guides, or keywords... (e.g., SEO, Token, Prompt)"
						autocomplete="off"
					/>
				</div>
			</section>

			<!-- 📦 Streamlined Content Section -->
			<section>
				<div class="section-title-wrapper">
					<h2 id="sectionTitle" class="section-title">Featured Micro Tools</h2>
					<span id="resultCount" class="result-count-badge"></span>
				</div>
				
				<div id="contentGrid" class="tool-grid"></div>
			</section>

			<section class="hero" style="padding-top: 4em;">
				<p>Lightweight, instant productivity tools that save you hours.</p>
			</section>
		</main>
		<Footer />

		<!-- Client-Side Search Engine Script -->
		<script is:inline define:vars={{ allSearchableItems }}>
			const searchInput = document.getElementById('searchInput');
			const sectionTitle = document.getElementById('sectionTitle');
			const resultCount = document.getElementById('resultCount');
			const contentGrid = document.getElementById('contentGrid');

			// Pin & Priority Sorting
			function sortItems(items) {
				return [...items].sort((a, b) => {
					if (a.pinned && !b.pinned) return -1;
					if (!a.pinned && b.pinned) return 1;
					return (b.priority || 0) - (a.priority || 0);
				});
			}

			// Render Items in Single-Row Streamlined Style
			function renderItems(items) {
				if (!contentGrid) return;

				if (items.length === 0) {
					contentGrid.innerHTML = `
						<div class="no-results">
							<div style="font-size: 2.2rem; margin-bottom: 0.5rem;">🔍</div>
							<p style="font-size: 1rem; font-weight: 600;">No matching tools or guides found</p>
							<p style="font-size: 0.85rem; opacity: 0.8;">Try searching for other keywords like "SEO", "JSON", or "Token"</p>
						</div>
					`;
					return;
				}

				contentGrid.innerHTML = items.map(item => {
					const isExternal = item.url.startsWith('http');
					const typeBadgeClass = item.type === 'sponsor' ? 'type-sponsor' : (item.type === 'blog' ? 'type-blog' : 'type-tool');
					const typeLabel = item.type === 'sponsor' ? 'Ad' : (item.type === 'blog' ? 'Blog' : 'Tool');

					return `
						<a href="${item.url}" class="item-card" ${isExternal ? 'target="_blank" rel="noopener"' : ''}>
							<span class="item-icon">${item.icon}</span>
							<div class="item-info">
								<div class="item-title">${item.pinned ? '<span class="pinned-tag">📌</span>' : ''}${item.title}</div>
								<div class="item-desc">${item.desc}</div>
							</div>
							<span class="item-badge ${typeBadgeClass}">${typeLabel}</span>
						</a>
					`;
				}).join('');
			}

			function initDefaultView() {
				const sorted = sortItems(allSearchableItems);
				const default20 = sorted.slice(0, 20); // Top 20 items by default
				
				if (sectionTitle) sectionTitle.textContent = 'Featured Micro Tools';
				if (resultCount) resultCount.textContent = `${default20.length} items`;
				
				renderItems(default20);
			}

			// Real-time Search Filter
			searchInput?.addEventListener('input', (e) => {
				const query = e.target.value.toLowerCase().trim();

				if (!query) {
					initDefaultView();
					return;
				}

				const filtered = allSearchableItems.filter(item =>
					item.title.toLowerCase().includes(query) ||
					item.desc.toLowerCase().includes(query) ||
					item.keywords.toLowerCase().includes(query)
				);

				const sortedResults = sortItems(filtered);

				if (sectionTitle) sectionTitle.textContent = 'Search Results';
				if (resultCount) resultCount.textContent = `${sortedResults.length} found`;

				renderItems(sortedResults);
			});

			initDefaultView();
		</script>
	</body>
</html>
