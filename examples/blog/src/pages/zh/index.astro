---
import BaseHead from 'src/components/BaseHead.astro';
import Header from 'src/components/Header.astro';
import Footer from 'src/components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from 'src/consts';
import { getCollection } from 'astro:content';

// 获取博客列表供搜索使用
const allPosts = await getCollection('blog');
const zhPosts = allPosts.filter((post) => post.data?.lang === 'zh' || post.id.startsWith('zh/'));

// 构建供前端搜索的静态 JSON 索引
const searchableItems = [
	// 1. 微工具索引
	{
		title: '提示词结构化优化工具',
		desc: '将粗糙的想法一键转化为结构清晰、高效的 ChatGPT 与 Claude 提示词。',
		url: '/zh/tools/prompt-refiner',
		type: 'tool',
		icon: '📝',
		keywords: 'prompt 提示词 costar costar框架 优化 催化剂 chatgpt claude'
	},
	{
		title: 'Token & 上下文限制计算器',
		desc: '精确计算大语言模型的 Token 数量，避免上下文超出截断问题。',
		url: '/zh/tools/token-calculator',
		type: 'tool',
		icon: '📊',
		keywords: 'token 计算器 上下文 限制 扣费 gpt4o claude deepseek gemini'
	},
	{
		title: 'SEO Meta 标题与描述生成器',
		desc: '生成符合 Google 规范且高点击率的 SEO Meta 标题与元描述。',
		url: '/zh/tools/seo-meta-generator',
		type: 'tool',
		icon: '🔍',
		keywords: 'seo meta 标题 元描述 描述生成器 google serp 点击率 ctr'
	},
	// 2. 博客文章索引
	...zhPosts.map((post) => ({
		title: post.data.title,
		desc: post.data.description,
		url: `/blog/${post.id.replace(/\.(md|mdx)$/, '').replace(/\/index$/, '')}/`,
		type: 'blog',
		icon: '📚',
		keywords: `${post.data.title} ${post.data.description}`
	}))
];
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={`帮你AI工具箱,轻量级 AI 辅助工具 - HelpMini`} description={SITE_DESCRIPTION} />
		<style>
			:root {
				--primary: #6366f1;
				--primary-hover: #4f46e5;
				--accent: #06b6d4;
				--bg-dark: #0f172a;
				--text-main: #f8fafc;
				--text-muted: #94a3b8;
				--card-bg: rgba(30, 41, 59, 0.7);
				--card-border: rgba(255, 255, 255, 0.1);
			}
			body {
				background-color: var(--bg-dark);
				color: var(--text-main);
			}
			main {
				width: 1000px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 3em 1em 5em;
			}
			.hero {
				text-align: center;
				padding: 2em 0 3em;
				position: relative;
			}
			.badge {
				display: inline-block;
				background: rgba(99, 102, 241, 0.15);
				color: #a5b4fc;
				border: 1px solid rgba(99, 102, 241, 0.3);
				padding: 0.4em 1.2em;
				border-radius: 20px;
				font-size: 0.85rem;
				font-weight: 600;
				margin-bottom: 1.5em;
				box-shadow: 0 0 15px rgba(99, 102, 241, 0.2);
			}
			.hero h1 {
				font-size: 3.5rem;
				font-weight: 800;
				margin-bottom: 0.4em;
				line-height: 1.2;
				letter-spacing: -1px;
				background: linear-gradient(135deg, #ffffff 0%, #a5b4fc 50%, #06b6d4 100%);
				-webkit-background-clip: text;
				-webkit-text-fill-color: transparent;
			}
			.hero p {
				font-size: 0.8rem;
				color: var(--text-muted);
				max-width: 600px;
				margin: 0 auto 2em;
				line-height: 1.6;
			}

			/* 🔍 核心搜索引擎式搜索框设计 */
			.search-wrapper {
				max-width: 640px;
				margin: 0 auto 3em;
				position: relative;
			}
			.search-input-box {
				width: 100%;
				padding: 1.1em 1.5em 1.1em 3.2em;
				background: rgba(15, 23, 42, 0.8);
				backdrop-filter: blur(16px);
				border: 1px solid rgba(99, 102, 241, 0.4);
				border-radius: 16px;
				color: #fff;
				font-size: 1.05rem;
				outline: none;
				box-sizing: border-box;
				box-shadow: 0 0 25px rgba(99, 102, 241, 0.15);
				transition: all 0.3s ease;
			}
			.search-input-box:focus {
				border-color: #06b6d4;
				box-shadow: 0 0 35px rgba(6, 182, 212, 0.25);
			}
			.search-icon {
				position: absolute;
				left: 1.2em;
				top: 50%;
				transform: translateY(-50%);
				font-size: 1.2rem;
				opacity: 0.6;
				pointer-events: none;
			}

			/* 搜索下拉结果浮层 */
			.search-results-dropdown {
				position: absolute;
				top: 105%;
				left: 0;
				right: 0;
				background: rgba(15, 23, 42, 0.95);
				backdrop-filter: blur(20px);
				border: 1px solid var(--card-border);
				border-radius: 14px;
				max-height: 380px;
				overflow-y: auto;
				z-index: 50;
				box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
				display: none;
				text-align: left;
			}
			.search-result-item {
				display: flex;
				align-items: center;
				gap: 1em;
				padding: 0.9em 1.2em;
				text-decoration: none;
				color: var(--text-main);
				border-bottom: 1px solid rgba(255, 255, 255, 0.05);
				transition: background 0.2s;
			}
			.search-result-item:hover {
				background: rgba(99, 102, 241, 0.2);
			}
			.result-item-title {
				font-weight: 600;
				font-size: 0.98rem;
			}
			.result-item-desc {
				font-size: 0.82rem;
				color: var(--text-muted);
				white-space: nowrap;
				overflow: hidden;
				text-overflow: ellipsis;
			}
			.result-type-badge {
				margin-left: auto;
				font-size: 0.7rem;
				padding: 0.2em 0.6em;
				border-radius: 6px;
				font-weight: 600;
			}
			.type-tool { background: rgba(6, 182, 212, 0.2); color: #38bdf8; }
			.type-blog { background: rgba(99, 102, 241, 0.2); color: #a5b4fc; }

			.tool-grid {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
				gap: 1.5rem;
				margin-top: 1.5rem;
			}
			.tool-card {
				background: var(--card-bg);
				backdrop-filter: blur(12px);
				border: 1px solid var(--card-border);
				border-radius: 16px;
				padding: 1.8rem;
				text-decoration: none;
				color: var(--text-main);
				display: flex;
				flex-direction: column;
				transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
				box-shadow: 0 4px 20px rgba(0, 0, 0, 0.2);
			}
			.tool-card:hover {
				transform: translateY(-6px);
				border-color: rgba(99, 102, 241, 0.6);
				box-shadow: 0 12px 30px -5px rgba(99, 102, 241, 0.3);
			}
			.tool-icon { font-size: 2.2rem; margin-bottom: 1rem; }
			.tool-card h3 { font-size: 1.25rem; font-weight: 700; margin-bottom: 0.6rem; }
			.tool-card p { font-size: 0.92rem; color: var(--text-muted); flex: 1; margin-bottom: 1.2rem; line-height: 1.6; }
			.tool-tag { font-size: 0.75rem; color: var(--accent); font-weight: 600; text-transform: uppercase; }
		</style>
	</head>
	<body>
		<Header lang="zh" />
		<main>
			<section class="hero">
				<div class="badge">🚀 帮你 AI 工具箱，为生产力提速</div>
				<h1>HelpMini</h1>

				<!-- 🔍 搜索引擎式中央搜索框 -->
				<div class="search-wrapper">
					<span class="search-icon">🔍</span>
					<input 
						type="text" 
						id="searchInput" 
						class="search-input-box" 
						placeholder="搜索您想要的工具或文档(教程)..." 
						autocomplete="off"
					/>
					<div id="searchDropdown" class="search-results-dropdown"></div>
				</div>
				<p>轻量、即时且强劲的 AI 辅助工具，为你的生产力效率提升数倍。</p>
			</section>

			<section>
				<h2 style="font-size: 1.5rem; font-weight: 700; letter-spacing: -0.5px;">精选微工具</h2>
				<div class="tool-grid">
					
					<a href="/zh/tools/prompt-refiner" class="tool-card">
						<div class="tool-icon">📝</div>
						<h3>提示词结构化优化工具</h3>
						<p>将粗糙的想法一键转化为结构清晰、高效的 ChatGPT 与 Claude 提示词。</p>
						<span class="tool-tag">免费工具 • 即时生成</span>
					</a>

					<a href="/zh/tools/token-calculator" class="tool-card">
						<div class="tool-icon">📊</div>
						<h3>Token & 上下文限制计算器</h3>
						<p>精确计算大语言模型的 Token 数量，避免上下文超出截断问题。</p>
						<span class="tool-tag">免费工具 • 即时生成</span>
					</a>

					<a href="/zh/tools/seo-meta-generator" class="tool-card">
						<div class="tool-icon">🔍</div>
						<h3>SEO Meta 标题与描述生成器</h3>
						<p>生成符合 Google 规范且高点击率的 SEO Meta 标题与元描述。</p>
						<span class="tool-tag">免费工具 • 即时生成</span>
					</a>

				</div>
			</section>
		</main>
		<Footer lang="zh" />

		<!-- 搜索实时逻辑 -->
		<script is:inline define:vars={{ searchableItems }}>
			const searchInput = document.getElementById('searchInput');
			const searchDropdown = document.getElementById('searchDropdown');

			searchInput?.addEventListener('input', (e) => {
				const query = e.target.value.toLowerCase().trim();

				if (!query) {
					searchDropdown.style.display = 'none';
					return;
				}

				// 模糊匹配关键词/标题/描述
				const filtered = searchableItems.filter(item => 
					item.title.toLowerCase().includes(query) ||
					item.desc.toLowerCase().includes(query) ||
					item.keywords.toLowerCase().includes(query)
				);

				if (filtered.length === 0) {
					searchDropdown.innerHTML = `<div style="padding: 1.2em; text-align: center; color: var(--text-muted); font-size: 0.9rem;">未找到相关工具或文章</div>`;
				} else {
					searchDropdown.innerHTML = filtered.map(item => `
						<a href="${item.url}" class="search-result-item">
							<span style="font-size: 1.4rem;">${item.icon}</span>
							<div style="flex: 1; overflow: hidden;">
								<div class="result-item-title">${item.title}</div>
								<div class="result-item-desc">${item.desc}</div>
							</div>
							<span class="result-type-badge ${item.type === 'tool' ? 'type-tool' : 'type-blog'}">
								${item.type === 'tool' ? '工具' : '博客'}
							</span>
						</a>
					`).join('');
				}

				searchDropdown.style.display = 'block';
			});

			// 点击外部自动隐藏下拉框
			document.addEventListener('click', (e) => {
				if (!searchInput?.contains(e.target) && !searchDropdown?.contains(e.target)) {
					searchDropdown.style.display = 'none';
				}
			});
		</script>
	</body>
</html>
