---
import BaseHead from 'src/components/BaseHead.astro';
import Header from 'src/components/Header.astro';
import Footer from 'src/components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from 'src/consts';
import { getCollection } from 'astro:content';
import { toolsData } from 'src/data/tools';

// 1. 获取英文博客
const allPosts = await getCollection('blog');
const enPosts = allPosts.filter((post) => post.data?.lang === 'en' || post.id.startsWith('en/'));

// 2. 赞助商/广告卡片配置
const sponsorItems = [];

// 3. 组装统一数据集 (Tools + Blogs + Sponsors)
const allSearchableItems = [
	...toolsData.map((tool) => ({
		title: tool.title.en,
		desc: tool.desc.en,
		url: tool.url.en,
		type: 'tool',
		icon: tool.icon,
		tag: tool.tag.en,
		keywords: `${tool.title.en} ${tool.keywords.en}`,
		pinned: (tool as any).pinned || false,
		priority: (tool as any).priority || 0
	})),
	...enPosts.map((post) => ({
		title: post.data.title,
		desc: post.data.description,
		url: `/blog/${post.id.replace(/\.(md|mdx)$/, '').replace(/\/index$/, '')}/`,
		type: 'blog',
		icon: '📚',
		tag: 'Guide',
		keywords: `${post.data.title} ${post.data.description}`,
		pinned: false,
		priority: 0
	})),
	...sponsorItems
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style style="is:global">
			/* 彻底清除原生链接丑陋的蓝色下划线 */
			a { text-decoration: none !important; }
		</style>
		<style>
			main {
				width: 1000px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 3em 1em 5em;
			}
			.hero {
				text-align: center;
				padding: 2em 0 2.5em;
				position: relative;
			}
			.badge {
				display: inline-block;
				background: var(--badge-bg);
				color: var(--badge-color);
				border: 1px solid var(--badge-border);
				padding: 0.4em 1.2em;
				border-radius: 20px;
				font-size: 0.85rem;
				font-weight: 600;
				margin-bottom: 1.5em;
				box-shadow: 0 0 15px rgba(99, 102, 241, 0.15);
				transition: all 0.3s ease;
			}
			.hero h1 {
				font-size: 3.5rem;
				font-weight: 800;
				margin-bottom: 0.4em;
				line-height: 1.2;
				letter-spacing: -1px;
				background: var(--hero-title-gradient);
				-webkit-background-clip: text;
				-webkit-text-fill-color: transparent;
			}
			.hero p {
				font-size: 0.95rem;
				color: var(--text-muted);
				max-width: 600px;
				margin: 0 auto 2em;
				line-height: 1.6;
			}

			/* 🔍 中央搜索框 */
			.search-wrapper {
				max-width: 640px;
				margin: 0 auto 2.5em;
				position: relative;
			}
			.search-input-box {
				width: 100%;
				padding: 1.1em 1.5em 1.1em 3.2em;
				background: var(--search-bg);
				backdrop-filter: blur(16px);
				border: 1px solid var(--card-border);
				border-radius: 16px;
				color: var(--text-main);
				font-size: 1.05rem;
				outline: none;
				box-sizing: border-box;
				box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
				transition: all 0.3s ease;
			}
			.search-input-box:focus {
				border-color: var(--accent);
				box-shadow: 0 0 25px var(--accent-glow);
			}
			.search-icon {
				position: absolute;
				left: 1.2em;
				top: 50%;
				transform: translateY(-50%);
				font-size: 1.2rem;
				opacity: 0.6;
				pointer-events: none;
			}

			/* 📦 标题栏 */
			.section-title-wrapper {
				display: flex;
				align-items: center;
				justify-content: space-between;
				margin-bottom: 1.2rem;
			}
			.section-title {
				font-size: 1.35rem;
				font-weight: 700;
				letter-spacing: -0.5px;
				color: var(--text-main);
				margin: 0;
			}
			.result-count-badge {
				font-size: 0.82rem;
				color: var(--text-muted);
				font-weight: 600;
				background: var(--gray-light);
				padding: 0.25em 0.7em;
				border-radius: 12px;
				border: 1px solid var(--card-border);
			}

			/* ⚡ 网格布局：恢复改版前标准的 3 列高颜值科技网格 */
			.tool-grid {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
				gap: 1.5rem;
			}

			/* 💎 还原改版前的标准科技感大卡片 (.tool-card) */
			.tool-card {
				background: var(--bg-card) !important;
				backdrop-filter: blur(12px) !important;
				-webkit-backdrop-filter: blur(12px) !important;
				border: 1px solid var(--card-border) !important;
				border-radius: 16px !important;
				padding: 1.8rem !important;
				text-decoration: none !important;
				color: var(--text-main) !important;
				display: flex !important;
				flex-direction: column !important;
				position: relative !important;
				box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05) !important;
				transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1) !important;
				box-sizing: border-box !important;
			}

			.tool-card:hover {
				transform: translateY(-6px) !important;
				border-color: var(--accent) !important;
				box-shadow: 0 12px 30px -5px var(--accent-glow) !important;
			}

			.tool-icon {
				font-size: 2.2rem !important;
				margin-bottom: 1rem !important;
				line-height: 1 !important;
			}

			.tool-card h3 {
				font-size: 1.25rem !important;
				font-weight: 700 !important;
				margin-bottom: 0.6rem !important;
				color: var(--text-main) !important;
				line-height: 1.3 !important;
			}

			.tool-card p {
				font-size: 0.92rem !important;
				color: var(--text-muted) !important;
				flex: 1 !important;
				margin-bottom: 1.2rem !important;
				line-height: 1.6 !important;
			}

			/* 底部 Tag & Badge 恢复 */
			.tool-card-footer {
				display: flex !important;
				justify-content: space-between !important;
				align-items: center !important;
				margin-top: auto !important;
			}

			.tool-tag {
				font-size: 0.75rem !important;
				font-weight: 700 !important;
				text-transform: uppercase !important;
				letter-spacing: 0.5px !important;
			}

			.tag-tool { color: var(--cyan) !important; }
			.tag-blog { color: var(--accent) !important; }
			.tag-sponsor { color: #f59e0b !important; }

			.type-badge {
				font-size: 0.7rem !important;
				padding: 0.2em 0.6em !important;
				border-radius: 6px !important;
				font-weight: 700 !important;
				text-transform: uppercase !important;
			}
			.badge-tool { background: rgba(6, 182, 212, 0.15) !important; color: var(--cyan) !important; border: 1px solid rgba(6, 182, 212, 0.25) !important; }
			.badge-blog { background: rgba(99, 102, 241, 0.15) !important; color: var(--accent) !important; border: 1px solid rgba(99, 102, 241, 0.25) !important; }
			.badge-sponsor { background: rgba(245, 158, 11, 0.15) !important; color: #f59e0b !important; border: 1px solid rgba(245, 158, 11, 0.3) !important; }

			.pinned-icon {
				position: absolute !important;
				top: 1rem !important;
				right: 1rem !important;
				font-size: 0.9rem !important;
				opacity: 0.8 !important;
			}

			.no-results {
				text-align: center;
				padding: 4em 1em;
				color: var(--text-muted);
				grid-column: 1 / -1;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<div class="badge">🚀 Micro AI Tools for Big Help</div>
				<h1>HelpMini</h1>
				
				<!-- 🔍 中央搜索框 -->
				<div class="search-wrapper">
					<span class="search-icon">🔍</span>
					<input
						type="text"
						id="searchInput"
						class="search-input-box"
						placeholder="Search tools, guides, or keywords... (e.g., SEO, Token, Prompt)"
						autocomplete="off"
					/>
				</div>
			</section>

			<!-- 📦 统一内容展示区 -->
			<section>
				<div class="section-title-wrapper">
					<h2 id="sectionTitle" class="section-title">Featured Micro Tools</h2>
					<span id="resultCount" class="result-count-badge"></span>
				</div>
				
				<div id="contentGrid" class="tool-grid"></div>
			</section>

			<section class="hero" style="padding-top: 4em;">
				<p>Lightweight, instant productivity tools that save you hours.</p>
			</section>
		</main>
		<Footer />

		<!-- 客户端 JavaScript 逻辑 -->
		<script is:inline define:vars={{ allSearchableItems }}>
			const searchInput = document.getElementById('searchInput');
			const sectionTitle = document.getElementById('sectionTitle');
			const resultCount = document.getElementById('resultCount');
			const contentGrid = document.getElementById('contentGrid');

			// 置顶与权重排序逻辑
			function sortItems(items) {
				return [...items].sort((a, b) => {
					if (a.pinned && !b.pinned) return -1;
					if (!a.pinned && b.pinned) return 1;
					return (b.priority || 0) - (a.priority || 0);
				});
			}

			// 渲染改版前的精美大卡片
			function renderItems(items) {
				if (!contentGrid) return;

				if (items.length === 0) {
					contentGrid.innerHTML = `
						<div class="no-results">
							<div style="font-size: 2.5rem; margin-bottom: 0.5rem;">🔍</div>
							<p style="font-size: 1.1rem; font-weight: 600;">No matching tools or guides found</p>
							<p style="font-size: 0.88rem; opacity: 0.8;">Try searching for other keywords like "SEO", "JSON", or "Token"</p>
						</div>
					`;
					return;
				}

				contentGrid.innerHTML = items.map(item => {
					const isExternal = item.url.startsWith('http');
					const tagClass = item.type === 'sponsor' ? 'tag-sponsor' : (item.type === 'blog' ? 'tag-blog' : 'tag-tool');
					const typeBadgeClass = item.type === 'sponsor' ? 'badge-sponsor' : (item.type === 'blog' ? 'badge-blog' : 'badge-tool');
					const typeLabel = item.type === 'sponsor' ? 'Ad' : (item.type === 'blog' ? 'Blog' : 'Tool');

					return `
						<a href="${item.url}" class="tool-card" ${isExternal ? 'target="_blank" rel="noopener"' : ''}>
							${item.pinned ? '<span class="pinned-icon" title="Pinned">📌</span>' : ''}
							<div class="tool-icon">${item.icon}</div>
							<h3>${item.title}</h3>
							<p>${item.desc}</p>
							<div class="tool-card-footer">
								<span class="tool-tag ${tagClass}">${item.tag || 'Tool'}</span>
								<span class="type-badge ${typeBadgeClass}">${typeLabel}</span>
							</div>
						</a>
					`;
				}).join('');
			}

			// 初始化默认视图（未搜索时最多显示前 20 个）
			function initDefaultView() {
				const sorted = sortItems(allSearchableItems);
				const default20 = sorted.slice(0, 20);
				
				if (sectionTitle) sectionTitle.textContent = 'Featured Micro Tools';
				if (resultCount) resultCount.textContent = `${default20.length} items`;
				
				renderItems(default20);
			}

			// 搜索过滤与原位切换
			searchInput?.addEventListener('input', (e) => {
				const query = e.target.value.toLowerCase().trim();

				if (!query) {
					initDefaultView();
					return;
				}

				const filtered = allSearchableItems.filter(item =>
					item.title.toLowerCase().includes(query) ||
					item.desc.toLowerCase().includes(query) ||
					item.keywords.toLowerCase().includes(query)
				);

				const sortedResults = sortItems(filtered);

				if (sectionTitle) sectionTitle.textContent = 'Search Results';
				if (resultCount) resultCount.textContent = `${sortedResults.length} found`;

				renderItems(sortedResults);
			});

			initDefaultView();
		</script>
	</body>
</html>
