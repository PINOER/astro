---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';

// 获取当前访问的路径，例如 "/about" 或 "/zh/about"
const pathname = Astro.url.pathname;

// 判断当前是否处于中文页面
const isChinese = pathname.startsWith('/zh') || pathname.includes('/zh/');

// 动态计算切换后的英文与中文路径
// 1. 如果当前是中文路径 (/zh/tools)，英文路径为把 /zh 移除后的路径 (/tools)
// 2. 如果当前是英文路径 (/tools)，中文路径为加上 /zh 前缀 (/zh/tools)
const cleanPath = pathname.replace(/^\/zh(\/|$)/, '/');
const enPath = cleanPath || '/';
const zhPath = cleanPath === '/' ? '/zh' : `/zh${cleanPath.startsWith('/') ? '' : '/'}${cleanPath}`;
---

<header>
	<nav>
		<h2><a href={isChinese ? "/zh" : "/"} >{SITE_TITLE}</a></h2>
		<div class="internal-links">
			<HeaderLink href={isChinese ? "/zh" : "/"}>Home</HeaderLink>
			<HeaderLink href={isChinese ? "/zh/blog" : "/blog"}>Blog</HeaderLink>
			<HeaderLink href={isChinese ? "/zh/about" : "/about"}>About</HeaderLink>
			
			<!-- 全站智能语言切换按钮 -->
			<div class="lang-switch">
				<a href={enPath} class={!isChinese ? 'active' : ''}>EN</a>
				<span class="divider">/</span>
				<a href={zhPath} class={isChinese ? 'active' : ''}>中文</a>
			</div>
		</div>

		<div class="social-links">
			<a href="https://github.com/withastro/astro" target="_blank">
				<span class="sr-only">GitHub</span>
				<svg viewBox="0 0 16 16" aria-hidden="true" width="32" height="32"><path fill="currentColor" d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"></path></svg>
			</a>
		</div>
	</nav>
</header>

<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: white;
		box-shadow: 0 2px 8px rgba(var(--black), 5%);
	}
	h2 { margin: 0; font-size: 1em; }
	h2 a { text-decoration: none; }
	nav { display: flex; align-items: center; justify-content: space-between; }
	.internal-links { display: flex; align-items: center; gap: 0.5rem; }
	nav a { padding: 1em 0.5em; color: var(--black); border-bottom: 4px solid transparent; text-decoration: none; }
	nav a.active { border-bottom-color: var(--accent); }
	
	.lang-switch {
		display: inline-flex;
		align-items: center;
		gap: 0.2rem;
		margin-left: 0.8rem;
		font-size: 0.85rem;
		font-weight: 600;
		background: rgba(0, 0, 0, 0.04);
		padding: 0.2em 0.6em;
		border-radius: 16px;
	}
	.lang-switch a {
		padding: 0.2em 0.3em !important;
		color: var(--gray, #666) !important;
		border-bottom: none !important;
		text-decoration: none !important;
		line-height: 1;
	}
	.lang-switch a.active {
		color: var(--accent, #0070f3) !important;
		font-weight: 700 !important;
	}
	.lang-switch .divider { color: #ccc; font-size: 0.8rem; }
	.social-links { display: flex; }
</style>
