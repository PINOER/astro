<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 800 400" style="width: 100%; height: auto; border-radius: 16px; background: #0f172a; border: 1px solid rgba(255,255,255,0.1);">
  <!-- Background Glow -->
  <defs>
    <linearGradient id="grad1" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#6366f1;stop-opacity:0.2" />
      <stop offset="100%" style="stop-color:#06b6d4;stop-opacity:0.1" />
    </linearGradient>
  </defs>
  <rect width="800" height="400" fill="url(#grad1)" rx="16"/>

  <!-- Left: Messy Input -->
  <rect x="50" y="80" width="310" height="240" rx="12" fill="#1e293b" stroke="#334155" stroke-width="1.5"/>
  <text x="70" y="115" fill="#ef4444" font-family="monospace" font-size="14" font-weight="bold">❌  HTML</text>
  <text x="70" y="155" fill="#94a3b8" font-family="monospace" font-size="12">```markdown</text>
  <text x="70" y="185" fill="#f43f5e" font-family="monospace" font-size="12">&lt;span&gt;Hello World&lt;/span&gt;&lt;br&gt;</text>
  <text x="70" y="215" fill="#94a3b8" font-family="monospace" font-size="12">&lt;p&gt;Excessive blank lines...&lt;/p&gt;</text>
  <text x="70" y="275" fill="#94a3b8" font-family="monospace" font-size="12">```</text>

  <!-- Arrow/Transform Icon -->
  <circle cx="400" cy="200" r="28" fill="#6366f1"/>
  <path d="M390 200 L410 200 M404 194 L410 200 L404 206" stroke="#ffffff" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>

  <!-- Right: Clean Output -->
  <rect x="440" y="80" width="310" height="240" rx="12" fill="#1e293b" stroke="#06b6d4" stroke-width="1.5"/>
  <text x="460" y="115" fill="#10b981" font-family="monospace" font-size="14" font-weight="bold">✓  Markdown</text>
  <text x="460" y="155" fill="#e2e8f0" font-family="monospace" font-size="13" font-weight="bold"># Hello World</text>
  <text x="460" y="195" fill="#cbd5e1" font-family="monospace" font-size="12">Properly spaced paragraphs</text>
  <text x="460" y="225" fill="#cbd5e1" font-family="monospace" font-size="12">and clean markdown text.</text>
</svg>
